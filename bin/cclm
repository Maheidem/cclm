# schema_display: thin wrapper that pins the canonical call shape across
# backends. Takes a profile path and a schema array (spread with "${arr[@]}").
schema_display() {
  display_profile_and_ask "$@"
}

# Human-readable file size
human_size() {
  local bytes=$1
  if (( bytes >= 1073741824 )); then
    printf "%.1f GB" "$(( bytes / 1073741824.0 ))"
  elif (( bytes >= 1048576 )); then
    printf "%.1f MB" "$(( bytes / 1048576.0 ))"
  else
    printf "%.1f KB" "$(( bytes / 1024.0 ))"
  fi
}

# Last session state (populated by load_last_session)
last_backend="" last_profile="" last_remote="" last_model=""

# Load last session state from STATE_FILE. Always returns 0; caller checks
# whether last_backend/last_profile are populated.
load_last_session() {
  if [[ -f "$STATE_FILE" ]]; then
    last_backend=$(jq -r '.backend // empty' "$STATE_FILE" 2>/dev/null || true)
    last_profile=$(jq -r '.profile // empty' "$STATE_FILE" 2>/dev/null || true)
    last_remote=$(jq -r '.remote_host // empty' "$STATE_FILE" 2>/dev/null || true)
    last_model=$(jq -r '.model // empty' "$STATE_FILE" 2>/dev/null || true)
  fi
  return 0
}

# Save last session state to STATE_FILE. Best-effort — warns but does not
# abort cclm if write fails (e.g. disk full, read-only FS).
save_last_session() {
  local backend="$1" profile="$2" remote_host="$3" model="$4"
  local _tmp
  _tmp="$(mktemp 2>/dev/null)" || { echo "Warning: could not create temp file for state save" >&2; return 0; }
  if ! jq -n \
    --arg be "$backend" \
    --arg prof "$profile" \
    --arg rh "${remote_host:-}" \
    --arg mod "$model" \
    '{backend: $be, profile: $prof, remote_host: $rh, model: $mod}' > "$_tmp" 2>/dev/null
  then
    rm -f "$_tmp"
    echo "Warning: could not save last-session state" >&2
    return 0
  fi
  mv "$_tmp" "$STATE_FILE" 2>/dev/null || { rm -f "$_tmp"; echo "Warning: could not write $STATE_FILE" >&2; }
  return 0
}

# Append-only session log. JSONL at $SESSION_LOG_FILE. One line per launch.
# NOTE: we can only record ts_start — `launch_claude` ends with `exec claude`,
# which replaces the process, so no post-run hook can write ts_end. Rotation
# is intentionally not implemented; leave that for future.
SESSION_LOG_DIR="${CCLM_CACHE_DIR:-$HOME/.cache/cclm}"
SESSION_LOG_FILE="$SESSION_LOG_DIR/sessions.log"

log_session() {
  local backend="$1" host="$2" model="$3" profile_basename="$4"
  mkdir -p "$SESSION_LOG_DIR" 2>/dev/null || return 0
  local ts_start
  ts_start=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  jq -n -c \
    --arg ts "$ts_start" \
    --arg be "$backend" \
    --arg prof "$profile_basename" \
    --arg host "$host" \
    --arg model "$model" \
    --arg pid "$$" \
    '{ts_start: $ts, backend: $be, profile_basename: $prof, host: $host, model: $model, pid: ($pid|tonumber)}' \
    >> "$SESSION_LOG_FILE" 2>/dev/null || true
  return 0
}

# ============================================================================
# Per-profile MCP servers
# ============================================================================
# Profiles may optionally carry an `mcp_servers` JSON object (name -> config).
# When present, apply_mcp_servers merges it into Claude Code's global config
# (`~/.claude.json` .mcpServers), after backing the original up so we can
# restore on exit or on next cclm run.
#
# IMPORTANT: launch_claude ends with `exec claude` which replaces this shell,
# so the EXIT trap set here never fires on a successful launch. The backup is
# instead picked up at the NEXT cclm startup (see the stale-backup guard below
# the CCLM_LIB_ONLY return). The EXIT trap exists only to handle the cclm-dies-
# before-exec case (jq merge failure, dry-run, signal).

# Restore the original claude.json from backup if one exists. Idempotent / no-op
# when there's nothing to restore. Called from the EXIT trap and from startup.
restore_claude_config() {
  [[ -f "$CCLM_CLAUDE_BACKUP" ]] || return 0
  # Backup may be a zero-byte marker — meaning claude.json didn't exist at
  # merge time — in which case "restore" means deleting the file we created.
  if [[ ! -s "$CCLM_CLAUDE_BACKUP" ]]; then
    rm -f "$CCLM_CLAUDE_CONFIG"
    rm -f "$CCLM_CLAUDE_BACKUP"
    return 0
  fi
  mv -f "$CCLM_CLAUDE_BACKUP" "$CCLM_CLAUDE_CONFIG" 2>/dev/null \
    || { echo "cclm: failed to restore $CCLM_CLAUDE_CONFIG from backup" >&2; return 1; }
  return 0
}

# Merge .mcp_servers from a profile into ~/.claude.json's .mcpServers.
# Args: profile_path
# - Returns 0 and does nothing when the profile has no .mcp_servers.
# - Backs up the existing claude.json (overwriting any prior backup) before
#   writing. If the claude.json is missing, a zero-byte marker backup is used
#   so restore knows to delete rather than restore.
# - On DRY_RUN=true, prints what WOULD be written to stdout and skips writes.
# - On any jq failure, prints an error and returns non-zero so callers abort.
apply_mcp_servers() {
  local profile="$1"
  [[ -f "$profile" ]] || return 0

  local add
  add=$(jq -c '.mcp_servers // empty' "$profile" 2>/dev/null) || {
    echo "cclm: failed to read mcp_servers from $profile" >&2
    return 1
  }
  # No mcp_servers field (or explicit null/empty) — nothing to do.
  [[ -z "$add" || "$add" == "null" ]] && return 0

  # Read current claude.json; treat missing/empty as {}.
  local current="{}"
  if [[ -f "$CCLM_CLAUDE_CONFIG" ]]; then
    current=$(jq -c '.' "$CCLM_CLAUDE_CONFIG" 2>/dev/null) || {
      echo "cclm: $CCLM_CLAUDE_CONFIG is not valid JSON — aborting" >&2
      return 1
    }
  fi

  # Merge: RHS wins on same-named keys → profile overrides any existing server
  # with the same name. This is the `+` semantics for jq objects.
  local merged
  merged=$(jq -n --argjson cur "$current" --argjson add "$add" \
    '$cur + {mcpServers: (($cur.mcpServers // {}) + $add)}' 2>/dev/null) || {
    echo "cclm: failed to merge mcp_servers into $CCLM_CLAUDE_CONFIG" >&2
    return 1
  }

  if [[ "${DRY_RUN:-false}" == "true" ]]; then
    echo "# --- would write to $CCLM_CLAUDE_CONFIG ---" >&2
    echo "$merged"
    return 0
  fi

  # Back up (overwriting any stale backup) before any write.
  if [[ -f "$CCLM_CLAUDE_CONFIG" ]]; then
    cp -f "$CCLM_CLAUDE_CONFIG" "$CCLM_CLAUDE_BACKUP" || {
      echo "cclm: failed to back up $CCLM_CLAUDE_CONFIG" >&2
      return 1
    }
  else
    # Record absence so restore removes the file we created (zero-byte marker).
    : > "$CCLM_CLAUDE_BACKUP" || {
      echo "cclm: failed to create backup marker at $CCLM_CLAUDE_BACKUP" >&2
      return 1
    }
  fi

  # Mark the backup as "live" — the shell-level TRAPEXIT / TRAPINT / TRAPTERM
  # hooks installed at global scope (below the CCLM_LIB_ONLY guard) check this
  # flag and restore on cclm exit. zsh scopes `trap … EXIT` and `TRAPEXIT`
  # function definitions to the enclosing function (unlike bash), so setting
  # the trap from inside apply_mcp_servers would fire at function return — not
  # at cclm exit. Instead we rely on the module-level hooks reading this flag.
  # On a successful `exec claude` the flag is discarded with the replaced
  # process; the next cclm startup sees the stale backup and restores it.
  _CCLM_MCP_ARMED=1

  # Atomic write via tempfile to keep claude.json intact if disk fills mid-write.
  local _tmp
  _tmp=$(mktemp 2>/dev/null) || {
    echo "cclm: failed to create temp file for claude.json write" >&2
    return 1
  }
  printf '%s\n' "$merged" > "$_tmp" && mv -f "$_tmp" "$CCLM_CLAUDE_CONFIG" || {
    rm -f "$_tmp"
    echo "cclm: failed to write $CCLM_CLAUDE_CONFIG" >&2
    return 1
  }
  return 0
}

# Set env vars and launch claude. Args: mode, api_id, host, port, context_length, extra_claude_args...
# mode is "exec" (replaces process) or "fg" (foreground, returns when done)
launch_claude() {
  local mode="$1" api_id="$2" host="$3" port="$4" ctx="$5"
  shift 5

  # Base URL: accept a full http(s):// URL in $host (remote providers like Z.ai),
  # otherwise build http://host:port (local backends).
  if [[ "$host" =~ ^https?:// ]]; then
    export ANTHROPIC_BASE_URL="$host"
  else
    export ANTHROPIC_BASE_URL="http://${host}:${port}"
  fi

  # Auth: real token (remote providers) vs placeholder (local).
  # CCLM_AUTH_TOKEN is set by backends that talk to real cloud endpoints.
  # Unset it after consumption so it can't leak to MCP servers, hooks, or subagents.
  if [[ -n "${CCLM_AUTH_TOKEN:-}" ]]; then
    export ANTHROPIC_AUTH_TOKEN="$CCLM_AUTH_TOKEN"
    unset CCLM_AUTH_TOKEN
    unset ANTHROPIC_API_KEY
  else
    export ANTHROPIC_API_KEY="lmstudio"
    unset ANTHROPIC_AUTH_TOKEN
  fi
  # Always clear subscription tokens and provider-routing env vars so they can't leak through.
  unset CLAUDE_CODE_OAUTH_TOKEN
  unset CLAUDE_CODE_OAUTH_REFRESH_TOKEN
  unset CLAUDE_CODE_USE_BEDROCK
  unset CLAUDE_CODE_USE_VERTEX
  unset ANTHROPIC_BEDROCK_BASE_URL
  unset ANTHROPIC_VERTEX_PROJECT_ID
  unset ANTHROPIC_CUSTOM_HEADERS

  export ANTHROPIC_MODEL="$api_id"
  # Per-tier routing: backends that support distinct models per Claude tier
  # (Z.ai) set CCLM_TIER_OPUS / CCLM_TIER_SONNET / CCLM_TIER_HAIKU. Local backends
  # leave them unset, so all three tiers collapse to $api_id (single loaded model).

  # Apply [1m] suffix to the resolved model names so Claude Code uses
  # a 1M context ceiling instead of the 200K default for standard models.
  # Local backends ignore the model field; cloud backends (Z/remote)
  # already have large capacities but Claude Code still caps them at 200K.
  export _CCLM_FAKE_OPUS="${CCLM_TIER_OPUS:-$api_id}[1m]"
  export _CCLM_FAKE_SONNET="${CCLM_TIER_SONNET:-$api_id}[1m]"
  export _CCLM_FAKE_HAIKU="${CCLM_TIER_HAIKU:-$api_id}[1m]"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$_CCLM_FAKE_OPUS"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$_CCLM_FAKE_SONNET"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="$_CCLM_FAKE_HAIKU"
  export CLAUDE_CODE_SUBAGENT_MODEL="$_CCLM_FAKE_HAIKU"

  export CLAUDE_CODE_MAX_CONTEXT_TOKENS="$ctx"
  export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$ctx"

  # Remote providers can be slower than Claude on long traces; Z.ai recommends 3000000.
  if [[ -n "${CCLM_API_TIMEOUT_MS:-}" ]]; then
    export API_TIMEOUT_MS="$CCLM_API_TIMEOUT_MS"
  fi

  export CLAUDE_CODE_ATTRIBUTION_HEADER="0"
  export DISABLE_TELEMETRY="1"
  export DISABLE_ERROR_REPORTING="1"
  export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"
  export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING="1"

  echo "" >&2
  echo "Model:   $_CCLM_FAKE_SONNET" >&2
  echo "Backend: $ANTHROPIC_BASE_URL" >&2
  echo "Context: ${ctx} tokens  (CLAUDE_CODE_AUTO_COMPACT_WINDOW=${ctx})" >&2
  echo "" >&2

  # Merge per-profile MCP servers into ~/.claude.json (no-op if the profile
  # lacks `.mcp_servers`). Runs before DRY_RUN so dry-runs still surface what
  # WOULD be written. Hard-fail on jq errors — don't exec claude with a busted
  # config. The EXIT trap is installed inside apply_mcp_servers after a
  # successful backup; `exec claude` below discards the trap on success, and
  # the next cclm startup restores from the backup (see stale-backup guard).
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    if ! apply_mcp_servers "$_PRELOADED_PROFILE"; then
      echo "cclm: refusing to launch claude with an unmerged MCP config" >&2
      exit 1
    fi
  fi

  # --dry-run / --print-env: print the env vars cclm manages and the command
  # that WOULD have been exec'd, then exit 0 without invoking claude.
  # Do NOT log dry-runs — only real launches are recorded.
  if [[ "${DRY_RUN:-false}" == "true" ]]; then
    env | grep -E '^(ANTHROPIC|CCLM|CLAUDE_CODE)_' | sort
    print -r -- "claude --model ${(q)_CCLM_FAKE_SONNET} ${(q-)@}"
    exit 0
  fi

  # Append-only session log. Reads backend/profile from the just-written
  # STATE_FILE (all backends call save_last_session immediately before
  # launch_claude, so the file is fresh). exec-replaces-process means we
  # cannot record ts_end — see log_session docs.
  local _log_backend="" _log_profile=""
  if [[ -f "$STATE_FILE" ]]; then
    _log_backend=$(jq -r '.backend // ""' "$STATE_FILE" 2>/dev/null || true)
    _log_profile=$(jq -r '.profile // ""' "$STATE_FILE" 2>/dev/null || true)
  fi
  log_session "$_log_backend" "$host" "$api_id" "$_log_profile"

  if [[ "$mode" == "exec" ]]; then
    exec claude --model "$_CCLM_FAKE_SONNET" "$@"
  else
    claude --model "$_CCLM_FAKE_SONNET" "$@"
  fi
}

# ============================================================================
# Ollama Backend
# ============================================================================
# Ollama exposes an OpenAI-compatible API at http://<host>:11434/v1.
# Shape mirrors run_remote() but defaults to port 11434 and tags profiles
# as ollama-<slug>.json so they're distinguishable in the picker.
# Defined above the CCLM_LIB_ONLY guard so unit tests can assert on its
# existence without triggering backend execution.

run_ollama() {
  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    # Resolve the profile once (applies any `extends` chain) and re-point
    # the jq reads at the resolved JSON. Falls back to the raw file if
    # resolve fails so a typo in `extends` still surfaces as an error rather
    # than silently corrupting the launch.
    local resolved_file
    resolved_file=$(mktemp -t cclm_resolved.XXXXXX) || {
      echo "cclm: failed to create tmp file for profile resolve" >&2
      return 1
    }
    # shellcheck disable=SC2064 — we want the resolved_file expanded now.
    trap "rm -f '$resolved_file'" EXIT
    if ! _cclm_read_profile "$_PRELOADED_PROFILE" > "$resolved_file" 2>/dev/null; then
      # Re-run without suppression to surface the error, then fail.
      _cclm_read_profile "$_PRELOADED_PROFILE" > /dev/null
      rm -f "$resolved_file"
      trap - EXIT
      return 1
    fi

    local _pl_host _pl_port _pl_model _pl_ctx
    _pl_host=$(jq -r '.host // ""' "$resolved_file")
    _pl_port=$(jq -r '.port // "11434"' "$resolved_file")
    _pl_model=$(jq -r '.model // ""' "$resolved_file")
    _pl_ctx=$(jq -r '.context_length // "65536"' "$resolved_file")

    # Values extracted — tmp file no longer needed. Drop it now so the
    # `exec claude` at the end of launch_claude doesn't leak /tmp entries.
    rm -f "$resolved_file"
    trap - EXIT

    if [[ "${_PRELOADED_ACTION:-open}" == "open" ]]; then
      echo "" >&2
      echo "  [ollama] $_pl_model @ ${_pl_host}:${_pl_port}" >&2
      save_last_session "ollama" "$(basename "$_PRELOADED_PROFILE")" "$_pl_host" "$_pl_model"
      launch_claude exec "$_pl_model" "$_pl_host" "$_pl_port" "$_pl_ctx" "${passthrough_args[@]}"
      return
    fi
    # Edit: fall through with defaults pre-filled
  fi

  # --- New session: collect host[:port] (ollama default port 11434) ---
  local hp_default="${_pl_host:-localhost}${_pl_port:+:$_pl_port}"
  [[ "$hp_default" == "localhost" ]] && hp_default="localhost:11434"
  local hp
  if [[ -n "${remote_host:-}" ]]; then
    hp="${remote_host}:${_pl_port:-11434}"
  else
    hp=$(ask "Ollama endpoint (host or host:port, default port 11434)" "$hp_default")
  fi
  if [[ -z "$hp" ]]; then
    echo "Host is required." >&2
    exit 1
  fi

  local o_host o_port
  if [[ "$hp" == *:* ]]; then
    o_host="${hp%:*}"
    o_port="${hp##*:}"
  else
    o_host="$hp"
    o_port="11434"
  fi
  local o_url="http://${o_host}:${o_port}"

  # --- Best-effort model picker via /v1/models (single try, short timeout) ---
  local o_model="${_pl_model:-}"
  local api_models
  api_models=$(curl -sf --max-time 2 "${o_url}/v1/models" 2>/dev/null | jq -r '.data[].id // empty' 2>/dev/null | grep -v 'embedding' || true)

  if [[ -n "$api_models" ]]; then
    echo "" >&2
    echo "Models on ${o_host}:${o_port}:" >&2
    echo "" >&2
    local -a model_list=()
    local count=0 mid
    while IFS= read -r mid; do
      [[ -z "$mid" ]] && continue
      count=$((count + 1))
      model_list+=("$mid")
      printf "  %d) %s\n" "$count" "$mid" >&2
    done <<< "$api_models"
    echo "  m) Enter model id manually" >&2
    echo "" >&2
    printf "Select (1-%d or m): " "$count" >&2
    read -r selection
    if [[ "$selection" == "m" || "$selection" == "M" ]]; then
      o_model=$(ask "Model id" "$o_model")
    elif [[ "$selection" =~ ^[0-9]+$ ]] && (( selection >= 1 && selection <= count )); then
      o_model="${model_list[$selection]}"
    else
      echo "Invalid selection." >&2
      exit 1
    fi
  else
    echo "" >&2
    echo "  (/v1/models unreachable or empty — enter model id manually)" >&2
    o_model=$(ask "Model id" "$o_model")
  fi

  if [[ -z "$o_model" ]]; then
    echo "Model id is required." >&2
    exit 1
  fi

  # --- Context window ---
  local o_ctx
  o_ctx=$(ask "Context window (tokens)" "${_pl_ctx:-65536}")

  # --- Save profile (with validation) ---
  local o_profile="$CONFIG_DIR/ollama-$(slug "${o_host}-${o_model}").json"
  if [[ "${DRY_RUN:-false}" != "true" && "${CCLM_SKIP_VALIDATE:-0}" != "1" ]]; then
    if ! _cclm_validate_endpoint "$o_url" "$o_model" "ollama"; then
      if ! _cclm_confirm_unreachable_save; then
        echo "Profile not saved. You can re-run cclm to try again." >&2
        return 1
      fi
    fi
  fi
  jq -n \
    --arg host "$o_host" \
    --arg port "$o_port" \
    --arg model "$o_model" \
    --arg ctx "$o_ctx" \
    '{host: $host, port: $port, model: $model, context_length: $ctx}' > "$o_profile"
  echo "" >&2
  echo "Profile saved: $o_profile" >&2

  save_last_session "ollama" "$(basename "$o_profile")" "$o_host" "$o_model"
  launch_claude exec "$o_model" "$o_host" "$o_port" "$o_ctx" "${passthrough_args[@]}"
}

# ============================================================================
# vLLM Backend
# ============================================================================
# vLLM exposes an OpenAI-compatible API at http://<host>:8000/v1.
# Shape mirrors run_ollama() but defaults to port 8000 and tags profiles
# as vllm-<slug>.json so they're distinguishable in the picker.
# Defined above the CCLM_LIB_ONLY guard so unit tests can assert on its
# existence without triggering backend execution.

run_vllm() {
  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    local _pl_host _pl_port _pl_model _pl_ctx
    _pl_host=$(jq -r '.host // ""' "$_PRELOADED_PROFILE")
    _pl_port=$(jq -r '.port // "8000"' "$_PRELOADED_PROFILE")
    _pl_model=$(jq -r '.model // ""' "$_PRELOADED_PROFILE")
    _pl_ctx=$(jq -r '.context_length // "65536"' "$_PRELOADED_PROFILE")

    if [[ "${_PRELOADED_ACTION:-open}" == "open" ]]; then
      echo "" >&2
      echo "  [vllm] $_pl_model @ ${_pl_host}:${_pl_port}" >&2
      save_last_session "vllm" "$(basename "$_PRELOADED_PROFILE")" "$_pl_host" "$_pl_model"
      launch_claude exec "$_pl_model" "$_pl_host" "$_pl_port" "$_pl_ctx" "${passthrough_args[@]}"
      return
    fi
    # Edit: fall through with defaults pre-filled
  fi

  # --- New session: collect host[:port] (vllm default port 8000) ---
  local hp_default="${_pl_host:-localhost}${_pl_port:+:$_pl_port}"
  [[ "$hp_default" == "localhost" ]] && hp_default="localhost:8000"
  local hp
  if [[ -n "${remote_host:-}" ]]; then
    hp="${remote_host}:${_pl_port:-8000}"
  else
    hp=$(ask "vLLM endpoint (host or host:port, default port 8000)" "$hp_default")
  fi
  if [[ -z "$hp" ]]; then
    echo "Host is required." >&2
    exit 1
  fi

  local v_host v_port
  if [[ "$hp" == *:* ]]; then
    v_host="${hp%:*}"
    v_port="${hp##*:}"
  else
    v_host="$hp"
    v_port="8000"
  fi
  local v_url="http://${v_host}:${v_port}"

  # --- Best-effort model picker via /v1/models (single try, short timeout) ---
  local v_model="${_pl_model:-}"
  local api_models
  api_models=$(curl -sf --max-time 2 "${v_url}/v1/models" 2>/dev/null | jq -r '.data[].id // empty' 2>/dev/null | grep -v 'embedding' || true)

  if [[ -n "$api_models" ]]; then
    echo "" >&2
    echo "Models on ${v_host}:${v_port}:" >&2
    echo "" >&2
    local -a model_list=()
    local count=0 mid
    while IFS= read -r mid; do
      [[ -z "$mid" ]] && continue
      count=$((count + 1))
      model_list+=("$mid")
      printf "  %d) %s\n" "$count" "$mid" >&2
    done <<< "$api_models"
    echo "  m) Enter model id manually" >&2
    echo "" >&2
    printf "Select (1-%d or m): " "$count" >&2
    read -r selection
    if [[ "$selection" == "m" || "$selection" == "M" ]]; then
      v_model=$(ask "Model id" "$v_model")
    elif [[ "$selection" =~ ^[0-9]+$ ]] && (( selection >= 1 && selection <= count )); then
      v_model="${model_list[$selection]}"
    else
      echo "Invalid selection." >&2
      exit 1
    fi
  else
    echo "" >&2
    echo "  (/v1/models unreachable or empty — enter model id manually)" >&2
    v_model=$(ask "Model id" "$v_model")
  fi

  if [[ -z "$v_model" ]]; then
    echo "Model id is required." >&2
    exit 1
  fi

  # --- Context window ---
  local v_ctx
  v_ctx=$(ask "Context window (tokens)" "${_pl_ctx:-65536}")

  # --- Save profile (with validation) ---
  local v_profile="$CONFIG_DIR/vllm-$(slug "${v_host}-${v_model}").json"
  if [[ "${DRY_RUN:-false}" != "true" && "${CCLM_SKIP_VALIDATE:-0}" != "1" ]]; then
    if ! _cclm_validate_endpoint "$v_url" "$v_model" "vllm"; then
      if ! _cclm_confirm_unreachable_save; then
        echo "Profile not saved. You can re-run cclm to try again." >&2
        return 1
      fi
    fi
  fi
  jq -n \
    --arg host "$v_host" \
    --arg port "$v_port" \
    --arg model "$v_model" \
    --arg ctx "$v_ctx" \
    '{host: $host, port: $port, model: $model, context_length: $ctx}' > "$v_profile"
  echo "" >&2
  echo "Profile saved: $v_profile" >&2

  save_last_session "vllm" "$(basename "$v_profile")" "$v_host" "$v_model"
  launch_claude exec "$v_model" "$v_host" "$v_port" "$v_ctx" "${passthrough_args[@]}"
}

# ============================================================================
# `cclm log` subcommand
# ============================================================================
# Summarize the append-only session log at $SESSION_LOG_FILE.
#   cclm log                       — last 10 sessions (tabular)
#   cclm log --last 7d             — filter to sessions within last N days
#   cclm log --profile <slug>      — filter to sessions matching profile basename
#                                    (substring match, so `foo` matches `lms-foo.json`)
#   cclm log --json                — dump raw JSONL (filtered, if combined with above)
#
# Date handling: ts_start is written as ISO-8601 UTC (date -u +"%Y-%m-%dT%H:%M:%SZ").
# The `--last Nd` filter parses this exact format with zsh string ops — no locale-
# dependent `date -d`/`date -f` involved, so behavior is identical across macOS/Linux.
# Defined above the CCLM_LIB_ONLY guard so unit tests can call it directly.
cmd_log() {
  local last_filter="" profile_filter="" as_json=false

  while (( $# )); do
    case "$1" in
      --last)
        [[ $# -ge 2 ]] || { echo "--last requires an argument (e.g. 7d)" >&2; return 2; }
        last_filter="$2"; shift ;;
      --last=*) last_filter="${1#--last=}" ;;
      --profile)
        [[ $# -ge 2 ]] || { echo "--profile requires an argument" >&2; return 2; }
        profile_filter="$2"; shift ;;
      --profile=*) profile_filter="${1#--profile=}" ;;
      --json) as_json=true ;;
      -h|--help)
        cat >&2 <<'EOF'
Usage: cclm log [--last Nd] [--profile <slug>] [--json]

Summarize the session log at ~/.cache/cclm/sessions.log.
Records ts_start only (cclm exec-replaces into claude, so ts_end cannot be captured).
EOF
        return 0 ;;
      *) echo "Unknown option: $1" >&2; return 2 ;;
    esac
    shift
  done

  if [[ ! -f "$SESSION_LOG_FILE" ]]; then
    echo "No sessions logged yet."
    return 0
  fi

  # Build a jq filter pipeline. Each stage is a no-op unless a flag is set.
  local jq_filter='.'

  # --last Nd: compute cutoff as "now - N days" in ISO-8601 UTC and
  # keep entries whose ts_start is lexicographically >= cutoff. Lex
  # compare is valid because ISO-8601 UTC strings sort chronologically.
  if [[ -n "$last_filter" ]]; then
    if [[ ! "$last_filter" =~ ^[0-9]+d$ ]]; then
      echo "--last must look like '7d' (N days)" >&2
      return 2
    fi
    local days="${last_filter%d}"
    local cutoff
    # BSD date (macOS) uses -v; GNU date uses -d. Try BSD first, then GNU.
    if cutoff=$(date -u -v-${days}d +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null); then
      :
    elif cutoff=$(date -u -d "${days} days ago" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null); then
      :
    else
      echo "Could not compute cutoff date." >&2
      return 1
    fi
    jq_filter="${jq_filter} | select(.ts_start >= \"${cutoff}\")"
  fi

  if [[ -n "$profile_filter" ]]; then
    # Substring match — user may pass slug or full basename.
    jq_filter="${jq_filter} | select(.profile_basename | contains(\"${profile_filter}\"))"
  fi

  if $as_json; then
    jq -c "$jq_filter" "$SESSION_LOG_FILE" 2>/dev/null
    return 0
  fi

  # Table mode: apply filter, then tail last 10, reformat.
  local rows
  rows=$(jq -c "$jq_filter" "$SESSION_LOG_FILE" 2>/dev/null | tail -10)
  if [[ -z "$rows" ]]; then
    echo "No sessions match."
    return 0
  fi

  printf "%-20s  %-7s  %-30s  %-25s  %s\n" "TIMESTAMP" "BACKEND" "PROFILE" "HOST" "MODEL"
  # Feed the loop via heredoc instead of a pipe so it runs in the current
  # shell. In zsh, a `while ... | done` pipeline puts the body in a subshell,
  # and `local` there echoes variable assignments on subsequent iterations.
  local line ts be prof host model
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    ts=$(echo "$line"     | jq -r '.ts_start // ""')
    be=$(echo "$line"     | jq -r '.backend // ""')
    prof=$(echo "$line"   | jq -r '.profile_basename // ""')
    host=$(echo "$line"   | jq -r '.host // ""')
    model=$(echo "$line"  | jq -r '.model // ""')
    printf "%-20s  %-7s  %-30s  %-25s  %s\n" \
      "${ts:0:19}" "$be" "${prof:0:30}" "${host:0:25}" "$model"
  done <<< "$rows"
  return 0
}

# ============================================================================
# `cclm status` subcommand
# ============================================================================
# Prints a health report without launching claude:
#   - last recorded session
#   - saved profiles grouped by backend
#   - reachability of every distinct host:port across profiles + defaults
#   - LM Studio loaded models (when `lms` CLI is on PATH)
# Section headers go to stderr; data rows go to stdout so it's pipe-safe.
# Never hard-exits on probe failure — backends may legitimately be down.
# Defined above the CCLM_LIB_ONLY guard so unit tests can call it directly.

# Reachability probe against a base URL. Tries /v1/models first (LM Studio,
# Ollama, OpenAI-compat) then falls back to /health (llama-server). Echoes
# "UP" or "DOWN". Always returns 0 so callers under `set -e` aren't killed.
_cclm_probe() {
  local base="$1"
  if curl -sf --max-time 1 "${base}/v1/models" >/dev/null 2>&1; then
    echo "UP"
  elif curl -sf --max-time 1 "${base}/health" >/dev/null 2>&1; then
    echo "UP"
  else
    echo "DOWN"
  fi
  return 0
}

# Render a status marker: colorized on a TTY, plain text otherwise. Keeps
# the literal "UP" / "DOWN" tokens in both paths so grep/tests work.
_cclm_status_marker() {
  local state="$1"
  if [[ -t 1 ]]; then
    if [[ "$state" == "UP" ]]; then
      printf '\033[32m✓ UP\033[0m'
    else
      printf '\033[31m✗ DOWN\033[0m'
    fi
  else
    if [[ "$state" == "UP" ]]; then
      printf '✓ UP'
    else
      printf '✗ DOWN'
    fi
  fi
}

cmd_status() {
  # Populate last_* globals (idempotent, always succeeds).
  load_last_session

  # --- Section 1: last session ---
  echo "Last session:" >&2
  if [[ -n "${last_backend:-}" || -n "${last_profile:-}" ]]; then
    printf "  %-13s %s\n" "backend:"     "${last_backend:-(none)}"
    printf "  %-13s %s\n" "profile:"     "${last_profile:-(none)}"
    printf "  %-13s %s\n" "model:"       "${last_model:-(none)}"
    printf "  %-13s %s\n" "remote_host:" "${last_remote:-local}"
  else
    echo "  (none)"
  fi

  # --- Section 2: saved profiles grouped by backend ---
  echo "" >&2
  echo "Saved profiles (grouped by backend):" >&2
  local -a all_profiles
  all_profiles=( "$CONFIG_DIR"/{lms,llama,zai,remote,ollama,vllm}-*.json(N) )
  if (( ${#all_profiles[@]} == 0 )); then
    echo "  (none)"
  else
    local be f base slug ctx count
    local -a group
    for be in lms llama zai remote ollama vllm; do
      group=( "$CONFIG_DIR"/${be}-*.json(N) )
      count=${#group[@]}
      (( count == 0 )) && continue
      printf "  [%s] (%d)\n" "$be" "$count"
      for f in "${group[@]}"; do
        base="${f:t}"
        # strip "<be>-" prefix and ".json" suffix → slug
        slug="${base#${be}-}"
        slug="${slug%.json}"
        case "$be" in
          llama) ctx=$(jq -r '.ctx_len // "?"' "$f" 2>/dev/null || echo "?") ;;
          *)     ctx=$(jq -r '.context_length // "?"' "$f" 2>/dev/null || echo "?") ;;
        esac
        [[ -z "$ctx" || "$ctx" == "null" ]] && ctx="?"
        printf "    - %-40s ctx:%s\n" "$slug" "$ctx"
      done
    done
  fi

  # --- Section 3: backend reachability ---
  echo "" >&2
  echo "Backend reachability:" >&2

  # Associative set of distinct endpoints: localhost defaults + any host:port
  # seen in profiles. zai uses full URLs and is stored as-is.
  # NOTE: zsh preserves literal quotes in assoc subscripts like `h["k"]` — keys
  # must come from a variable (`k=...; h[$k]=1`) to avoid leaking the quotes.
  local -A endpoints
  local k
  k="localhost:1234";  endpoints[$k]=1     # LM Studio default
  k="localhost:8081";  endpoints[$k]=1     # llama.cpp default
  k="localhost:11434"; endpoints[$k]=1     # Ollama default
  k="localhost:8000";  endpoints[$k]=1     # vLLM default

  local pf pbase pbe h p rh zurl
  for pf in "$CONFIG_DIR"/{lms,llama,zai,remote,ollama,vllm}-*.json(N); do
    pbase="${pf:t}"
    pbe="${pbase%%-*}"
    case "$pbe" in
      lms)
        rh=$(jq -r '.remote_host // "localhost"' "$pf" 2>/dev/null || echo "localhost")
        [[ -z "$rh" || "$rh" == "null" ]] && rh="localhost"
        k="${rh}:1234"; endpoints[$k]=1
        ;;
      llama)
        rh=$(jq -r '.remote_host // "localhost"' "$pf" 2>/dev/null || echo "localhost")
        p=$(jq -r '.port // "8081"' "$pf" 2>/dev/null || echo "8081")
        [[ -z "$rh" || "$rh" == "null" ]] && rh="localhost"
        [[ -z "$p" || "$p" == "null" ]] && p="8081"
        k="${rh}:${p}"; endpoints[$k]=1
        ;;
      remote|ollama|vllm)
        h=$(jq -r '.host // "localhost"' "$pf" 2>/dev/null || echo "localhost")
        p=$(jq -r '.port // ""' "$pf" 2>/dev/null || echo "")
        [[ -z "$h" || "$h" == "null" ]] && h="localhost"
        if [[ -z "$p" || "$p" == "null" ]]; then
          case "$pbe" in
            ollama) p="11434" ;;
            vllm)   p="8000" ;;
            *)      p="1234" ;;
          esac
        fi
        k="${h}:${p}"; endpoints[$k]=1
        ;;
      zai)
        zurl=$(jq -r '.base_url // empty' "$pf" 2>/dev/null || echo "")
        if [[ -n "$zurl" && "$zurl" != "null" ]]; then
          k="$zurl"; endpoints[$k]=1
        fi
        ;;
    esac
  done

  local ep state base_url
  for ep in "${(@k)endpoints}"; do
    if [[ "$ep" =~ ^https?:// ]]; then
      base_url="$ep"
    else
      base_url="http://${ep}"
    fi
    state=$(_cclm_probe "$base_url")
    printf "  %-40s %s\n" "$ep" "$(_cclm_status_marker "$state")"
  done

  # --- Section 4: LM Studio loaded models (optional) ---
  if command -v lms >/dev/null 2>&1; then
    echo "" >&2
    echo "LM Studio loaded models:" >&2
    local lms_json lms_loaded line
    lms_json=$(lms ps --json 2>/dev/null || echo "")
    if [[ -n "$lms_json" ]]; then
      lms_loaded=$(echo "$lms_json" | jq -r '.[]? | .modelKey // .identifier // .path // empty' 2>/dev/null || echo "")
      if [[ -n "$lms_loaded" ]]; then
        while IFS= read -r line; do
          [[ -n "$line" ]] && printf "  - %s\n" "$line"
        done <<< "$lms_loaded"
      else
        echo "  (none loaded)"
      fi
    else
      echo "  (lms ps unavailable)"
    fi
  fi

  return 0
}

# Detect a top-level shortcut arg: `cclm resume` or `cclm <profile-slug>`.
# Sets _PRELOADED_PROFILE (absolute path), _PRELOADED_ACTION=open, and backend
# globals so the main dispatch routes to run_<backend> via the preload
# fast-path — no profile picker, no backend menu.
#
# Return codes:
#   0 — shortcut matched; globals set, caller should shift $1 off the arg list
#   1 — not a shortcut (flag, unknown slug, empty arg); caller falls through
#   2 — `resume` requested but no last-session state exists; caller exits 1
#
# Defined above the CCLM_LIB_ONLY guard so unit tests can call it directly.
# ----------------------------------------------------------------------------
# Profile picker helpers
# ----------------------------------------------------------------------------

# _profile_display_line <profile_path>
#   Prints the one-line summary for a saved profile to stdout, WITHOUT any
#   leading index/tab. Shared by both the numbered fallback (which prepends
#   "  NN) ") and the fzf feed (which prepends "<path>\t"). Keeping this in
#   one place guarantees the two UIs render identically — per CLAUDE.md the
#   numbered fallback must be preserved exactly, so any future formatting
#   change here affects both UIs in lockstep.
#
# Defined above the CCLM_LIB_ONLY guard so unit tests can call pick_profile
# directly (see test/test_fzf_picker.zsh).
_profile_display_line() {
  local f="$1"
  local base="${f:t}"
  local be_tag model_name host_info ctx_info
  case "$base" in
    llama-*)  be_tag="llama" ;;
    lms-*)    be_tag="lms" ;;
    zai-*)    be_tag="zai" ;;
    remote-*) be_tag="remote" ;;
    ollama-*) be_tag="ollama" ;;
    vllm-*)   be_tag="vllm" ;;
  esac
  case "$be_tag" in
    llama)
      model_name=$(jq -r --arg b "$base" '.model // $b' "$f")
      local rh=$(jq -r '.remote_host // empty' "$f")
      host_info="${rh:+remote:$rh}"
      [[ -z "$host_info" ]] && host_info="local"
      ctx_info=$(jq -r '.ctx_len // "?"' "$f")
      ;;
    lms)
      model_name=$(jq -r --arg b "$base" '.model // $b' "$f")
      local rh=$(jq -r '.remote_host // empty' "$f")
      host_info="${rh:+remote:$rh}"
      [[ -z "$host_info" ]] && host_info="local"
      ctx_info=$(jq -r '.context_length // "?"' "$f")
      ;;
    zai)
      model_name=$(jq -r '.sonnet_model // "?"' "$f")
      host_info=$(jq -r '.base_url // "z.ai"' "$f" | sed 's|https\?://||; s|/.*||')
      ctx_info=$(jq -r '.context_length // "?"' "$f")
      ;;
    remote)
      model_name=$(jq -r '.model // "?"' "$f")
      local rh_p=$(jq -r '.host // "?"' "$f")
      local rp_p=$(jq -r '.port // "1234"' "$f")
      host_info="${rh_p}:${rp_p}"
      ctx_info=$(jq -r '.context_length // "?"' "$f")
      ;;
    ollama)
      model_name=$(jq -r '.model // "?"' "$f")
      local oh_p=$(jq -r '.host // "?"' "$f")
      local op_p=$(jq -r '.port // "11434"' "$f")
      host_info="${oh_p}:${op_p}"
      ctx_info=$(jq -r '.context_length // "?"' "$f")
      ;;
    vllm)
      model_name=$(jq -r '.model // "?"' "$f")
      local vh_p=$(jq -r '.host // "?"' "$f")
      local vp_p=$(jq -r '.port // "8000"' "$f")
      host_info="${vh_p}:${vp_p}"
      ctx_info=$(jq -r '.context_length // "?"' "$f")
      ;;
  esac
  printf "[%-5s] %-28s %-21s ctx:%s" "$be_tag" \
    "${model_name:0:28}" "$host_info" "$ctx_info"
}

# pick_profile: unified picker across all saved backend profiles.
#   Returns 0 with globals (_PRELOADED_PROFILE, _PRELOADED_ACTION, backend) set,
#   or 1 to fall through to the backend-selection menu.
#
# Two UIs are supported:
#   1. fzf-powered fuzzy picker  (default when `fzf` is on PATH and stdin is a
#      TTY). Keys: Enter=open, Ctrl-E=edit, Ctrl-D=delete, Esc=quit.
#   2. Numbered fallback menu    (used when fzf is missing, CCLM_NO_FZF=1 is
#      set, or stdin is not a TTY unless CCLM_FZF_FORCE=1 is set — the latter
#      is a test-only hatch so pick_profile can be exercised via a piped stub).
#
# Defined above the CCLM_LIB_ONLY guard so unit tests can call it directly.
pick_profile() {
  local -a profiles
  profiles=( "$CONFIG_DIR"/{llama,lms,zai,remote,ollama,vllm}-*.json(N) )

  # No saved profiles — skip picker entirely
  (( ${#profiles[@]} == 0 )) && return 1

  # ---- fzf branch --------------------------------------------------------
  # Gated on: fzf installed, CCLM_NO_FZF unset, and either stdin-is-a-TTY or
  # the test-only CCLM_FZF_FORCE hatch. A stubbed `fzf` shell function beats
  # the `command -v` check (it reports the function as a builtin-like hit),
  # which is exactly how test/test_fzf_picker.zsh drives this path.
  if [[ -z "${CCLM_NO_FZF:-}" ]] \
     && command -v fzf >/dev/null 2>&1 \
     && { [[ -t 0 ]] || [[ -n "${CCLM_FZF_FORCE:-}" ]]; }; then
    while true; do
      # Build tab-delimited feed: "<path>\t<display>". fzf shows only the
      # display portion (--with-nth=2..) while the path travels through as
      # the first field for unambiguous reverse lookup — avoids index games
      # and survives duplicate model names across backends.
      local feed="" f
      for f in "${profiles[@]}"; do
        feed+="${f}"$'\t'"$(_profile_display_line "$f")"$'\n'
      done

      local fzf_out key selection picked
      fzf_out=$(printf '%s' "$feed" | fzf \
        --prompt='Profile> ' \
        --height=40% \
        --reverse \
        --header='Enter=open  Ctrl-E=edit  Ctrl-D=delete  Esc=cancel' \
        --with-nth=2.. \
        --delimiter=$'\t' \
        --expect=ctrl-e,ctrl-d)

      # Esc / no selection → quit (matches numbered menu's `q` behavior).
      [[ -z "$fzf_out" ]] && exit 0

      # fzf --expect contract: line 1 = key name (empty for Enter), line 2 =
      # the selected input line.
      key=$(printf '%s\n' "$fzf_out" | sed -n '1p')
      selection=$(printf '%s\n' "$fzf_out" | sed -n '2p')
      picked="${selection%%$'\t'*}"

      [[ -z "$picked" || ! -f "$picked" ]] && exit 0

      local picked_base="${picked:t}"
      local picked_backend="${picked_base%%-*}"

      case "$key" in
        "")
          _PRELOADED_PROFILE="$picked"
          _PRELOADED_ACTION="open"
          backend="$picked_backend"
          return 0
          ;;
        ctrl-e)
          _PRELOADED_PROFILE="$picked"
          _PRELOADED_ACTION="edit"
          backend="$picked_backend"
          return 0
          ;;
        ctrl-d)
          printf "  Delete %s? (y/N): " "$picked_base" >&2
          local del_confirm
          read -r del_confirm
          if [[ "$del_confirm" =~ ^[Yy]$ ]]; then
            rm "$picked"
            echo "  Deleted." >&2
            profiles=( "$CONFIG_DIR"/{llama,lms,zai,remote,ollama,vllm}-*.json(N) )
            (( ${#profiles[@]} == 0 )) && return 1
          fi
          continue
          ;;
        *) exit 0 ;;
      esac
    done
  fi

  # ---- numbered fallback (preserved exactly) -----------------------------
  while true; do
    echo "" >&2
    echo "Saved profiles:" >&2
    echo "" >&2

    local i=1
    for f in "${profiles[@]}"; do
      printf "  %2d) %s\n" "$i" "$(_profile_display_line "$f")" >&2
      (( i++ ))
    done

    echo "" >&2
    echo "  n) New session (full config)" >&2
    echo "  q) Quit" >&2
    echo "" >&2
    printf "Choice: " >&2
    read -r choice

    [[ "$choice" == "q" ]] && exit 0
    [[ "$choice" == "n" ]] && return 1

    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#profiles[@]} )); then
      echo "Invalid selection." >&2
      continue
    fi

    local picked="${profiles[$choice]}"
    local picked_base="${picked:t}"
    local picked_backend="${picked_base%%-*}"

    # Action sub-menu
    local display_model
    case "$picked_backend" in
      llama)  display_model=$(jq -r --arg b "$picked_base" '.model // $b' "$picked") ;;
      lms)    display_model=$(jq -r --arg b "$picked_base" '.model // $b' "$picked") ;;
      zai)    display_model=$(jq -r --arg b "$picked_base" '.sonnet_model // $b' "$picked") ;;
      remote) display_model=$(jq -r --arg b "$picked_base" '.model // $b' "$picked") ;;
      ollama) display_model=$(jq -r --arg b "$picked_base" '.model // $b' "$picked") ;;
      vllm)   display_model=$(jq -r --arg b "$picked_base" '.model // $b' "$picked") ;;
    esac

    echo "" >&2
    echo "  [$picked_backend] $display_model" >&2
    echo "    o) Open/launch" >&2
    echo "    e) Edit parameters" >&2
    echo "    d) Delete" >&2
    echo "    b) Back to list" >&2
    echo "" >&2
    printf "  Action [o]: " >&2
    read -r action
    action="${action:-o}"

    case "$action" in
      o|O)
        _PRELOADED_PROFILE="$picked"
        _PRELOADED_ACTION="open"
        backend="$picked_backend"
        return 0
        ;;
      e|E)
        _PRELOADED_PROFILE="$picked"
        _PRELOADED_ACTION="edit"
        backend="$picked_backend"
        return 0
        ;;
      d|D)
        printf "  Delete %s? (y/N): " "$picked_base" >&2
        read -r del_confirm
        if [[ "$del_confirm" =~ ^[Yy]$ ]]; then
          rm "$picked"
          echo "  Deleted." >&2
          # Refresh list
          profiles=( "$CONFIG_DIR"/{llama,lms,zai,remote,ollama,vllm}-*.json(N) )
          (( ${#profiles[@]} == 0 )) && return 1
        fi
        # Reset counter and re-display
        i=1
        continue
        ;;
      b|B) i=1; continue ;;
      *) echo "  Invalid action." >&2; continue ;;
    esac
  done
}

try_shortcut_dispatch() {
  local arg="${1:-}"

  # Empty or flag-like args are not shortcuts — let the normal parser see them.
  [[ -z "$arg" || "$arg" == -* ]] && return 1

  if [[ "$arg" == "resume" ]]; then
    load_last_session
    if [[ -z "$last_backend" || -z "$last_profile" ]]; then
      return 2
    fi
    _PRELOADED_PROFILE="$CONFIG_DIR/$last_profile"
    _PRELOADED_ACTION="open"
    backend="$last_backend"
    remote_host="${last_remote:-}"
    return 0
  fi

  # Profile-slug shortcut: arg must have a known backend prefix AND a matching
  # profile file. E.g. `cclm lms-qwen` -> $CONFIG_DIR/lms-qwen.json.
  local prefix="${arg%%-*}"
  case "$prefix" in
    lms|llama|zai|remote|ollama|vllm) ;;
    *) return 1 ;;
  esac

  local candidate="$CONFIG_DIR/${arg}.json"
  [[ -f "$candidate" ]] || return 1

  _PRELOADED_PROFILE="$candidate"
  _PRELOADED_ACTION="open"
  backend="$prefix"
  return 0
}

# ============================================================================
# Per-project .cclmrc auto-selection
# ============================================================================
# When invoked with no explicit backend flag and no matching positional slug,
# cclm walks up from $PWD looking for a .cclmrc file. Discovery stops when one
# is found, at $HOME, or at /. The file format is a line-oriented key=value
# config; supported keys: `profile=<slug>` (equivalent to `cclm <slug>`) and
# `backend=<lms|llama|zai|remote|ollama|vllm>` (equivalent to `cclm --<backend>`).
# Lines starting with `#` are comments; blank lines are ignored. Malformed files
# print a warning and fall through to the interactive picker.
#
# Symlinked cwd: uses logical $PWD (the user's mental cd path), not `pwd -P`,
# matching how tools like git resolve the working directory.
# Defined above the CCLM_LIB_ONLY guard so tests can drive these directly.

# Walk up from $1 (absolute start dir), looking for .cclmrc. Stop at $HOME or /.
# Echoes the discovered path on stdout (rc=0) or nothing (rc=1).
find_cclmrc() {
  local rcdir="${1:-$PWD}"
  # Normalize: if not absolute, prefix with PWD. We intentionally do NOT call
  # `realpath`/`pwd -P` here — users `cd` through symlinks and expect the
  # logical path to be honored (e.g. git's rev-parse behavior).
  [[ "$rcdir" == /* ]] || rcdir="$PWD/$rcdir"

  local home="${HOME:-}"
  while [[ -n "$rcdir" ]]; do
    if [[ -f "$rcdir/.cclmrc" ]]; then
      echo "$rcdir/.cclmrc"
      return 0
    fi
    # Stop boundaries: we check $HOME itself (above), then break. Similarly
    # we stop at root once we've checked it.
    [[ "$rcdir" == "$home" ]] && return 1
    [[ "$rcdir" == "/" ]] && return 1
    # Trim the last path segment; `${rcdir:h}` yields "/" when rcdir is "/foo".
    local parent="${rcdir:h}"
    # Guard against stuck loops (shouldn't happen, but cheap insurance).
    [[ "$parent" == "$rcdir" ]] && return 1
    rcdir="$parent"
  done
  return 1
}

# Parse a .cclmrc file at $1 and, on success, set the preload globals that the
# dispatch path already uses (backend, _PRELOADED_PROFILE, _PRELOADED_ACTION).
# Returns 0 on successful resolution, 1 on any malformed/invalid content (with
# a stderr warning so the user knows why the picker showed up anyway).
#
# Precedence when both keys are present: `profile=` wins over `backend=` —
# profile is strictly more specific (carries the backend prefix + the slug).
apply_cclmrc() {
  local rcpath="$1"
  [[ -f "$rcpath" ]] || { echo "cclm: .cclmrc not found: $rcpath" >&2; return 1; }

  local rcprofile="" rcbackend=""
  local lineno=0 line key rcvalue
  while IFS= read -r line || [[ -n "$line" ]]; do
    lineno=$((lineno + 1))
    # Strip leading/trailing whitespace. We avoid extended_glob quantifiers
    # (not enabled globally) and just loop off one char at a time — rc files
    # are tiny, this is a non-hotpath.
    while [[ "$line" == [[:space:]]* ]]; do line="${line#?}"; done
    while [[ "$line" == *[[:space:]] ]]; do line="${line%?}"; done
    [[ -z "$line" || "$line" == \#* ]] && continue
    # Must contain `=`, with a key matching [a-z_][a-z_0-9]* before it. We
    # avoid zsh's extended_glob `#` operator (not enabled globally in this
    # script) and do the split-then-validate dance instead.
    if [[ "$line" != *=* ]]; then
      echo "cclm: warning: $rcpath:$lineno malformed line: $line" >&2
      return 1
    fi
    key="${line%%=*}"
    rcvalue="${line#*=}"
    if [[ -z "$key" || "$key" == [^a-z_]* || "$key" == *[^a-z_0-9]* ]]; then
      echo "cclm: warning: $rcpath:$lineno malformed key: $key" >&2
      return 1
    fi
    case "$key" in
      profile) rcprofile="$rcvalue" ;;
      backend) rcbackend="$rcvalue" ;;
      *)
        # Unknown keys are a warning, not an error (forward compat).
        echo "cclm: warning: $rcpath:$lineno unknown key: $key" >&2
        ;;
    esac
  done < "$rcpath"

  # `profile=` takes precedence — reuse try_shortcut_dispatch's validation so
  # we enforce the known-prefix rule and the file-exists check in one place.
  if [[ -n "$rcprofile" ]]; then
    local prefix="${rcprofile%%-*}"
    case "$prefix" in
      lms|llama|zai|remote|ollama|vllm) ;;
      *)
        echo "cclm: warning: $rcpath: profile '$rcprofile' lacks a known backend prefix" >&2
        return 1
        ;;
    esac
    local candidate="$CONFIG_DIR/${rcprofile}.json"
    if [[ ! -f "$candidate" ]]; then
      echo "cclm: warning: $rcpath: profile '$rcprofile' not found at $candidate" >&2
      return 1
    fi
    _PRELOADED_PROFILE="$candidate"
    _PRELOADED_ACTION="open"
    backend="$prefix"
    return 0
  fi

  if [[ -n "$rcbackend" ]]; then
    case "$rcbackend" in
      lms|llama|zai|remote|ollama|vllm) backend="$rcbackend"; return 0 ;;
      *)
        echo "cclm: warning: $rcpath: unknown backend '$rcbackend'" >&2
        return 1
        ;;
    esac
  fi

  # File was well-formed but specified nothing actionable.
  echo "cclm: warning: $rcpath: no profile= or backend= directive" >&2
  return 1
}

# ============================================================================
# `cclm edit` subcommand
# ============================================================================
# Targeted profile-field editor — avoids re-running the full backend flow just
# to change one value.
#
#   cclm edit <slug>              interactive: numbered list, pick a field, prompt for value
#   cclm edit <slug> <field>      direct: match by exact jq-key, else case-insensitive
#                                 substring on key+label; ambiguous/missing -> exit 1
#
# Schema is the single source of truth for editable fields. Fields present in
# the JSON but absent from the backend's PROFILE_SCHEMA are ignored. JSON type
# is preserved across edits: numeric existing values stay numeric if the new
# input parses as a number; string/null fields round-trip as strings.
# Defined above the CCLM_LIB_ONLY guard so unit tests can call it directly.

# Extract the jq key (e.g. "ctx_len") from a schema filter like ".ctx_len" or
# `.slot_save_path // ""`. Returns the bare key with no leading dot, no
# surrounding whitespace, no `// default` suffix.
_cclm_schema_key() {
  local f="$1"
  # Drop anything from the first " //" onward.
  f="${f%% //*}"
  # Trim whitespace.
  f="${f## }"; f="${f%% }"
  # Strip leading dot.
  f="${f#.}"
  echo "$f"
}

# Merge a single key/value into a JSON profile file, preserving the existing
# value's type where possible. Writes to a tmp file and atomically mvs.
_cclm_profile_merge() {
  local profile="$1" key="$2" new_val="$3"
  local existing_type tmp
  existing_type=$(jq -r --arg k "$key" '.[$k] | type' "$profile" 2>/dev/null || echo "null")
  tmp=$(mktemp) || { echo "could not create tmp file" >&2; return 1; }

  # Choose --arg (string) vs --argjson (typed). Preserve number/bool types
  # when the new input is compatible; empty input against a currently-null
  # field round-trips to null.
  if [[ "$existing_type" == "number" && "$new_val" =~ ^-?[0-9]+(\.[0-9]+)?$ ]]; then
    jq --arg k "$key" --argjson v "$new_val" '.[$k] = $v' "$profile" > "$tmp"
  elif [[ "$existing_type" == "boolean" && ( "$new_val" == "true" || "$new_val" == "false" ) ]]; then
    jq --arg k "$key" --argjson v "$new_val" '.[$k] = $v' "$profile" > "$tmp"
  elif [[ "$existing_type" == "null" && -z "$new_val" ]]; then
    jq --arg k "$key" '.[$k] = null' "$profile" > "$tmp"
  else
    jq --arg k "$key" --arg v "$new_val" '.[$k] = $v' "$profile" > "$tmp"
  fi

  if [[ ! -s "$tmp" ]]; then
    rm -f "$tmp"
    echo "jq failed to merge $key" >&2
    return 1
  fi
  mv "$tmp" "$profile"
}

cmd_edit() {
  local slug="${1:-}" field_arg="${2:-}"

  if [[ -z "$slug" ]]; then
    cat >&2 <<'EOF'
Usage: cclm edit <slug> [field]

Edit a single field of a saved profile without re-running the full flow.
  cclm edit lms-qwen3                   # pick a field from the list
  cclm edit llama-qwen3 ctx_len         # edit one field by jq-key
  cclm edit remote-anthropic host       # substring/label match also works
EOF
    return 2
  fi

  # Check backend prefix BEFORE file existence — a typo like `bogus-foo`
  # reports the specific "unknown backend prefix" instead of a generic
  # "not found".
  local prefix="${slug%%-*}"
  local schema_var
  case "$prefix" in
    lms)    schema_var="LMS_PROFILE_SCHEMA" ;;
    llama)  schema_var="LLAMA_PROFILE_SCHEMA_WITH_PATH" ;;
    zai)    schema_var="ZAI_PROFILE_SCHEMA" ;;
    remote) schema_var="REMOTE_PROFILE_SCHEMA" ;;
    ollama) schema_var="OLLAMA_PROFILE_SCHEMA" ;;
    vllm)   schema_var="VLLM_PROFILE_SCHEMA" ;;
    *)
      echo "cclm edit: unknown backend prefix '$prefix' (expected lms/llama/zai/remote/ollama/vllm)" >&2
      return 1
      ;;
  esac

  local profile="$CONFIG_DIR/${slug}.json"
  if [[ ! -f "$profile" ]]; then
    echo "cclm edit: profile not found: $profile" >&2
    return 1
  fi

  # Indirect array expansion — same pattern as test/verify_golden.zsh.
  local -a schema
  schema=( "${(@P)schema_var}" )

  # Parse schema into parallel arrays: labels, keys, filters.
  local -a labels keys filters
  local spec lbl flt grp k
  for spec in "${schema[@]}"; do
    IFS='|' read -r lbl flt grp <<< "$spec"
    k=$(_cclm_schema_key "$flt")
    labels+=("$lbl")
    keys+=("$k")
    filters+=("$flt")
  done

  # --- Resolve target field ------------------------------------------------
  local idx=-1 i
  if [[ -n "$field_arg" ]]; then
    # 1. Exact jq-key match wins (keys are unique by construction).
    for (( i=1; i<=${#keys[@]}; i++ )); do
      if [[ "${keys[$i]}" == "$field_arg" ]]; then
        idx=$i
        break
      fi
    done

    # 2. Fall back to case-insensitive substring match on key OR label.
    if (( idx < 0 )); then
      local -a matches
      local needle="${field_arg:l}" hay_key hay_lbl
      for (( i=1; i<=${#keys[@]}; i++ )); do
        hay_key="${keys[$i]:l}"
        hay_lbl="${labels[$i]:l}"
        if [[ "$hay_key" == *"$needle"* || "$hay_lbl" == *"$needle"* ]]; then
          matches+=("$i")
        fi
      done
      if (( ${#matches[@]} == 0 )); then
        echo "cclm edit: no field matches '$field_arg' in $prefix schema" >&2
        echo "  Available fields:" >&2
        for (( i=1; i<=${#keys[@]}; i++ )); do
          printf "    %s (%s)\n" "${keys[$i]}" "${labels[$i]}" >&2
        done
        return 1
      elif (( ${#matches[@]} > 1 )); then
        echo "cclm edit: '$field_arg' is ambiguous — matches:" >&2
        local m
        for m in "${matches[@]}"; do
          printf "    %s (%s)\n" "${keys[$m]}" "${labels[$m]}" >&2
        done
        return 1
      fi
      idx=${matches[1]}
    fi
  else
    # Interactive selection.
    echo "Profile: $profile" >&2
    echo "Editable fields:" >&2
    local cur
    for (( i=1; i<=${#keys[@]}; i++ )); do
      cur=$(jq -r "${filters[$i]}" "$profile" 2>/dev/null)
      [[ -z "$cur" || "$cur" == "null" ]] && cur="-"
      printf "  %2d) %-22s %s\n" "$i" "${labels[$i]}" "$cur" >&2
    done
    echo "" >&2
    printf "Field # to edit (q to quit): " >&2
    local choice
    read -r choice
    [[ "$choice" == "q" || -z "$choice" ]] && return 0
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#keys[@]} )); then
      echo "cclm edit: invalid selection" >&2
      return 1
    fi
    idx=$choice
  fi

  local target_key="${keys[$idx]}"
  local target_lbl="${labels[$idx]}"
  local target_flt="${filters[$idx]}"
  local current
  current=$(jq -r "$target_flt" "$profile" 2>/dev/null)
  [[ "$current" == "null" ]] && current=""

  local new_val
  new_val=$(ask "$target_lbl" "$current")

  if ! _cclm_profile_merge "$profile" "$target_key" "$new_val"; then
    return 1
  fi
  echo "Updated $target_key in $(basename "$profile")." >&2
  return 0
}

# ============================================================================
# `cclm bench` subcommand
# ============================================================================
# Benchmark OpenAI-compatible backends by POSTing a short prompt to
# /v1/chat/completions and measuring wallclock + token counts.
#
#   cclm bench                               — bench every saved profile (except zai)
#   cclm bench --profiles lms-foo,llama-bar  — bench specific profiles (comma-sep)
#   cclm bench --iterations 3                — repeat N times, show individual rows + mean
#   cclm bench --prompt-file PATH            — use a custom prompt file (<=~50 tokens)
#   cclm bench --dry-run                     — print curl commands, don't run them
#
# Output: markdown-style table to stdout. Progress/warnings go to stderr so the
# table is clean under `cclm bench | tee bench.md`.
#
# zai-*.json profiles are skipped: Z.ai speaks the Anthropic-native messages
# protocol (/v1/messages), not OpenAI /v1/chat/completions, and wiring up the
# different request/response shape is out of scope for this first pass.
#
# Auth: no Authorization header is sent by default. Local backends (lms / llama
# / ollama / vllm) accept unauthenticated requests on localhost; for remote
# profiles that need a key, set CCLM_BENCH_API_KEY in the environment and it
# will be sent as `Authorization: Bearer <key>`.
#
# Wallclock: zmodload zsh/datetime gives us $EPOCHREALTIME (float seconds,
# cross-platform, no subprocess — `date +%s.%N` is GNU-only and `date +%s` has
# 1s granularity, both useless for fast backends).
# Defined above the CCLM_LIB_ONLY guard so unit tests can call it directly.

# Resolve a saved profile JSON path into (base_url, model_id) suitable for
# POSTing to /v1/chat/completions. Prints `base_url|model_id|display_label` to
# stdout; returns 1 if the profile is unsupported (zai) or malformed.
# `display_label` is the profile slug (no prefix) used for table rows.
_cclm_bench_resolve() {
  # NOTE: zsh ties lowercase `path` to the `PATH` array — `local path=...`
  # would blow away PATH inside the function and hide jq/curl. Use `pfile`.
  local pfile="$1"
  local base="${pfile:t}"           # basename
  base="${base%.json}"
  local prefix="${base%%-*}"        # lms / llama / zai / ...
  # display label is the full slug (e.g. "lms-qwen3"); keeps rows unambiguous
  # when two backends have the same short name.
  local slug="$base"

  local host port model url
  case "$prefix" in
    zai)
      echo "[bench] skipping $base — Z.ai speaks Anthropic-native protocol" >&2
      return 1
      ;;
    lms)
      host=$(jq -r '.remote_host // "localhost"' "$pfile")
      [[ -z "$host" || "$host" == "null" ]] && host="localhost"
      port="1234"
      model=$(jq -r '.model // ""' "$pfile")
      ;;
    llama)
      host=$(jq -r '.remote_host // "localhost"' "$pfile")
      [[ -z "$host" || "$host" == "null" ]] && host="localhost"
      port=$(jq -r '.port // "8081"' "$pfile")
      # llama profiles store the full .gguf path; llama-server accepts any
      # identifier in the request body, so the basename (no extension) is a
      # reasonable display-and-payload choice.
      model=$(jq -r '.model_path // ""' "$pfile")
      model="${model:t}"
      model="${model%.gguf}"
      ;;
    remote|ollama|vllm)
      host=$(jq -r '.host // ""' "$pfile")
      port=$(jq -r --arg p "$prefix" '.port // (if $p == "ollama" then "11434" elif $p == "vllm" then "8000" else "1234" end)' "$pfile")
      model=$(jq -r '.model // ""' "$pfile")
      ;;
    *)
      echo "[bench] skipping $base — unknown backend prefix" >&2
      return 1
      ;;
  esac

  if [[ -z "$host" || -z "$model" ]]; then
    echo "[bench] skipping $base — missing host or model" >&2
    return 1
  fi
  url="http://${host}:${port}"
  printf '%s|%s|%s\n' "$url" "$model" "$slug"
  return 0
}

# Run one /v1/chat/completions POST. Returns 0 and prints
# "<wallclock>|<prompt_tok>|<completion_tok>|<tok_per_s>" on stdout. On
# failure, returns non-zero and prints a short reason on stderr.
_cclm_bench_one_iter() {
  local base_url="$1" model="$2" prompt="$3"

  local payload
  payload=$(jq -n \
    --arg m "$model" \
    --arg p "$prompt" \
    '{model: $m, messages: [{role: "user", content: $p}], max_tokens: 200, stream: false}')

  # Optional bearer auth (remote backends may require it).
  local -a auth_args=()
  if [[ -n "${CCLM_BENCH_API_KEY:-}" ]]; then
    auth_args=(-H "Authorization: Bearer ${CCLM_BENCH_API_KEY}")
  fi

  local t0 t1 elapsed
  t0="$EPOCHREALTIME"
  local resp rc=0
  # curl failure must not trip `set -e` — we want to report it, not die.
  resp=$(curl -sS --max-time 120 \
    -H "Content-Type: application/json" \
    "${auth_args[@]}" \
    -d "$payload" \
    "${base_url}/v1/chat/completions" 2>/dev/null) || rc=$?
  t1="$EPOCHREALTIME"

  if (( rc != 0 )) || [[ -z "$resp" ]]; then
    echo "[bench] curl failed against ${base_url} (rc=${rc})" >&2
    return 1
  fi

  # jq under `set -o pipefail`: if the body isn't JSON, the whole thing should
  # fail gracefully. We parse fields individually and default to "" so a
  # partial response surfaces as an obvious bad row rather than crashing.
  local pt ct
  pt=$(echo "$resp" | jq -r '.usage.prompt_tokens // empty' 2>/dev/null)
  ct=$(echo "$resp" | jq -r '.usage.completion_tokens // empty' 2>/dev/null)
  if [[ -z "$pt" || -z "$ct" ]]; then
    echo "[bench] malformed response from ${base_url} (no usage fields)" >&2
    return 1
  fi

  # LC_ALL=C forces awk to use '.' as decimal separator regardless of locale —
  # users with comma-decimal locales (de_DE.UTF-8 etc.) would otherwise get
  # "0,210" which breaks downstream markdown parsing.
  elapsed=$(LC_ALL=C awk -v a="$t1" -v b="$t0" 'BEGIN{printf "%.3f", a - b}')
  local tps
  tps=$(LC_ALL=C awk -v c="$ct" -v e="$elapsed" 'BEGIN{ if (e+0 <= 0) printf "inf"; else printf "%.2f", c / e }')
  printf '%s|%s|%s|%s\n' "$elapsed" "$pt" "$ct" "$tps"
  return 0
}

cmd_bench() {
  # --- arg parse ---
  local prompt_file="" iterations=1 profiles_spec=""
  local dry_run=false
  while (( $# )); do
    case "$1" in
      --prompt-file)
        [[ $# -ge 2 ]] || { echo "--prompt-file requires an argument" >&2; return 2; }
        prompt_file="$2"; shift ;;
      --prompt-file=*) prompt_file="${1#--prompt-file=}" ;;
      --profiles)
        [[ $# -ge 2 ]] || { echo "--profiles requires an argument" >&2; return 2; }
        profiles_spec="$2"; shift ;;
      --profiles=*) profiles_spec="${1#--profiles=}" ;;
      --iterations)
        [[ $# -ge 2 ]] || { echo "--iterations requires an argument" >&2; return 2; }
        iterations="$2"; shift ;;
      --iterations=*) iterations="${1#--iterations=}" ;;
      --dry-run) dry_run=true ;;
      -h|--help)
        cat >&2 <<'EOF'
Usage: cclm bench [--prompt-file FILE] [--profiles <slugs>] [--iterations N] [--dry-run]

Benchmark OpenAI-compatible backends by POSTing a short prompt to
/v1/chat/completions and measuring wallclock and tokens/sec.

Options:
  --prompt-file FILE      Prompt text file (default: short embedded haiku prompt)
  --profiles <slugs>      Comma-separated list of profile slugs (default: all saved, except zai)
  --iterations N          Repeat N times per profile, print individual rows + mean (default: 1)
  --dry-run               Print the curl commands that would run and exit

Env:
  CCLM_BENCH_API_KEY      Optional bearer token sent as Authorization header.

Z.ai profiles (zai-*.json) are skipped — Anthropic-native protocol is out of
scope for this first pass.
EOF
        return 0 ;;
      *) echo "Unknown option: $1" >&2; return 2 ;;
    esac
    shift
  done

  if ! [[ "$iterations" =~ ^[1-9][0-9]*$ ]]; then
    echo "--iterations must be a positive integer" >&2
    return 2
  fi

  # --- resolve prompt ---
  local prompt
  if [[ -n "$prompt_file" ]]; then
    if [[ ! -f "$prompt_file" ]]; then
      echo "cclm bench: prompt file not found: $prompt_file" >&2
      return 1
    fi
    prompt=$(<"$prompt_file")
  else
    prompt="Write a haiku about idempotent installers."
  fi

  # --- resolve profile list ---
  local -a profile_paths
  local _slug _path
  if [[ -n "$profiles_spec" ]]; then
    for _slug in ${(s:,:)profiles_spec}; do
      [[ -z "$_slug" ]] && continue
      _path="$CONFIG_DIR/${_slug}.json"
      if [[ ! -f "$_path" ]]; then
        echo "[bench] warning: profile not found: $_path" >&2
        continue
      fi
      profile_paths+=("$_path")
    done
  else
    # Include zai-*.json in the default sweep so the user sees an explicit
    # skip message (instead of silently missing profiles). Resolver filters them.
    profile_paths=( "$CONFIG_DIR"/{lms,llama,zai,remote,ollama,vllm}-*.json(N) )
  fi

  if (( ${#profile_paths[@]} == 0 )); then
    echo "cclm bench: no benchable profiles found." >&2
    return 1
  fi

  # --- zsh datetime for sub-second wallclock ---
  zmodload zsh/datetime 2>/dev/null || {
    echo "cclm bench: zsh/datetime module unavailable" >&2
    return 1
  }

  # Declare loop-local scratch vars once for the whole function body. Re-
  # declaring `local p` / `local slug` later (e.g. in the live loop) would
  # trigger zsh's typeset-echoing-its-value-to-stdout behavior when the name
  # already exists in the same scope. One declaration, reused in both blocks.
  local p_iter resolved base_url model slug_out i

  # --- dry-run: print curl commands, exit 0 ---
  if $dry_run; then
    for p_iter in "${profile_paths[@]}"; do
      resolved=$(_cclm_bench_resolve "$p_iter") || continue
      IFS='|' read -r base_url model slug_out <<< "$resolved"
      for (( i=1; i<=iterations; i++ )); do
        printf 'curl -sS -H "Content-Type: application/json" -d %q %s/v1/chat/completions  # [%s iter %d]\n' \
          "$(jq -n --arg m "$model" --arg pr "$prompt" '{model:$m, messages:[{role:"user",content:$pr}], max_tokens:200, stream:false}')" \
          "$base_url" "$slug_out" "$i"
      done
    done
    return 0
  fi

  # --- header ---
  local header_iter=""
  (( iterations > 1 )) && header_iter="| iter "
  printf '| profile                              %s| wallclock (s) | prompt_tok | completion_tok | tok/s |\n' "$header_iter"
  printf '|--------------------------------------'
  (( iterations > 1 )) && printf -- '|------'
  printf '|---------------|------------|----------------|-------|\n'

  local success_count=0 fail_count=0
  local -a wall_times completion_tokens_arr
  local one rc wall pt ct tps mean_wall mean_tps total_ct ct_i iter_fail
  for p_iter in "${profile_paths[@]}"; do
    resolved=$(_cclm_bench_resolve "$p_iter") || { fail_count=$((fail_count + 1)); continue; }
    IFS='|' read -r base_url model slug_out <<< "$resolved"
    echo "[bench] ${slug_out} -> ${base_url} (${model})" >&2

    wall_times=()
    completion_tokens_arr=()
    iter_fail=false

    for (( i=1; i<=iterations; i++ )); do
      rc=0
      one=$(_cclm_bench_one_iter "$base_url" "$model" "$prompt") || rc=$?
      if (( rc != 0 )); then
        iter_fail=true
        if (( iterations > 1 )); then
          printf '| %-36s | %-4d | %13s | %10s | %14s | %5s |\n' "$slug_out" "$i" "ERR" "-" "-" "-"
        else
          printf '| %-36s | %13s | %10s | %14s | %5s |\n' "$slug_out" "ERR" "-" "-" "-"
        fi
        continue
      fi
      IFS='|' read -r wall pt ct tps <<< "$one"
      wall_times+=("$wall")
      completion_tokens_arr+=("$ct")
      if (( iterations > 1 )); then
        printf '| %-36s | %-4d | %13s | %10s | %14s | %5s |\n' "$slug_out" "$i" "$wall" "$pt" "$ct" "$tps"
      else
        printf '| %-36s | %13s | %10s | %14s | %5s |\n' "$slug_out" "$wall" "$pt" "$ct" "$tps"
      fi
    done

    if (( ${#wall_times[@]} > 0 )); then
      success_count=$((success_count + 1))
      if (( iterations > 1 )); then
        # mean row
        mean_wall=$(printf '%s\n' "${wall_times[@]}" | LC_ALL=C awk '{s+=$1; n++} END{if(n>0) printf "%.3f", s/n}')
        total_ct=0
        for ct_i in "${completion_tokens_arr[@]}"; do total_ct=$((total_ct + ct_i)); done
        mean_tps=$(LC_ALL=C awk -v c="$total_ct" -v w="$mean_wall" -v n="${#wall_times[@]}" \
          'BEGIN{ if (w+0 <= 0) printf "inf"; else printf "%.2f", (c/n) / w }')
        printf '| %-36s | %-4s | %13s | %10s | %14s | %5s |\n' "$slug_out" "mean" "$mean_wall" "-" "-" "$mean_tps"
      fi
    else
      fail_count=$((fail_count + 1))
    fi
  done

  echo "[bench] ${success_count} succeeded, ${fail_count} failed" >&2
  (( success_count > 0 )) || return 1
  return 0
}

# ----------------------------------------------------------------------------
# Profile management (`cclm profile <subcmd>`)
#
# Subcommands: list | clone <src> <dst> | rename <old> <new> | delete <slug>
#
# Slug validation: a slug must start with a valid backend prefix
# (lms-/llama-/zai-/remote-/ollama-/vllm-) followed by a non-empty name. Clone
# and rename additionally require src and dst to share the same backend prefix
# — moving a profile across backends would create a file whose JSON schema
# mismatches its filename, i.e. an unusable profile.
#
# Atomicity:
#   clone  — cp src tmp (same dir) && mv tmp dst (rename, atomic on same FS)
#   rename — mv src dst (atomic on same FS)
#   delete — rm (atomic)
# Refuse-on-overwrite: clone/rename exit 1 if dst already exists.
#
# Defined above the CCLM_LIB_ONLY guard so unit tests can call it directly.
# ----------------------------------------------------------------------------

_cclm_valid_prefix() {
  local prefix="$1"
  case "$prefix" in
    lms|llama|zai|remote|ollama|vllm) return 0 ;;
    *) return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Profile inheritance (optional `extends` field)
#
# A profile JSON may set `"extends": "<base-slug>"`. _cclm_profile_resolve
# reads the profile, recursively resolves the parent (same backend prefix
# required), and deep-merges with `jq -s '.[0] * .[1]'` so child keys win.
# The merged output is emitted to stdout (the `extends` field is stripped).
#
# Cycle detection uses a comma-separated seen-set threaded through recursion.
# A hard depth ceiling of 10 guards against runaway chains (distinct from a
# cycle: you get a different error message).
#
# Backends opt in via `_cclm_read_profile` which accepts either an absolute
# path or a slug and emits resolved JSON. Callers who only deal with flat
# JSON can keep cat-ing files directly — extends is fully optional.
# ---------------------------------------------------------------------------

# _cclm_profile_resolve <slug>
# Emits resolved JSON on stdout. Errors go to stderr; exit 1 on any failure
# (missing file, cross-prefix extends, cycle, depth > 10).
_cclm_profile_resolve() {
  local slug="$1"
  _cclm_profile_resolve_impl "$slug" 0 ""
}

# Internal: <slug> <depth> <seen_csv>
_cclm_profile_resolve_impl() {
  local slug="$1" depth="$2" seen="$3"

  if (( depth > 10 )); then
    echo "cclm: profile extends depth limit (10) exceeded at '$slug'" >&2
    return 1
  fi

  if [[ -z "$slug" ]]; then
    echo "cclm: profile resolve: empty slug" >&2
    return 1
  fi

  # Cycle check: slug already in seen set?
  case ",${seen}," in
    *",${slug},"*)
      echo "cclm: profile extends cycle detected involving '$slug' (chain: ${seen})" >&2
      return 1
      ;;
  esac

  local prefix="${slug%%-*}"
  if ! _cclm_valid_prefix "$prefix"; then
    echo "cclm: profile resolve: unknown backend prefix '$prefix' in '$slug'" >&2
    return 1
  fi

  local pfile="$CONFIG_DIR/${slug}.json"
  if [[ ! -f "$pfile" ]]; then
    echo "cclm: profile resolve: profile not found: $pfile" >&2
    return 1
  fi

  local parent
  parent=$(jq -r '.extends // empty' "$pfile" 2>/dev/null || true)

  if [[ -z "$parent" ]]; then
    # Base case: no extends. Emit the JSON (strip any stray extends just in case).
    jq 'del(.extends)' "$pfile"
    return $?
  fi

  # Same-prefix guard: the parent slug must belong to the same backend.
  local parent_prefix="${parent%%-*}"
  if [[ "$parent_prefix" != "$prefix" ]]; then
    echo "cclm: profile resolve: cross-backend extends not allowed ('$slug' [$prefix] extends '$parent' [$parent_prefix])" >&2
    return 1
  fi

  # Resolve parent first (DFS), then deep-merge child on top.
  local next_seen
  if [[ -z "$seen" ]]; then
    next_seen="$slug"
  else
    next_seen="${seen},${slug}"
  fi

  local parent_json
  parent_json=$(_cclm_profile_resolve_impl "$parent" $((depth + 1)) "$next_seen") || return 1

  # jq -s slurps both inputs as an array; `.[0] * .[1]` deep-merges with the
  # second input (child) overriding the first (parent). Then strip `extends`.
  jq -s '.[0] * .[1] | del(.extends)' \
    <(printf '%s' "$parent_json") \
    "$pfile"
}

# _cclm_read_profile <slug_or_path>
# Thin wrapper backends can use instead of cat-ing a profile file directly.
# Resolves `extends` transparently. Accepts either an absolute path (e.g.
# from the profile picker's _PRELOADED_PROFILE) or a bare slug.
_cclm_read_profile() {
  local input="$1"
  local slug
  if [[ "$input" == /* || "$input" == */* ]]; then
    # Path form: derive slug from basename, stripping .json.
    slug="${input:t}"
    slug="${slug%.json}"
  else
    slug="$input"
  fi
  _cclm_profile_resolve "$slug"
}

cmd_profile() {
  local sub="${1:-}"
  if [[ -z "$sub" ]]; then
    cat >&2 <<'EOF'
Usage: cclm profile <subcommand> [args...]

Subcommands:
  list                        List saved profiles grouped by backend.
  clone <src> <dst>           Copy profile <src> to <dst> (same backend prefix).
  rename <old> <new>          Rename profile <old> to <new> (same backend prefix).
  delete <slug>               Delete profile <slug> (prompts unless FORCE=1).
  resolve <slug>              Print profile JSON with `extends` applied.
EOF
    return 2
  fi
  shift

  case "$sub" in
    list)   _cclm_profile_list "$@" ;;
    clone)  _cclm_profile_clone "$@" ;;
    rename) _cclm_profile_rename "$@" ;;
    delete|rm) _cclm_profile_delete "$@" ;;
    resolve|show) _cclm_profile_resolve_cmd "$@" ;;
    *)
      echo "cclm profile: unknown subcommand '$sub' (expected list/clone/rename/delete/resolve)" >&2
      return 2
      ;;
  esac
}

# `cclm profile resolve <slug>` — print resolved JSON (with extends applied)
# to stdout. Validates prefix up front so typos get a clean error.
_cclm_profile_resolve_cmd() {
  local slug="${1:-}"
  if [[ -z "$slug" ]]; then
    echo "Usage: cclm profile resolve <slug>" >&2
    return 2
  fi
  # Prefix validation (gives a clearer error than _cclm_profile_resolve's
  # internal message if someone mistypes the backend tag).
  _cclm_profile_prefix_of "$slug" "resolve" >/dev/null || return 1
  _cclm_profile_resolve "$slug"
}

# List saved profiles grouped by backend. Mirrors the cmd_status section but
# as a standalone command without last-session/reachability noise.
_cclm_profile_list() {
  local -a all_profiles
  all_profiles=( "$CONFIG_DIR"/{lms,llama,zai,remote,ollama,vllm}-*.json(N) )
  if (( ${#all_profiles[@]} == 0 )); then
    echo "No profiles saved in $CONFIG_DIR." >&2
    return 0
  fi
  local be f base slug count
  local -a group
  for be in lms llama zai remote ollama vllm; do
    group=( "$CONFIG_DIR"/${be}-*.json(N) )
    count=${#group[@]}
    (( count == 0 )) && continue
    printf "  [%s] (%d)\n" "$be" "$count"
    for f in "${group[@]}"; do
      base="${f:t}"
      slug="${base%.json}"
      printf "    - %s\n" "$slug"
    done
  done
  return 0
}

# Validate a slug's backend prefix. Writes the prefix to stdout on success.
# On failure writes an error to stderr and returns 1.
_cclm_profile_prefix_of() {
  local slug="$1" label="$2"
  if [[ -z "$slug" ]]; then
    echo "cclm profile $label: slug required" >&2
    return 1
  fi
  # Reject bare slugs with no prefix separator or an empty tail.
  if [[ "$slug" != *-* || "${slug#*-}" == "" ]]; then
    echo "cclm profile $label: '$slug' missing backend prefix (expected lms-/llama-/zai-/remote-/ollama-/vllm-)" >&2
    return 1
  fi
  local prefix="${slug%%-*}"
  if ! _cclm_valid_prefix "$prefix"; then
    echo "cclm profile $label: unknown backend prefix '$prefix' (expected lms/llama/zai/remote/ollama/vllm)" >&2
    return 1
  fi
  echo "$prefix"
  return 0
}

_cclm_profile_clone() {
  local src="${1:-}" dst="${2:-}"
  if [[ -z "$src" || -z "$dst" ]]; then
    echo "Usage: cclm profile clone <src-slug> <dst-slug>" >&2
    return 2
  fi

  local src_prefix dst_prefix
  src_prefix=$(_cclm_profile_prefix_of "$src" "clone") || return 1
  dst_prefix=$(_cclm_profile_prefix_of "$dst" "clone") || return 1

  if [[ "$src_prefix" != "$dst_prefix" ]]; then
    echo "cclm profile clone: src/dst prefix mismatch ('$src_prefix' vs '$dst_prefix') — cross-backend clone is not allowed" >&2
    return 1
  fi

  local src_path="$CONFIG_DIR/${src}.json"
  local dst_path="$CONFIG_DIR/${dst}.json"

  if [[ ! -f "$src_path" ]]; then
    echo "cclm profile clone: source profile not found: $src_path" >&2
    return 1
  fi
  if [[ -e "$dst_path" ]]; then
    echo "cclm profile clone: destination already exists: $dst_path (refusing to overwrite)" >&2
    return 1
  fi

  # Atomic copy: write to a tmp file in the same dir, then rename into place.
  local tmp
  tmp=$(mktemp "$CONFIG_DIR/.clone.XXXXXX") || {
    echo "cclm profile clone: could not create tmp file in $CONFIG_DIR" >&2
    return 1
  }
  if ! cp "$src_path" "$tmp"; then
    rm -f "$tmp"
    echo "cclm profile clone: failed to copy $src_path" >&2
    return 1
  fi
  if ! mv "$tmp" "$dst_path"; then
    rm -f "$tmp"
    echo "cclm profile clone: failed to finalize $dst_path" >&2
    return 1
  fi
  echo "Cloned ${src}.json -> ${dst}.json" >&2
  return 0
}

_cclm_profile_rename() {
  local old="${1:-}" new="${2:-}"
  if [[ -z "$old" || -z "$new" ]]; then
    echo "Usage: cclm profile rename <old-slug> <new-slug>" >&2
    return 2
  fi

  local old_prefix new_prefix
  old_prefix=$(_cclm_profile_prefix_of "$old" "rename") || return 1
  new_prefix=$(_cclm_profile_prefix_of "$new" "rename") || return 1

  if [[ "$old_prefix" != "$new_prefix" ]]; then
    echo "cclm profile rename: old/new prefix mismatch ('$old_prefix' vs '$new_prefix') — cross-backend rename is not allowed" >&2
    return 1
  fi

  local old_path="$CONFIG_DIR/${old}.json"
  local new_path="$CONFIG_DIR/${new}.json"

  if [[ ! -f "$old_path" ]]; then
    echo "cclm profile rename: source profile not found: $old_path" >&2
    return 1
  fi
  if [[ -e "$new_path" ]]; then
    echo "cclm profile rename: destination already exists: $new_path (refusing to overwrite)" >&2
    return 1
  fi

  if ! mv "$old_path" "$new_path"; then
    echo "cclm profile rename: mv failed ($old_path -> $new_path)" >&2
    return 1
  fi
  echo "Renamed ${old}.json -> ${new}.json" >&2
  return 0
}

_cclm_profile_delete() {
  local slug="${1:-}"
  if [[ -z "$slug" ]]; then
    echo "Usage: cclm profile delete <slug>" >&2
    return 2
  fi

  local prefix
  prefix=$(_cclm_profile_prefix_of "$slug" "delete") || return 1

  local pfile="$CONFIG_DIR/${slug}.json"
  if [[ ! -f "$pfile" ]]; then
    echo "cclm profile delete: profile not found: $pfile" >&2
    return 1
  fi

  if [[ "${FORCE:-0}" != "1" ]]; then
    printf "Delete %s? (y/N): " "$slug" >&2
    local reply
    read -r reply
    if [[ ! "$reply" =~ ^[Yy]$ ]]; then
      echo "Cancelled." >&2
      return 0
    fi
  fi

  if ! rm -- "$pfile"; then
    echo "cclm profile delete: rm failed: $pfile" >&2
    return 1
  fi
  echo "Deleted ${slug}.json" >&2
  return 0
}

# ---------------------------------------------------------------------------
# LM Studio: detect currently-loaded model and render the picker.
# Defined above the CCLM_LIB_ONLY guard so tests can drive them directly
# without going through the full run_lms() flow (which requires a live
# LM Studio server + matching `lms ls` output).
# ---------------------------------------------------------------------------

# Detect the currently-loaded LM Studio model.
# Writes two tab-separated values to stdout:
#   <modelKey>\t<identifier-preferred key>
# Both are empty if `lms ps` fails or returns no entries — callers treat that
# as "nothing loaded" and behavior is identical to pre-change.
#
# modelKey — matches entries returned by `lms ls --llm --json`; used for the
#   existing [LOADED] marker in the picker list.
# identifier-preferred key — falls back to modelKey when no custom identifier
#   is set; mirrors the extraction pattern already used when resolving the
#   API id post-load (see api_id resolution further down in run_lms).
_cclm_lms_detect_loaded() {
  local ps_json mk ident
  ps_json=$(lms ps --json 2>/dev/null || true)
  if [[ -z "$ps_json" ]]; then
    printf '\t\n'
    return 0
  fi
  mk=$(printf '%s' "$ps_json" | jq -r '.[0].modelKey // empty' 2>/dev/null || true)
  ident=$(printf '%s' "$ps_json" | jq -r '.[0] | if .identifier == null or .identifier == "null" or .identifier == "" then (.modelKey // empty) else .identifier end' 2>/dev/null || true)
  [[ "$mk" == "null" ]] && mk=""
  [[ "$ident" == "null" ]] && ident=""
  printf '%s\t%s\n' "$mk" "$ident"
}

# Render the interactive LM Studio model picker to stderr.
# Args: <models_json> <loaded_id> <loaded_key>
#   models_json — raw output of `lms ls --llm --json`
#   loaded_id   — modelKey of loaded model (empty if none)
#   loaded_key  — identifier-preferred key (empty if none)
#
# Writes one tab-separated line to stdout: <default_idx>\t<show_synthetic>\t<count>
# (default_idx=0 when no default should be offered; show_synthetic is
# "true"/"false"; count is the number of numbered entries.)
#
# Rendering rules (req 2):
#   - [LOADED] marker on list entry whose modelKey == loaded_id.
#   - Loaded model's slug-profile EXISTS → default_idx = its list position;
#     prompt shows "[N]" hint so Enter picks it.
#   - Loaded model exists but has NO saved profile → prepend synthetic
#     "0) Use currently-loaded model: <loaded_key>" and allow 0 in range.
_cclm_lms_render_model_picker() {
  local models_json="$1" loaded_id="$2" loaded_key="$3"
  local count default_idx=0 show_synthetic=false has_loaded_profile=false
  count=$(printf '%s' "$models_json" | jq 'length' 2>/dev/null || echo 0)

  if [[ -n "$loaded_key" ]] && [[ -f "$CONFIG_DIR/lms-$(slug "$loaded_key").json" ]]; then
    has_loaded_profile=true
  fi

  echo "" >&2
  echo "Available LM Studio models:" >&2
  echo "" >&2

  if [[ -n "$loaded_key" ]] && ! $has_loaded_profile; then
    show_synthetic=true
    printf "  0) Use currently-loaded model: %s\n" "$loaded_key" >&2
  fi

  local i key display params max_ctx tool_use loaded_marker tool_tag saved_tag
  for ((i=0; i<count; i++)); do
    loaded_marker="" tool_tag="" saved_tag=""
    key=$(printf '%s' "$models_json" | jq -r ".[$i].modelKey")
    display=$(printf '%s' "$models_json" | jq -r ".[$i].displayName")
    params=$(printf '%s' "$models_json" | jq -r ".[$i].paramsString")
    max_ctx=$(printf '%s' "$models_json" | jq -r ".[$i].maxContextLength")
    tool_use=$(printf '%s' "$models_json" | jq -r ".[$i].trainedForToolUse")
    [[ "$key" = "$loaded_id" ]] && loaded_marker=" [LOADED]"
    [[ "$tool_use" = "true" ]] && tool_tag=" tools"
    [[ -f "$CONFIG_DIR/lms-$(slug "$key").json" ]] && saved_tag=" *"
    if $has_loaded_profile && [[ "$key" = "$loaded_id" ]]; then
      default_idx=$((i+1))
    fi
    printf "  %d) %-30s %6s  ctx:%dk%s%s%s\n" \
      $((i+1)) "$display" "$params" $((max_ctx/1024)) "$tool_tag" "$loaded_marker" "$saved_tag" >&2
  done
  echo "" >&2
  echo "  (* = saved profile)" >&2
  echo "" >&2

  local prompt_range="1-${count}"
  $show_synthetic && prompt_range="0-${count}"
  if (( default_idx > 0 )); then
    printf "Select model (%s) [%d]: " "$prompt_range" "$default_idx" >&2
  else
    printf "Select model (%s): " "$prompt_range" >&2
  fi

  printf '%d\t%s\t%d\n' "$default_idx" "$show_synthetic" "$count"
}

# ============================================================================
# `cclm keys` subcommand — secure credential storage
# ============================================================================
# Manages API keys via the system credential store. Backend is detected by
# capability (command -v) not $OSTYPE — keeps PATH-shim tests clean.
#
# Backend precedence:
#   1. `security`     — macOS Keychain (service name: "cclm-<name>")
#   2. `secret-tool`  — Linux libsecret (service=cclm, name=<name>)
#   3. file fallback  — $CONFIG_DIR/keys/<name> with mode 600 (dir 700)
#
# `_cclm_get_key` additionally falls back to env var <NAME_UPPER>_API_KEY
# between the credential store and the file fallback, so existing users with
# `ZAI_API_KEY` in their shell keep working with zero config changes.
#
# Secrets are never printed to stderr. Only `cclm keys get` writes to stdout.
# Defined above the CCLM_LIB_ONLY guard so unit tests can call them directly.

# Pick a credential backend once. Echoes one of: security, secret-tool, file.
_cclm_keys_backend() {
  if (( $+commands[security] )); then
    echo security
  elif (( $+commands[secret-tool] )); then
    echo secret-tool
  else
    echo file
  fi
}

# File-fallback path resolver. Avoids `local path=...` (zsh PATH gotcha).
_cclm_keys_file_path() {
  echo "$CONFIG_DIR/keys/$1"
}

# Get a secret by name. Order: keychain/secret-tool, env var, file, empty.
# Prints secret to stdout (empty if not found). Never logs anything.
_cclm_get_key() {
  local name="$1"
  [[ -z "$name" ]] && return 0
  local backend secret="" env_name key_file
  backend="$(_cclm_keys_backend)"

  case "$backend" in
    security)
      secret=$(security find-generic-password -a "$USER" -s "cclm-$name" -w 2>/dev/null || true)
      ;;
    secret-tool)
      secret=$(secret-tool lookup service cclm name "$name" 2>/dev/null || true)
      ;;
  esac

  if [[ -z "$secret" ]]; then
    # Env-var fallback: e.g. name=zai -> $ZAI_API_KEY.
    env_name="${(U)name}_API_KEY"
    secret="${(P)env_name:-}"
  fi

  if [[ -z "$secret" ]]; then
    key_file="$(_cclm_keys_file_path "$name")"
    if [[ -r "$key_file" ]]; then
      secret=$(<"$key_file")
    fi
  fi

  printf '%s' "$secret"
}

# `cclm keys add <name>`: prompt for a secret (input hidden) and store it.
_cclm_keys_add() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo "Usage: cclm keys add <name>" >&2
    return 2
  fi
  printf "Enter secret for '%s' (input hidden): " "$name" >&2
  local secret
  read -rs secret
  echo "" >&2
  if [[ -z "$secret" ]]; then
    echo "No secret provided; aborting." >&2
    return 1
  fi

  local backend
  backend="$(_cclm_keys_backend)"
  case "$backend" in
    security)
      # -U updates the existing entry instead of erroring on duplicate.
      if security add-generic-password -a "$USER" -s "cclm-$name" -w "$secret" -U >/dev/null 2>&1; then
        echo "Stored '$name' in macOS Keychain (service: cclm-$name)." >&2
      else
        echo "Failed to store '$name' in Keychain." >&2
        unset secret
        return 1
      fi
      ;;
    secret-tool)
      if printf '%s' "$secret" | secret-tool store --label "cclm/$name" service cclm name "$name" >/dev/null 2>&1; then
        echo "Stored '$name' via libsecret (service=cclm, name=$name)." >&2
      else
        echo "Failed to store '$name' via secret-tool." >&2
        unset secret
        return 1
      fi
      ;;
    file)
      local key_dir key_file
      key_dir="$CONFIG_DIR/keys"
      key_file="$(_cclm_keys_file_path "$name")"
      mkdir -p "$key_dir"
      chmod 700 "$key_dir" 2>/dev/null || true
      # Restrict perms while writing — never widen the window.
      (umask 077 && printf '%s' "$secret" > "$key_file")
      chmod 600 "$key_file" 2>/dev/null || true
      echo "Warning: no system credential store available." >&2
      echo "  Stored '$name' at $key_file (mode 600). Consider installing" >&2
      echo "  the 'security' (macOS) or 'secret-tool' (Linux) tool." >&2
      ;;
  esac
  unset secret
  return 0
}

# `cclm keys remove <name>`: delete stored secret from primary backend + file.
_cclm_keys_remove() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo "Usage: cclm keys remove <name>" >&2
    return 2
  fi
  local removed=false backend
  backend="$(_cclm_keys_backend)"

  case "$backend" in
    security)
      if security delete-generic-password -a "$USER" -s "cclm-$name" >/dev/null 2>&1; then
        echo "Removed '$name' from macOS Keychain." >&2
        removed=true
      fi
      ;;
    secret-tool)
      if secret-tool clear service cclm name "$name" >/dev/null 2>&1; then
        echo "Removed '$name' from libsecret." >&2
        removed=true
      fi
      ;;
  esac

  # Always sweep file fallback too — user may have mixed backends over time.
  local key_file
  key_file="$(_cclm_keys_file_path "$name")"
  if [[ -f "$key_file" ]]; then
    rm -f "$key_file"
    echo "Removed $key_file." >&2
    removed=true
  fi

  if ! $removed; then
    echo "No stored key named '$name' found." >&2
    return 1
  fi
  return 0
}

# `cclm keys list`: print names only, never values. One per line on stdout.
_cclm_keys_list() {
  local backend found=false
  backend="$(_cclm_keys_backend)"

  case "$backend" in
    security)
      # dump-keychain is noisy and may prompt; best-effort grep for cclm-*.
      local dump
      dump=$(security dump-keychain 2>/dev/null | grep -oE '"svce"<blob>="cclm-[^"]+"' 2>/dev/null || true)
      if [[ -n "$dump" ]]; then
        echo "$dump" | sed -E 's/.*"cclm-([^"]+)".*/\1/' | sort -u
        found=true
      fi
      ;;
    secret-tool)
      local search
      search=$(secret-tool search --all service cclm 2>/dev/null | awk -F' = ' '/^attribute\.name /{print $2}' | sort -u || true)
      if [[ -n "$search" ]]; then
        echo "$search"
        found=true
      fi
      ;;
  esac

  # Also enumerate file fallbacks (mixed-backend or no-keychain environments).
  local key_dir="$CONFIG_DIR/keys"
  if [[ -d "$key_dir" ]]; then
    local f
    for f in "$key_dir"/*(N); do
      [[ -f "$f" ]] || continue
      echo "${f:t}"
      found=true
    done
  fi

  if ! $found; then
    echo "No cclm keys stored." >&2
    return 0
  fi
  return 0
}

# `cclm keys get <name>`: print secret on stdout (scripting / internal use).
_cclm_keys_get() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo "Usage: cclm keys get <name>" >&2
    return 2
  fi
  local secret
  secret="$(_cclm_get_key "$name")"
  if [[ -z "$secret" ]]; then
    echo "No key named '$name' found." >&2
    return 1
  fi
  printf '%s\n' "$secret"
  return 0
}

cmd_keys() {
  local sub="${1:-}"
  if [[ -z "$sub" || "$sub" == "-h" || "$sub" == "--help" ]]; then
    cat >&2 <<'EOF'
Usage: cclm keys <subcommand> [args...]

Subcommands:
  add <name>      Store a secret (prompts, input hidden).
  get <name>      Print a stored secret to stdout.
  list            List stored key names (values never shown).
  remove <name>   Delete a stored secret.

Backends (auto-detected):
  macOS: security (Keychain), Linux: secret-tool (libsecret),
  fallback: $CONFIG_DIR/keys/<name> (mode 600).
EOF
    [[ -z "$sub" ]] && return 2
    return 0
  fi
  shift
  case "$sub" in
    add)    _cclm_keys_add "$@" ;;
    get)    _cclm_keys_get "$@" ;;
    list)   _cclm_keys_list "$@" ;;
    remove|rm|delete) _cclm_keys_remove "$@" ;;
    *)
      echo "Unknown keys subcommand: $sub" >&2
      echo "Run 'cclm keys --help' for usage." >&2
      return 2
      ;;
  esac
}

# When sourced for tests (CCLM_LIB_ONLY=1), return here — helpers are defined,
# main execution (migration, arg parsing, backend dispatch) is skipped.
[[ "${CCLM_LIB_ONLY:-0}" == "1" ]] && return 0

# Stale-backup recovery: the EXIT trap below never fires on the success path
# (exec claude replaces the process), so a previous invocation that merged
# mcp_servers leaves its backup on disk. Restore it before anyone touches
# ~/.claude.json this run.
if [[ -f "$CCLM_CLAUDE_BACKUP" ]]; then
  echo "cclm: restoring ${CCLM_CLAUDE_CONFIG} from previous session backup." >&2
  restore_claude_config || true
fi

# Shell-level EXIT / INT / TERM hooks for per-profile MCP merges. These must be
# defined at GLOBAL scope (not inside a function) because zsh scopes trap/
# TRAPEXIT definitions to the enclosing function. Fires only when
# apply_mcp_servers set `_CCLM_MCP_ARMED=1` on the active shell — meaning we
# actually merged something and didn't reach `exec claude`. The subshell guard
# prevents the hook running inside every $(…) command substitution.
_cclm_mcp_on_exit() {
  (( ZSH_SUBSHELL == 0 )) || return 0
  [[ "${_CCLM_MCP_ARMED:-0}" == "1" ]] || return 0
  restore_claude_config
}
trap '_cclm_mcp_on_exit'                                          EXIT
trap '_cclm_mcp_on_exit; trap - INT;  kill -INT  $$'              INT
trap '_cclm_mcp_on_exit; trap - TERM; kill -TERM $$'              TERM

# ============================================================================
# Profile Migration
# ============================================================================

for f in "$CONFIG_DIR"/*.json(N); do
  _base="${f:t}"
  [[ "$_base" == .* ]] && continue
  [[ "$_base" == lms-* || "$_base" == llama-* || "$_base" == zai-* || "$_base" == remote-* || "$_base" == ollama-* || "$_base" == vllm-* ]] && continue
  [[ "$_base" != *-* ]] && continue
  mv "$f" "$CONFIG_DIR/lms-${_base}"
  echo "  [migrate] ${_base} -> lms-${_base}" >&2
done

# Add remote_host field to profiles that lack it (backward compat)
for f in "$CONFIG_DIR"/{llama,lms}-*.json(N); do
  jq -e 'has("remote_host")' "$f" >/dev/null 2>&1 && continue
  _tmp=$(mktemp) && jq '. + {remote_host: null}' "$f" > "$_tmp" && mv "$_tmp" "$f"
done

# ============================================================================
# Argument Parsing
# ============================================================================

backend=""
remote_host=""
DRY_RUN=false
passthrough_args=()

# Intercept subcommands BEFORE backend dispatch. These are cclm-internal
# commands that don't launch claude (e.g. `cclm log`). Consume the leading
# subcommand word and forward the rest to the handler, which exits.
if [[ $# -ge 1 && "$1" == "log" ]]; then
  shift
  cmd_log "$@"
  exit $?
fi

if [[ $# -ge 1 && "$1" == "status" ]]; then
  shift
  cmd_status "$@"
  exit $?
fi

if [[ $# -ge 1 && "$1" == "edit" ]]; then
  shift
  cmd_edit "$@"
  exit $?
fi

if [[ $# -ge 1 && "$1" == "profile" ]]; then
  shift
  cmd_profile "$@"
  exit $?
fi

if [[ $# -ge 1 && "$1" == "bench" ]]; then
  shift
  cmd_bench "$@"
  exit $?
fi

if [[ $# -ge 1 && "$1" == "keys" ]]; then
  shift
  cmd_keys "$@"
  exit $?
fi

# Top-level shortcuts: `cclm resume` and `cclm <profile-slug>`. Both must
# short-circuit the profile/backend pickers by pre-populating preload globals.
# Explicit backend flags (--lms/--llama/...) take precedence — if any backend
# flag appears anywhere in $@, we skip shortcut detection entirely and let the
# normal arg parser drive dispatch.
_PRELOADED_PROFILE=""
_PRELOADED_ACTION=""
_has_backend_flag=false
for _a in "$@"; do
  case "$_a" in
    --lms|--llama|--zai|--remote|--ollama|--vllm) _has_backend_flag=true; break ;;
  esac
done
unset _a
if (( $# >= 1 )) && ! $_has_backend_flag; then
  # `set -e` is active, so we must guard the call — non-zero rc from the
  # helper is part of its contract (1 = fall-through, 2 = resume-no-state),
  # not a failure that should kill the script.
  _sc_rc=0
  try_shortcut_dispatch "$1" || _sc_rc=$?
  case "$_sc_rc" in
    0) shift ;;  # shortcut consumed $1; remaining args flow to passthrough
    2)
      echo "cclm: no previous session recorded — nothing to resume." >&2
      exit 1
      ;;
    # rc=1: not a shortcut — fall through to normal arg parsing
  esac
  unset _sc_rc
fi
unset _has_backend_flag

while (( $# )); do
  case "$1" in
    --lms)    backend="lms" ;;
    --llama)  backend="llama" ;;
    --zai)    backend="zai" ;;
    --remote) backend="remote" ;;
    --ollama) backend="ollama" ;;
    --vllm)   backend="vllm" ;;
    --dry-run|--print-env) DRY_RUN=true ;;
    --host)
      [[ $# -ge 2 ]] || { echo "--host requires an argument" >&2; exit 2; }
      remote_host="$2"; shift ;;
    --host=*) remote_host="${1#--host=}" ;;
    *)       passthrough_args+=("$1") ;;
  esac
  shift
done
export DRY_RUN

# --- Per-project .cclmrc auto-selection -------------------------------------
# Precedence: CLI flags > positional slug > .cclmrc > picker. At this point
# both paths that set a backend have already run: an explicit `--<backend>`
# flag will have set $backend, and a matching positional slug will have set
# both $backend AND $_PRELOADED_PROFILE via try_shortcut_dispatch. So "nothing
# explicit was selected" reduces to the single guard below.
if [[ -z "$backend" && -z "${_PRELOADED_PROFILE:-}" ]]; then
  _rcpath=$(find_cclmrc "$PWD") || _rcpath=""
  if [[ -n "$_rcpath" ]] && apply_cclmrc "$_rcpath"; then
    if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
      echo "[cclm] using .cclmrc from $_rcpath: profile=${_PRELOADED_PROFILE:t:r}" >&2
    else
      echo "[cclm] using .cclmrc from $_rcpath: backend=$backend" >&2
    fi
  fi
  unset _rcpath
fi

# Load last session state (always returns 0; last_* may be empty on first run).
load_last_session

# --- Profile picker (runs first when no backend flag) ---
# pick_profile() is defined above the CCLM_LIB_ONLY guard (see top of file).
# Preload globals may already be populated by try_shortcut_dispatch (`cclm
# resume` / `cclm <slug>`); only initialize if empty so we don't wipe them.
: "${_PRELOADED_PROFILE:=}"
: "${_PRELOADED_ACTION:=}"
if [[ -z "$backend" ]] && pick_profile; then
  # backend was set by pick_profile — dispatch directly
  :
elif [[ -n "$_PRELOADED_PROFILE" ]]; then
  # Backend was pre-selected via --lms/--llama/--zai, profile picked
  :
elif [[ -z "$backend" ]]; then
  # No profile picked — show existing backend picker
  echo "" >&2
  echo "Select backend:" >&2

  # Show resume option if available
  if [[ -n "$last_backend" && -n "$last_profile" ]]; then
    echo "  0) Resume last session ($last_backend @ ${last_remote:-local}, $last_model)" >&2
  fi

  echo "  1) LM Studio" >&2
  echo "  2) llama.cpp" >&2
  echo "  3) Z.ai GLM (remote)" >&2
  echo "  4) Remote (OpenAI-compatible: just IP + port + ctx)" >&2
  echo "" >&2

  if [[ -n "$last_backend" ]]; then
    printf "Choice (0-4): " >&2
  else
    printf "Choice (1-4): " >&2
  fi
  read -r bchoice

  case "$bchoice" in
    0)
      backend="$last_backend"
      remote_host="$last_remote"
      ;;
    1) backend="lms" ;;
    2) backend="llama" ;;
    3) backend="zai" ;;
    4) backend="remote" ;;
    *) echo "Invalid selection." >&2; exit 1 ;;
  esac
fi

# Remote-host prompt applies to local-backend flows only; Z.ai and remote handle host internally.
if [[ -z "$remote_host" && "$backend" != "zai" && "$backend" != "remote" && -z "$_PRELOADED_PROFILE" ]]; then
  printf "  Remote host               [local]: " >&2
  read -r _rhost
  remote_host="${_rhost:-}"
fi

# ============================================================================
# LM Studio Backend
# ============================================================================

run_lms() {
  local LMS_HOST="${remote_host:-localhost}"
  local LMS_PORT=1234
  local LMS_URL="http://${LMS_HOST}:${LMS_PORT}"

  local is_lms_remote=false
  [[ "$LMS_HOST" != "localhost" && "$LMS_HOST" != "127.0.0.1" ]] && is_lms_remote=true

  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    local _pl_model _pl_ctx _pl_gpu _pl_parallel _pl_ttl _pl_id _pl_rh
    _pl_model=$(jq -r '.model' "$_PRELOADED_PROFILE")
    _pl_ctx=$(jq -r '.context_length // "65536"' "$_PRELOADED_PROFILE")
    _pl_gpu=$(jq -r '.gpu // "max"' "$_PRELOADED_PROFILE")
    _pl_parallel=$(jq -r '.parallel // "1"' "$_PRELOADED_PROFILE")
    _pl_ttl=$(jq -r '.ttl // ""' "$_PRELOADED_PROFILE")
    _pl_id=$(jq -r '.identifier // ""' "$_PRELOADED_PROFILE")
    _pl_rh=$(jq -r '.remote_host // ""' "$_PRELOADED_PROFILE")
    LMS_HOST="${_pl_rh:-localhost}"
    [[ "$LMS_HOST" == "null" ]] && LMS_HOST="localhost"
    LMS_URL="http://${LMS_HOST}:${LMS_PORT}"
    [[ "$LMS_HOST" != "localhost" && "$LMS_HOST" != "127.0.0.1" ]] && is_lms_remote=true

    if [[ "${_PRELOADED_ACTION:-open}" == "open" ]]; then
      # Fast launch: skip all model selection, load and connect directly
      echo "" >&2
      echo "  [$LMS_HOST] $_pl_model" >&2
      if $is_lms_remote; then
        # Remote: check server, poll if needed, connect
        local server_up=false
        curl -sf --max-time 3 "${LMS_URL}/v1/models" > /dev/null 2>&1 && server_up=true
        if ! $server_up; then
          echo "" >&2
          echo "  ────────────────────────────────────────────────────────────────" >&2
          echo "  Run this on $LMS_HOST:" >&2
          echo "" >&2
          printf "  lms server start --port %s && \\\\\n" "$LMS_PORT" >&2
          printf "  lms load \"%s\" -c %s --gpu %s --parallel %s -y\n" \
            "$_pl_model" "$_pl_ctx" "$_pl_gpu" "$_pl_parallel" >&2
          echo "" >&2
          echo "  ────────────────────────────────────────────────────────────────" >&2
          echo "" >&2
          if ! poll_until_ready "${LMS_URL}/v1/models" '.data | length > 0' 300 5 "${LMS_HOST}:${LMS_PORT}"; then
            echo "" >&2
            exit 1
          fi
        fi
        save_last_session "lms" "$(basename "$_PRELOADED_PROFILE")" "$LMS_HOST" "$_pl_model"
        launch_claude exec "$_pl_model" "$LMS_HOST" "$LMS_PORT" "$_pl_ctx" "${passthrough_args[@]}"
      else
        # Local: check LMS, load model, launch
        if ! curl -s "${LMS_URL}/v1/models" > /dev/null 2>&1; then
          echo "LM Studio is not reachable at ${LMS_URL}" >&2
          echo "Start it with: lms server start --port ${LMS_PORT}" >&2
          exit 1
        fi
        local loaded_id
        loaded_id=$(lms ps --json 2>/dev/null | jq -r '.[0].modelKey // empty' 2>/dev/null || true)
        if [[ -n "$loaded_id" && "$loaded_id" != "$_pl_model" ]]; then
          echo "Unloading: $loaded_id" >&2
          lms unload "$loaded_id" 2>/dev/null || true
        fi
        local -a load_args=("-c" "$_pl_ctx" "--gpu" "$_pl_gpu" "--parallel" "$_pl_parallel" "-y")
        [[ -n "$_pl_ttl" ]] && load_args+=("--ttl" "$_pl_ttl")
        [[ -n "$_pl_id" ]] && load_args+=("--identifier" "$_pl_id")
        load_args+=("$_pl_model")
        echo "Loading: $_pl_model" >&2
        echo "  ctx:$_pl_ctx  gpu:$_pl_gpu  parallel:$_pl_parallel" >&2
        lms load "${load_args[@]}"
        local api_id
        api_id=$(lms ps --json 2>/dev/null | jq -r '.[0] | if .identifier == null or .identifier == "null" then .modelKey else .identifier end' 2>/dev/null || true)
        [[ "$api_id" == "null" || -z "$api_id" ]] && {
          echo "No model loaded in LM Studio. Run: lms load <model>" >&2
          exit 1
        }
        save_last_session "lms" "$(basename "$_PRELOADED_PROFILE")" "$LMS_HOST" "$api_id"
        launch_claude exec "$api_id" "$LMS_HOST" "$LMS_PORT" "$_pl_ctx" "${passthrough_args[@]}"
      fi
      return
    else
      # Edit: fall through to existing flow, but skip model selection
      # and force re-prompt of parameters with profile values as defaults.
      EDIT_MODE=true
    fi
  fi

  # --- Remote LM Studio ---
  if $is_lms_remote; then
    local server_up=false
    curl -sf --max-time 3 "${LMS_URL}/v1/models" > /dev/null 2>&1 && server_up=true

    if ! $server_up; then
      # Server not running: walk through config, generate one-liner, poll
      echo "" >&2
      echo "LM Studio at ${LMS_URL} is not reachable." >&2
      echo "" >&2

      local lms_model_key lms_ctx lms_gpu lms_parallel lms_profile
      if [[ "${EDIT_MODE:-false}" == "true" ]]; then
        lms_model_key=$(jq -r '.model' "$_PRELOADED_PROFILE")
        echo "Editing profile for: $lms_model_key" >&2
      else
        lms_model_key=$(ask "Model key on $LMS_HOST (e.g., qwen/qwen3.5-27b)" "")
        if [[ -z "$lms_model_key" ]]; then
          echo "Model key is required." >&2
          exit 1
        fi
      fi
      lms_profile="$CONFIG_DIR/lms-$(slug "$lms_model_key").json"

      local use_lms_saved=false
      if schema_display "$lms_profile" "${LMS_PROFILE_SCHEMA_BRIEF[@]}"; then
        use_lms_saved=true
      fi

      local d_lctx="65536" d_lgpu="max" d_lpar="1"
      if [[ -f "$lms_profile" ]]; then
        d_lctx=$(jq -r '.context_length // "65536"' "$lms_profile")
        d_lgpu=$(jq -r '.gpu // "max"' "$lms_profile")
        d_lpar=$(jq -r '.parallel // "1"' "$lms_profile")
      fi

      if $use_lms_saved; then
        lms_ctx="$d_lctx"; lms_gpu="$d_lgpu"; lms_parallel="$d_lpar"
      else
        echo "" >&2
        echo "Configure parameters (press Enter for default):" >&2
        echo "" >&2
        lms_ctx=$(ask "Context length" "$d_lctx")
        lms_gpu=$(ask "GPU offload" "$d_lgpu")
        lms_parallel=$(ask "Parallel requests" "$d_lpar")
        jq -n \
          --arg model "$lms_model_key" \
          --arg ctx "$lms_ctx" \
          --arg gpu "$lms_gpu" \
          --arg par "$lms_parallel" \
          --arg rh "$LMS_HOST" \
          '{model: $model, context_length: $ctx, gpu: $gpu, parallel: $par, remote_host: (if $rh == "" then null else $rh end)}' > "$lms_profile"
        echo "" >&2
        echo "Profile saved." >&2
      fi

      echo "" >&2
      echo "  ────────────────────────────────────────────────────────────────" >&2
      echo "  Run this on $LMS_HOST:" >&2
      echo "" >&2
      printf "  lms server start --port %s && \\\\\n" "$LMS_PORT" >&2
      printf "  lms load \"%s\" -c %s --gpu %s --parallel %s -y\n" \
        "$lms_model_key" "$lms_ctx" "$lms_gpu" "$lms_parallel" >&2
      echo "" >&2
      echo "  ────────────────────────────────────────────────────────────────" >&2
      echo "" >&2

      if ! poll_until_ready "${LMS_URL}/v1/models" '.data | length > 0' 300 5 "${LMS_HOST}:${LMS_PORT}"; then
        echo "" >&2
        exit 1
      fi

      save_last_session "lms" "lms-$(slug "$lms_model_key").json" "$LMS_HOST" "$lms_model_key"
      launch_claude exec "$lms_model_key" "$LMS_HOST" "$LMS_PORT" "$lms_ctx" "${passthrough_args[@]}"
      return
    fi

    # Server IS running: query and select model (or use profile's in edit mode)
    local api_id
    if [[ "${EDIT_MODE:-false}" == "true" ]]; then
      api_id=$(jq -r '.model' "$_PRELOADED_PROFILE")
      echo "Editing profile for: $api_id" >&2
    else
      local api_models
      api_models=$(curl -s "${LMS_URL}/v1/models" 2>/dev/null \
        | jq -r '.data[].id | select(contains("embedding") | not)' 2>/dev/null || true)

      if [[ -z "$api_models" ]]; then
        echo "No models available on remote LM Studio at ${LMS_URL}" >&2
        exit 1
      fi

      echo "" >&2
      echo "Models on remote LM Studio (${LMS_HOST}):" >&2
      echo "" >&2
      local count=0
      local model_list=()
      while IFS= read -r mid; do
        count=$((count + 1))
        model_list+=("$mid")
        printf "  %d) %s\n" "$count" "$mid" >&2
      done <<< "$api_models"
      echo "" >&2

      printf "Select model (1-%d): " "$count" >&2
      read -r selection

      if ! [[ "$selection" =~ ^[0-9]+$ ]] || (( selection < 1 || selection > count )); then
        echo "Invalid selection." >&2
        exit 1
      fi

      api_id="${model_list[$selection]}"
    fi
    echo "" >&2
    local ctx_size d_ctx="65536"
    [[ "${EDIT_MODE:-false}" == "true" ]] && d_ctx=$(jq -r '.context_length // "65536"' "$_PRELOADED_PROFILE")
    ctx_size=$(ask "Context window (tokens)" "$d_ctx")

    save_last_session "lms" "lms-$(slug "$api_id").json" "$LMS_HOST" "$api_id"
    launch_claude exec "$api_id" "$LMS_HOST" "$LMS_PORT" "$ctx_size" "${passthrough_args[@]}"
    return
  fi

  # --- Local LM Studio: preflight check ---
  if ! curl -s "${LMS_URL}/v1/models" > /dev/null 2>&1; then
    echo "LM Studio is not reachable at ${LMS_URL}" >&2
    echo "Start it with: lms server start --port ${LMS_PORT}" >&2
    exit 1
  fi

  local models_json
  models_json=$(lms ls --llm --json 2>/dev/null)

  if [[ -z "$models_json" ]] || [[ "$(echo "$models_json" | jq 'length')" -eq 0 ]]; then
    echo "No LLM models found in LM Studio." >&2
    exit 1
  fi

  # Auto-detect currently-loaded model. Empty values → nothing loaded,
  # behavior matches pre-change (no synthetic option, no default hint).
  local loaded_id loaded_key _detect_out
  _detect_out=$(_cclm_lms_detect_loaded)
  loaded_id="${_detect_out%%$'\t'*}"
  loaded_key="${_detect_out##*$'\t'}"
  loaded_key="${loaded_key%$'\n'}"
  local loaded_profile_path=""
  [[ -n "$loaded_key" ]] && loaded_profile_path="$CONFIG_DIR/lms-$(slug "$loaded_key").json"

  local chosen chosen_max_ctx profile
  if [[ "${EDIT_MODE:-false}" == "true" ]]; then
    chosen=$(jq -r '.model' "$_PRELOADED_PROFILE")
    chosen_max_ctx=$(echo "$models_json" | jq -r --arg k "$chosen" '.[] | select(.modelKey == $k) | .maxContextLength' 2>/dev/null | head -1)
    [[ -z "$chosen_max_ctx" ]] && chosen_max_ctx=65536
    profile="$_PRELOADED_PROFILE"
    echo "" >&2
    echo "Editing profile for: $chosen" >&2
  else
    local _picker_out default_idx show_synthetic count
    _picker_out=$(_cclm_lms_render_model_picker "$models_json" "$loaded_id" "$loaded_key")
    default_idx="${_picker_out%%$'\t'*}"
    local _rest="${_picker_out#*$'\t'}"
    show_synthetic="${_rest%%$'\t'*}"
    count="${_rest##*$'\t'}"
    count="${count%$'\n'}"

    read -r selection

    # Empty input → default (only valid when default_idx set).
    if [[ -z "$selection" ]]; then
      if (( default_idx > 0 )); then
        selection="$default_idx"
      else
        echo "Invalid selection." >&2
        exit 1
      fi
    fi

    if ! [[ "$selection" =~ ^[0-9]+$ ]] || (( selection < 0 || selection > count )); then
      echo "Invalid selection." >&2
      exit 1
    fi
    if (( selection == 0 )) && [[ "$show_synthetic" != "true" ]]; then
      echo "Invalid selection." >&2
      exit 1
    fi

    if (( selection == 0 )); then
      # Synthetic: use the loaded model directly; no profile on disk yet.
      # Falls through to the save-new-profile block below.
      chosen="$loaded_key"
      chosen_max_ctx=$(echo "$models_json" | jq -r --arg k "$loaded_key" --arg mk "$loaded_id" '.[] | select(.modelKey == $k or .modelKey == $mk) | .maxContextLength' 2>/dev/null | head -1)
      [[ -z "$chosen_max_ctx" || "$chosen_max_ctx" == "null" ]] && chosen_max_ctx=65536
      profile="$loaded_profile_path"
    else
      chosen=$(echo "$models_json" | jq -r ".[$((selection-1))].modelKey")
      chosen_max_ctx=$(echo "$models_json" | jq -r ".[$((selection-1))].maxContextLength")
      profile="$CONFIG_DIR/lms-$(slug "$chosen").json"
    fi
  fi

  # Load or edit profile
  local use_saved=false
  if schema_display "$profile" "${LMS_PROFILE_SCHEMA[@]}"; then
    use_saved=true
  fi

  local ctx_size gpu parallel ttl identifier
  if $use_saved; then
    ctx_size=$(jq -r '.context_length' "$profile")
    gpu=$(jq -r '.gpu' "$profile")
    parallel=$(jq -r '.parallel' "$profile")
    ttl=$(jq -r '.ttl // ""' "$profile")
    identifier=$(jq -r '.identifier // ""' "$profile")
  else
    local def_ctx def_gpu="max" def_parallel="1" def_ttl="" def_id=""
    def_ctx=$((chosen_max_ctx < 32768 ? chosen_max_ctx : 32768))

    if [[ -f "$profile" ]]; then
      def_ctx=$(jq -r '.context_length' "$profile")
      def_gpu=$(jq -r '.gpu' "$profile")
      def_parallel=$(jq -r '.parallel' "$profile")
      def_ttl=$(jq -r '.ttl // ""' "$profile")
      def_id=$(jq -r '.identifier // ""' "$profile")
    fi

    echo "" >&2
    echo "Configure load parameters (press Enter for default):" >&2
    echo "" >&2
    ctx_size=$(ask "Context length" "$def_ctx")
    gpu=$(ask "GPU offload" "$def_gpu")
    parallel=$(ask "Parallel requests" "$def_parallel")
    ttl=$(ask "TTL (seconds)" "$def_ttl")
    identifier=$(ask "API identifier" "$def_id")

    jq -n \
      --arg ctx "$ctx_size" \
      --arg gpu "$gpu" \
      --arg par "$parallel" \
      --arg ttl "$ttl" \
      --arg id "$identifier" \
      --arg model "$chosen" \
      '{
        model: $model,
        context_length: $ctx,
        gpu: $gpu,
        parallel: $par,
        ttl: (if $ttl == "" then null else $ttl end),
        identifier: (if $id == "" then null else $id end),
        remote_host: null
      }' > "$profile"

    echo "" >&2
    echo "Profile saved to $profile" >&2
  fi

  # Build lms load command
  local load_args=("$chosen" "-c" "$ctx_size" "--gpu" "$gpu" "--parallel" "$parallel" "-y")
  [[ -n "$ttl" ]] && load_args+=("--ttl" "$ttl")
  [[ -n "$identifier" ]] && load_args+=("--identifier" "$identifier")

  # Load model
  if [[ "$chosen" = "$loaded_id" ]]; then
    echo "" >&2
    echo "Model already loaded: $chosen" >&2
  else
    echo "" >&2
    if [[ -n "$loaded_id" ]]; then
      echo "Unloading: $loaded_id" >&2
      lms unload "$loaded_id" 2>/dev/null || true
    fi
    echo "Loading: $chosen" >&2
    echo "  ctx:$ctx_size  gpu:$gpu  parallel:$parallel${ttl:+  ttl:${ttl}s}${identifier:+  id:$identifier}" >&2
    lms load "${load_args[@]}"
  fi

  # Resolve API identifier
  local api_id
  api_id=$(lms ps --json 2>/dev/null | jq -r '.[0] | if .identifier == null or .identifier == "null" then .modelKey else .identifier end' 2>/dev/null || true)
  [[ "$api_id" == "null" || -z "$api_id" ]] && {
    echo "No model loaded in LM Studio. Run: lms load <model>" >&2
    exit 1
  }

  save_last_session "lms" "lms-$(slug "$api_id").json" "$LMS_HOST" "$api_id"
  launch_claude exec "$api_id" "$LMS_HOST" "$LMS_PORT" "$ctx_size" "${passthrough_args[@]}"
}

# ============================================================================
# llama.cpp Backend
# ============================================================================

run_llama() {
  # Determine remote vs local early — governs the entire flow
  local llama_host="${remote_host:-localhost}"
  local is_remote=false
  [[ "$llama_host" != "localhost" && "$llama_host" != "127.0.0.1" ]] && is_remote=true

  # Shared param variables
  local chosen_path="" model_id="" profile="" chosen_fname="" model_dir="" mmproj_path="" mmproj_match=""
  local ctx_len="" gpu_layers="" flash_attn="" cache_type_k="" cache_type_v="" swa_full="" batch_size="" ubatch_size=""
  local temperature="" top_p="" top_k="" min_p="" repeat_penalty=""
  local port="" parallel_slots="" slot_save_path="" cache_ram=""
  local use_saved=false

  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    model_id=$(jq -r '.model' "$_PRELOADED_PROFILE")
    chosen_path=$(jq -r '.model_path' "$_PRELOADED_PROFILE")
    llama_host=$(jq -r '.remote_host // "localhost"' "$_PRELOADED_PROFILE")
    [[ -z "$llama_host" || "$llama_host" == "null" ]] && llama_host="localhost"
    [[ "$llama_host" != "localhost" && "$llama_host" != "127.0.0.1" ]] && is_remote=true
    profile="$_PRELOADED_PROFILE"
    [[ "${_PRELOADED_ACTION:-open}" == "open" ]] && use_saved=true
  fi

  if $is_remote; then
    # ========================================================================
    # Remote: ask model path, configure, generate one-liner, poll, connect
    # ========================================================================

    # Model selection — skip when preloaded from profile picker
    if [[ -z "$model_id" ]]; then
      echo "" >&2
      echo "Remote llama-server target: $llama_host" >&2
      echo "" >&2
      chosen_path=$(ask "Model path on $llama_host" "")
      if [[ -z "$chosen_path" ]]; then
        echo "Model path is required." >&2
        exit 1
      fi
      local _fname="${chosen_path:t}"
      model_id="${_fname%.gguf}"
      profile="$CONFIG_DIR/llama-$(slug "$model_id").json"
    fi

    if [[ -f "$profile" ]] && ! $use_saved; then
      if schema_display "$profile" "${LLAMA_PROFILE_SCHEMA_WITH_PATH[@]}"; then
        use_saved=true
      fi
    fi

    if $use_saved; then
      ctx_len=$(jq -r '.ctx_len' "$profile")
      gpu_layers=$(jq -r '.gpu_layers' "$profile")
      flash_attn=$(jq -r '.flash_attn' "$profile")
      cache_type_k=$(jq -r '.cache_type_k' "$profile")
      cache_type_v=$(jq -r '.cache_type_v' "$profile")
      swa_full=$(jq -r '.swa_full' "$profile")
      batch_size=$(jq -r '.batch_size' "$profile")
      ubatch_size=$(jq -r '.ubatch_size' "$profile")
      temperature=$(jq -r '.temperature' "$profile")
      top_p=$(jq -r '.top_p' "$profile")
      top_k=$(jq -r '.top_k' "$profile")
      min_p=$(jq -r '.min_p' "$profile")
      repeat_penalty=$(jq -r '.repeat_penalty' "$profile")
      port=$(jq -r '.port' "$profile")
      parallel_slots=$(jq -r '.parallel_slots' "$profile")
      slot_save_path=$(jq -r '.slot_save_path // ""' "$profile")
      cache_ram=$(jq -r '.cache_ram // ""' "$profile")
    else
      local d_ctx="65536" d_ngl="99" d_fa="on" d_ctk="q8_0" d_ctv="q8_0"
      local d_swa="true" d_bs="4096" d_ubs="1024"
      local d_temp="0.6" d_topp="0.95" d_topk="20" d_minp="0.00" d_rp="1.0"
      local d_port="8081" d_np="1" d_ssp="" d_cram=""

      if [[ -f "$profile" ]]; then
        d_ctx=$(jq -r '.ctx_len' "$profile")
        d_ngl=$(jq -r '.gpu_layers' "$profile")
        d_fa=$(jq -r '.flash_attn' "$profile")
        d_ctk=$(jq -r '.cache_type_k' "$profile")
        d_ctv=$(jq -r '.cache_type_v' "$profile")
        d_swa=$(jq -r '.swa_full' "$profile")
        d_bs=$(jq -r '.batch_size' "$profile")
        d_ubs=$(jq -r '.ubatch_size' "$profile")
        d_temp=$(jq -r '.temperature' "$profile")
        d_topp=$(jq -r '.top_p' "$profile")
        d_topk=$(jq -r '.top_k' "$profile")
        d_minp=$(jq -r '.min_p' "$profile")
        d_rp=$(jq -r '.repeat_penalty' "$profile")
        d_port=$(jq -r '.port' "$profile")
        d_np=$(jq -r '.parallel_slots' "$profile")
        d_ssp=$(jq -r '.slot_save_path // ""' "$profile")
        d_cram=$(jq -r '.cache_ram // ""' "$profile")
      fi

      echo "" >&2
      echo "Configure llama-server parameters (press Enter for default):" >&2
      echo "" >&2
      echo "  Loading:" >&2
      ctx_len=$(ask "Context length" "$d_ctx")
      gpu_layers=$(ask "GPU layers" "$d_ngl")
      flash_attn=$(ask "Flash attention" "$d_fa")
      cache_type_k=$(ask "KV cache type K" "$d_ctk")
      cache_type_v=$(ask "KV cache type V" "$d_ctv")
      swa_full=$(ask "SWA full" "$d_swa")
      batch_size=$(ask "Batch size" "$d_bs")
      ubatch_size=$(ask "Ubatch size" "$d_ubs")
      echo "" >&2
      echo "  Sampling:" >&2
      temperature=$(ask "Temperature" "$d_temp")
      top_p=$(ask "Top-P" "$d_topp")
      top_k=$(ask "Top-K" "$d_topk")
      min_p=$(ask "Min-P" "$d_minp")
      repeat_penalty=$(ask "Repeat penalty" "$d_rp")
      echo "" >&2
      echo "  Server:" >&2
      port=$(ask "Port" "$d_port")
      parallel_slots=$(ask "Parallel slots" "$d_np")
      slot_save_path=$(ask "Slot save path on remote" "$d_ssp")
      cache_ram=$(ask "Cache RAM (MB)" "$d_cram")

      jq -n \
        --arg ctx "$ctx_len" --arg ngl "$gpu_layers" --arg fa "$flash_attn" \
        --arg ctk "$cache_type_k" --arg ctv "$cache_type_v" --arg swa "$swa_full" \
        --arg bs "$batch_size" --arg ubs "$ubatch_size" \
        --arg temp "$temperature" --arg tp "$top_p" --arg tk "$top_k" \
        --arg mp "$min_p" --arg rp "$repeat_penalty" \
        --arg port "$port" --arg np "$parallel_slots" \
        --arg ssp "$slot_save_path" --arg cram "$cache_ram" \
        --arg model "$model_id" --arg path "$chosen_path" \
        --arg rh "$llama_host" \
        '{
          model: $model, model_path: $path,
          ctx_len: $ctx, gpu_layers: $ngl, flash_attn: $fa,
          cache_type_k: $ctk, cache_type_v: $ctv, swa_full: $swa,
          batch_size: $bs, ubatch_size: $ubs,
          temperature: $temp, top_p: $tp, top_k: $tk, min_p: $mp, repeat_penalty: $rp,
          port: $port, parallel_slots: $np,
          slot_save_path: (if $ssp == "" then null else $ssp end),
          cache_ram: (if $cram == "" then null else $cram end),
          remote_host: (if $rh == "localhost" or $rh == "127.0.0.1" or $rh == "" then null else $rh end)
        }' > "$profile"
      echo "" >&2
      echo "Profile saved." >&2
    fi

    # Print one-liner
    echo "" >&2
    echo "  ────────────────────────────────────────────────────────────────" >&2
    echo "  Run this on $llama_host:" >&2
    echo "" >&2
    printf "  llama-server \\\\\n" >&2
    printf "    -m \"%s\" \\\\\n" "$chosen_path" >&2
    printf "    -c %s -ngl %s \\\\\n" "$ctx_len" "$gpu_layers" >&2
    [[ -n "$flash_attn" ]] && printf "    --flash-attn %s \\\\\n" "$flash_attn" >&2
    printf "    --cache-type-k %s --cache-type-v %s \\\\\n" "$cache_type_k" "$cache_type_v" >&2
    [[ "$swa_full" == "true" ]] && printf "    --swa-full \\\\\n" >&2
    printf "    -b %s -ub %s \\\\\n" "$batch_size" "$ubatch_size" >&2
    printf "    --temp %s --top-p %s --top-k %s --min-p %s --repeat-penalty %s \\\\\n" \
      "$temperature" "$top_p" "$top_k" "$min_p" "$repeat_penalty" >&2
    printf "    --port %s -np %s \\\\\n" "$port" "$parallel_slots" >&2
    [[ -n "$slot_save_path" ]] && printf "    --slot-save-path \"%s\" \\\\\n" "$slot_save_path" >&2
    [[ -n "$cache_ram" ]] && printf "    --cache-ram %s \\\\\n" "$cache_ram" >&2
    printf "    --jinja --metrics --host 0.0.0.0\n" >&2
    echo "" >&2
    echo "  ────────────────────────────────────────────────────────────────" >&2

    # Check if already running, or poll until ready
    local remote_health="http://${llama_host}:${port}/health"
    if curl -sf --max-time 3 "$remote_health" 2>/dev/null | jq -e '.status == "ok"' > /dev/null 2>&1; then
      echo "" >&2
      echo "Remote server is already running. Connecting..." >&2
    else
      if ! poll_until_ready "$remote_health" '.status == "ok"' 300 5 "${llama_host}:${port}"; then
        echo "" >&2
        exit 1
      fi
    fi

    # Read actual context window from server (overrides profile — server may have been started with different -c)
    local actual_ctx
    actual_ctx=$(curl -sf --max-time 3 "http://${llama_host}:${port}/slots" 2>/dev/null | jq -r '.[0].n_ctx // empty')
    if [[ -n "$actual_ctx" && "$actual_ctx" != "$ctx_len" ]]; then
      echo "  Context: profile has ${ctx_len}, server reports ${actual_ctx} — using ${actual_ctx}" >&2
      ctx_len="$actual_ctx"
    fi

    save_last_session "llama" "$(basename "$profile")" "$llama_host" "$model_id"
    launch_claude exec "$model_id" "$llama_host" "$port" "$ctx_len" "${passthrough_args[@]}"
    return
  fi

  # ========================================================================
  # Local: scan GGUF files, configure, start llama-server, connect
  # ========================================================================

  # Model selection — skip when preloaded from profile picker
  if [[ -z "$model_id" ]]; then
    if [[ ! -d "$MODELS_DIR" ]]; then
      echo "Models directory not found: $MODELS_DIR" >&2
      exit 1
    fi

    local gguf_files=()
    local gguf_sizes=()
    local gguf_dirs=()

    while IFS= read -r -d '' fpath; do
      gguf_files+=("$fpath")
      gguf_sizes+=("$(_stat_size "$fpath")")
      gguf_dirs+=("$(basename "$(dirname "$(dirname "$fpath")")")")
    done < <(find "$MODELS_DIR" -name "*.gguf" -not -name "mmproj*" -print0 | sort -z)

    local model_count=${#gguf_files[@]}
    if (( model_count == 0 )); then
      echo "No GGUF models found in $MODELS_DIR" >&2
      exit 1
    fi

    echo "" >&2
    echo "Available GGUF models:" >&2
    echo "" >&2
    local fname hsize pdir saved_tag name_no_ext
    for ((i=0; i<model_count; i++)); do
      saved_tag=""
      fname="${gguf_files[$((i+1))]:t}"
      hsize=$(human_size "${gguf_sizes[$((i+1))]}")
      pdir="${gguf_dirs[$((i+1))]}"
      name_no_ext="${fname%.gguf}"
      [[ -f "$CONFIG_DIR/llama-$(slug "$name_no_ext").json" ]] && saved_tag=" *"
      printf "  %2d) %-42s %8s  (%s)%s\n" $((i+1)) "$fname" "$hsize" "$pdir" "$saved_tag" >&2
    done
    echo "" >&2
    echo "  (* = saved profile)" >&2
    echo "" >&2

    printf "Select model (1-%d): " "$model_count" >&2
    read -r selection

    if ! [[ "$selection" =~ ^[0-9]+$ ]] || (( selection < 1 || selection > model_count )); then
      echo "Invalid selection." >&2
      exit 1
    fi

    chosen_path="${gguf_files[$selection]}"
    chosen_fname="${chosen_path:t}"
    model_id="${chosen_fname%.gguf}"
    model_dir="${chosen_path:h}"
    profile="$CONFIG_DIR/llama-$(slug "$model_id").json"

    # --- mmproj detection (optional) ---
    mmproj_match=$(find "$model_dir" -name "mmproj*.gguf" -print -quit 2>/dev/null)
    if [[ -n "$mmproj_match" ]]; then
      echo "" >&2
      echo "Multimodal projector found: ${mmproj_match:t}" >&2
      echo "  Note: enabling mmproj disables slot save/restore (KV cache persistence)." >&2
      printf "  Load mmproj? (y/N): " >&2
      read -r mmproj_reply
      if [[ "$mmproj_reply" =~ ^[Yy]$ ]]; then
        mmproj_path="$mmproj_match"
      fi
    fi
  fi

  # --- Profile load or configure ---
  if [[ -f "$profile" ]] && ! $use_saved; then
    if schema_display "$profile" "${LLAMA_PROFILE_SCHEMA[@]}"; then
      use_saved=true
    fi
  fi

  if $use_saved; then
    ctx_len=$(jq -r '.ctx_len' "$profile")
    gpu_layers=$(jq -r '.gpu_layers' "$profile")
    flash_attn=$(jq -r '.flash_attn' "$profile")
    cache_type_k=$(jq -r '.cache_type_k' "$profile")
    cache_type_v=$(jq -r '.cache_type_v' "$profile")
    swa_full=$(jq -r '.swa_full' "$profile")
    batch_size=$(jq -r '.batch_size' "$profile")
    ubatch_size=$(jq -r '.ubatch_size' "$profile")
    temperature=$(jq -r '.temperature' "$profile")
    top_p=$(jq -r '.top_p' "$profile")
    top_k=$(jq -r '.top_k' "$profile")
    min_p=$(jq -r '.min_p' "$profile")
    repeat_penalty=$(jq -r '.repeat_penalty' "$profile")
    port=$(jq -r '.port' "$profile")
    parallel_slots=$(jq -r '.parallel_slots' "$profile")
    slot_save_path=$(jq -r '.slot_save_path // ""' "$profile")
    cache_ram=$(jq -r '.cache_ram // ""' "$profile")
  else
    local d_ctx="65536" d_ngl="99" d_fa="on" d_ctk="q8_0" d_ctv="q8_0"
    local d_swa="true" d_bs="4096" d_ubs="1024"
    local d_temp="0.6" d_topp="0.95" d_topk="20" d_minp="0.00" d_rp="1.0"
    local d_port="8081" d_np="1" d_ssp="$HOME/.cache/cclm/slots" d_cram=""

    if [[ -f "$profile" ]]; then
      d_ctx=$(jq -r '.ctx_len' "$profile")
      d_ngl=$(jq -r '.gpu_layers' "$profile")
      d_fa=$(jq -r '.flash_attn' "$profile")
      d_ctk=$(jq -r '.cache_type_k' "$profile")
      d_ctv=$(jq -r '.cache_type_v' "$profile")
      d_swa=$(jq -r '.swa_full' "$profile")
      d_bs=$(jq -r '.batch_size' "$profile")
      d_ubs=$(jq -r '.ubatch_size' "$profile")
      d_temp=$(jq -r '.temperature' "$profile")
      d_topp=$(jq -r '.top_p' "$profile")
      d_topk=$(jq -r '.top_k' "$profile")
      d_minp=$(jq -r '.min_p' "$profile")
      d_rp=$(jq -r '.repeat_penalty' "$profile")
      d_port=$(jq -r '.port' "$profile")
      d_np=$(jq -r '.parallel_slots' "$profile")
      d_ssp=$(jq -r '.slot_save_path // ""' "$profile")
      d_cram=$(jq -r '.cache_ram // ""' "$profile")
    fi

    echo "" >&2
    echo "Configure llama-server parameters (press Enter for default):" >&2

    echo "" >&2
    echo "  Loading:" >&2
    ctx_len=$(ask "Context length" "$d_ctx")
    gpu_layers=$(ask "GPU layers" "$d_ngl")
    flash_attn=$(ask "Flash attention" "$d_fa")
    cache_type_k=$(ask "KV cache type K" "$d_ctk")
    cache_type_v=$(ask "KV cache type V" "$d_ctv")
    swa_full=$(ask "SWA full" "$d_swa")
    batch_size=$(ask "Batch size" "$d_bs")
    ubatch_size=$(ask "Ubatch size" "$d_ubs")

    echo "" >&2
    echo "  Sampling:" >&2
    temperature=$(ask "Temperature" "$d_temp")
    top_p=$(ask "Top-P" "$d_topp")
    top_k=$(ask "Top-K" "$d_topk")
    min_p=$(ask "Min-P" "$d_minp")
    repeat_penalty=$(ask "Repeat penalty" "$d_rp")

    echo "" >&2
    echo "  Server:" >&2
    port=$(ask "Port" "$d_port")
    parallel_slots=$(ask "Parallel slots" "$d_np")
    slot_save_path=$(ask "Slot save path" "$d_ssp")
    cache_ram=$(ask "Cache RAM (MB)" "$d_cram")

    jq -n \
      --arg ctx "$ctx_len" \
      --arg ngl "$gpu_layers" \
      --arg fa "$flash_attn" \
      --arg ctk "$cache_type_k" \
      --arg ctv "$cache_type_v" \
      --arg swa "$swa_full" \
      --arg bs "$batch_size" \
      --arg ubs "$ubatch_size" \
      --arg temp "$temperature" \
      --arg tp "$top_p" \
      --arg tk "$top_k" \
      --arg mp "$min_p" \
      --arg rp "$repeat_penalty" \
      --arg port "$port" \
      --arg np "$parallel_slots" \
      --arg ssp "$slot_save_path" \
      --arg cram "$cache_ram" \
      --arg model "$model_id" \
      --arg path "$chosen_path" \
      '{
        model: $model,
        model_path: $path,
        ctx_len: $ctx,
        gpu_layers: $ngl,
        flash_attn: $fa,
        cache_type_k: $ctk,
        cache_type_v: $ctv,
        swa_full: $swa,
        batch_size: $bs,
        ubatch_size: $ubs,
        temperature: $temp,
        top_p: $tp,
        top_k: $tk,
        min_p: $mp,
        repeat_penalty: $rp,
        port: $port,
        parallel_slots: $np,
        slot_save_path: (if $ssp == "" then null else $ssp end),
        cache_ram: (if $cram == "" then null else $cram end),
        remote_host: null
      }' > "$profile"

    echo "" >&2
    echo "Profile saved to $profile" >&2
  fi

  # --- Port conflict check ---
  if lsof -i ":${port}" -sTCP:LISTEN > /dev/null 2>&1; then
    echo "" >&2
    echo "Port ${port} is already in use." >&2
    local pids_on_port
    pids_on_port=$(lsof -ti ":${port}" -sTCP:LISTEN 2>/dev/null | tr '\n' ' ')
    printf "Kill process(es) %s and continue? (y/N): " "${pids_on_port% }" >&2
    read -r kill_reply
    if [[ "$kill_reply" =~ ^[Yy]$ ]]; then
      local _pid
      for _pid in ${=pids_on_port}; do
        kill "$_pid" 2>/dev/null || true
      done
      # Wait up to ~2s for port to free; escalate to SIGKILL if still in use.
      local _waited=0
      while (( _waited < 20 )); do
        sleep 0.1
        lsof -i ":${port}" -sTCP:LISTEN > /dev/null 2>&1 || break
        (( _waited++ ))
      done
      if lsof -i ":${port}" -sTCP:LISTEN > /dev/null 2>&1; then
        echo "Port still in use after SIGTERM; escalating to SIGKILL..." >&2
        for _pid in ${=pids_on_port}; do
          kill -9 "$_pid" 2>/dev/null || true
        done
        sleep 0.5
      fi
      if lsof -i ":${port}" -sTCP:LISTEN > /dev/null 2>&1; then
        echo "Could not free port ${port}. Aborting." >&2
        exit 1
      fi
    else
      echo "Aborted." >&2
      exit 1
    fi
  fi

  # Build llama-server command
  local server_args=(
    "-m" "$chosen_path"
    "-c" "$ctx_len"
    "-ngl" "$gpu_layers"
    "--cache-type-k" "$cache_type_k"
    "--cache-type-v" "$cache_type_v"
    "-b" "$batch_size"
    "-ub" "$ubatch_size"
    "--temp" "$temperature"
    "--top-p" "$top_p"
    "--top-k" "$top_k"
    "--min-p" "$min_p"
    "--repeat-penalty" "$repeat_penalty"
    "--port" "$port"
    "-np" "$parallel_slots"
    "--jinja"
    "--metrics"
  )

  [[ -n "$flash_attn" ]] && server_args+=("--flash-attn" "$flash_attn")
  [[ "$swa_full" == "true" ]] && server_args+=("--swa-full")
  if [[ -n "$slot_save_path" ]]; then
    slot_save_path="${slot_save_path/#\~/$HOME}"
    mkdir -p "$slot_save_path"
    server_args+=("--slot-save-path" "$slot_save_path")
  fi
  [[ -n "$cache_ram" ]] && server_args+=("--cache-ram" "$cache_ram")
  [[ -n "$mmproj_path" ]] && server_args+=("--mmproj" "$mmproj_path")

  # Start server
  LLAMA_PID=""
  trap 'if [[ -n "${LLAMA_PID:-}" ]]; then kill "$LLAMA_PID" 2>/dev/null; wait "$LLAMA_PID" 2>/dev/null; fi' EXIT INT TERM

  echo "" >&2
  echo "Starting llama-server..." >&2
  echo "  Model: $model_id" >&2
  echo "  Port:  $port" >&2
  [[ -n "$mmproj_path" ]] && echo "  mmproj: ${mmproj_path:t}" >&2

  local cache_dir="${CCLM_CACHE_DIR:-$HOME/.cache/cclm}"
  mkdir -p "$cache_dir" 2>/dev/null || true
  local server_log="${CCLM_LOG_FILE:-$cache_dir/llama-server.log}"
  llama-server "${server_args[@]}" > "$server_log" 2>&1 &
  LLAMA_PID=$!

  # Wait for health
  local health_url="http://localhost:${port}/health"
  local waited=0
  local timeout=120

  printf "Waiting for llama-server to load model..." >&2
  while (( waited < timeout )); do
    if ! kill -0 "$LLAMA_PID" 2>/dev/null; then
      echo "" >&2
      echo "llama-server exited unexpectedly. Check log: $server_log" >&2
      tail -5 "$server_log" >&2
      exit 1
    fi
    if curl -s "$health_url" 2>/dev/null | jq -e '.status == "ok"' > /dev/null 2>&1; then
      echo " ready." >&2
      break
    fi
    printf "." >&2
    sleep 2
    waited=$((waited + 2))
  done

  if (( waited >= timeout )); then
    echo "" >&2
    echo "Timed out waiting for llama-server (${timeout}s). Check log: $server_log" >&2
    tail -10 "$server_log" >&2
    kill "$LLAMA_PID" 2>/dev/null || true
    exit 1
  fi

  save_last_session "llama" "$(basename "$profile")" "$llama_host" "$model_id"
  launch_claude fg "$model_id" "$llama_host" "$port" "$ctx_len" "${passthrough_args[@]}"
}

# ============================================================================
# Z.ai GLM Backend (remote, Anthropic-compatible)
# Docs: https://docs.z.ai/devpack/tool/claude
# ============================================================================

run_zai() {
  # --- 1. API key ---
  # Source-of-truth chain: cclm keys (keychain/secret-tool/file) > existing
  # $ZAI_API_KEY in env > interactive prompt + persist to ~/.zshenv. The first
  # lookup covers new users who ran `cclm keys add zai`; the env check keeps
  # backward-compat for users whose shell already exports the key.
  local _zai_stored
  _zai_stored="$(_cclm_get_key zai)"
  if [[ -n "$_zai_stored" ]]; then
    export ZAI_API_KEY="$_zai_stored"
  fi
  unset _zai_stored

  if [[ -z "${ZAI_API_KEY:-}" ]]; then
    echo "" >&2
    echo "Z.ai API key not found in \$ZAI_API_KEY." >&2
    echo "Get one at: https://z.ai/manage-apikey/apikey-list" >&2
    echo "" >&2
    printf "  Paste API key (input hidden): " >&2
    local _key
    read -rs _key
    echo "" >&2
    if [[ -z "$_key" ]]; then
      echo "No key provided. Aborting." >&2
      exit 1
    fi
    export ZAI_API_KEY="$_key"

    printf "  Save to ~/.zshenv so all sessions see it? (y/N): " >&2
    local _persist
    read -r _persist
    if [[ "$_persist" =~ ^[Yy]$ ]]; then
      # Persist to ~/.zshenv — loaded by every zsh invocation (login or not),
      # unlike ~/.zshrc which is interactive-only.
      local zshenv="$HOME/.zshenv"
      touch "$zshenv"
      if grep -qE '^[[:space:]]*export[[:space:]]+ZAI_API_KEY=' "$zshenv" 2>/dev/null; then
        local _tmp
        _tmp="$(mktemp)"
        grep -vE '^[[:space:]]*export[[:space:]]+ZAI_API_KEY=' "$zshenv" > "$_tmp" || true
        mv "$_tmp" "$zshenv"
        echo "  Replaced existing ZAI_API_KEY in $zshenv" >&2
      else
        echo "  Saved ZAI_API_KEY to $zshenv (loaded by all zsh sessions)" >&2
      fi
      printf "export ZAI_API_KEY=%q\n" "$_key" >> "$zshenv"
      chmod 600 "$zshenv"
    else
      echo "  Keeping key in this shell only." >&2
    fi
  fi

  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    local profile="$_PRELOADED_PROFILE"
    if [[ "${_PRELOADED_ACTION:-open}" == "open" ]]; then
      # Fast launch: read profile, set env vars, connect
      local base_url opus_model sonnet_model haiku_model ctx timeout_ms
      base_url=$(jq -r '.base_url // ""' "$profile")
      opus_model=$(jq -r '.opus_model // ""' "$profile")
      sonnet_model=$(jq -r '.sonnet_model // ""' "$profile")
      haiku_model=$(jq -r '.haiku_model // ""' "$profile")
      ctx=$(jq -r '.context_length // 200000' "$profile")
      timeout_ms=$(jq -r '.api_timeout_ms // 3000000' "$profile")

      # Back-compat with old single-model schema
      local _legacy
      _legacy=$(jq -r '.model // ""' "$profile")
      [[ -z "$opus_model"   && -n "$_legacy" ]] && opus_model="$_legacy"
      [[ -z "$sonnet_model" && -n "$_legacy" ]] && sonnet_model="$_legacy"
      [[ -z "$haiku_model"  && -n "$_legacy" ]] && haiku_model="$_legacy"

      echo "" >&2
      echo "  [zai] $sonnet_model @ ${base_url}" >&2

      save_last_session "zai" "$(basename "$profile")" "$base_url" "$sonnet_model"
      export CCLM_AUTH_TOKEN="$ZAI_API_KEY"
      export CCLM_TIER_OPUS="$opus_model"
      export CCLM_TIER_SONNET="$sonnet_model"
      export CCLM_TIER_HAIKU="$haiku_model"
      export CCLM_API_TIMEOUT_MS="$timeout_ms"

      print_tier_routing "$opus_model" "$sonnet_model" "$haiku_model"

      launch_claude exec "$sonnet_model" "$base_url" "" "$ctx" "${passthrough_args[@]}"
      return
    else
      # Edit: skip profile selection, set profile so existing flow uses it
      # The existing profile loading code will pick it up with use_saved=false
      local prof_name="${profile:t:r}"
      prof_name="${prof_name#zai-}"
      echo "" >&2
      echo "Editing profile: $prof_name" >&2
      # Fall through — the profile selection below will be skipped
    fi
  else
    local profile=""
  fi

  # --- 2. Profile selection ---
  if [[ -z "$profile" ]]; then
    # Profiles key on a user-chosen name so multiple deployments can coexist
    # (e.g., zai-payg, zai-coding-plan, zai-cheap).
    echo "" >&2
    echo "Z.ai profile:" >&2
    local -a zai_profiles
    zai_profiles=( "$CONFIG_DIR"/zai-*.json(N) )

    local i=1
    for f in "${zai_profiles[@]}"; do
      prof_name="${f:t:r}"            # basename, strip .json
      prof_name="${prof_name#zai-}"    # strip zai- prefix
      printf "  %d) %s\n" "$i" "$prof_name" >&2
      (( i++ ))
    done
    echo "  n) New profile" >&2
    printf "Choice: " >&2
    local pchoice
    read -r pchoice

    if [[ -z "$pchoice" || "$pchoice" == [nN] ]]; then
      local new_name
      new_name="$(ask 'Profile name' 'default')"
      profile="$CONFIG_DIR/zai-$(slug "$new_name").json"
    else
      if [[ "$pchoice" =~ ^[0-9]+$ ]] && (( pchoice >= 1 && pchoice <= ${#zai_profiles[@]} )); then
        profile="${zai_profiles[$pchoice]}"
      else
        echo "Invalid selection." >&2; exit 1
      fi
    fi
  fi

  # --- 3. Load saved values ---
  local d_base_url="" d_opus="" d_sonnet="" d_haiku=""
  local d_ctx="200000" d_timeout_ms="3000000"
  if [[ -f "$profile" ]]; then
    d_base_url=$(jq -r '.base_url // ""' "$profile")
    d_opus=$(jq -r '.opus_model // ""' "$profile")
    d_sonnet=$(jq -r '.sonnet_model // ""' "$profile")
    d_haiku=$(jq -r '.haiku_model // ""' "$profile")
    # Back-compat with old single-model profile schema.
    local _d_legacy
    _d_legacy=$(jq -r '.model // ""' "$profile")
    [[ -z "$d_opus"   && -n "$_d_legacy" ]] && d_opus="$_d_legacy"
    [[ -z "$d_sonnet" && -n "$_d_legacy" ]] && d_sonnet="$_d_legacy"
    [[ -z "$d_haiku"  && -n "$_d_legacy" ]] && d_haiku="$_d_legacy"
    d_ctx=$(jq -r '.context_length // 200000' "$profile")
    d_timeout_ms=$(jq -r '.api_timeout_ms // 3000000' "$profile")
  fi

  # --- 3b. Use saved profile as-is? (skip all prompts if yes) ---
  local use_saved=false
  if [[ -f "$profile" && -n "$d_base_url" && -n "$d_opus" && -n "$d_sonnet" && -n "$d_haiku" ]]; then
    if schema_display "$profile" "${ZAI_PROFILE_SCHEMA[@]}"; then
      use_saved=true
    fi
  fi

  # Output variables populated by either the saved-profile path or the prompts below.
  local base_url opus_model sonnet_model haiku_model ctx timeout_ms

  if $use_saved; then
    base_url="$d_base_url"
    opus_model="$d_opus"
    sonnet_model="$d_sonnet"
    haiku_model="$d_haiku"
    ctx="$d_ctx"
    timeout_ms="$d_timeout_ms"
  else
    # --- 4. Base URL ---
    if [[ -n "${remote_host:-}" ]]; then
      # --host flag provided: use it directly as base URL
      if [[ "$remote_host" == http://* || "$remote_host" == https://* ]]; then
        base_url="$remote_host"
      else
        base_url="https://${remote_host}"
      fi
      echo "  Using custom endpoint: $base_url" >&2
    else
      echo "" >&2
      echo "Base URL:" >&2
      echo "  1) https://api.z.ai/api/anthropic        (official Claude Code endpoint — recommended)" >&2
      echo "  2) https://api.z.ai/api/coding/paas/v4   (Coding Plan subscription, OpenAI protocol)" >&2
      echo "  3) Custom" >&2
      local url_default_hint="1"
      [[ -n "$d_base_url" ]] && url_default_hint="current: $d_base_url"
      printf "Choice [%s]: " "$url_default_hint" >&2
      local uchoice
      read -r uchoice
      case "${uchoice:-}" in
        1) base_url="https://api.z.ai/api/anthropic" ;;
        2) base_url="https://api.z.ai/api/coding/paas/v4" ;;
        3) base_url="$(ask 'Custom base URL' "${d_base_url:-https://api.z.ai/api/anthropic}")" ;;
        "") base_url="${d_base_url:-https://api.z.ai/api/anthropic}" ;;
        *)  echo "Invalid selection." >&2; exit 1 ;;
      esac
    fi

    # --- 5. Per-tier model selection ---
    # Fetch live model list from Z.ai's OpenAI-compat /models endpoint
    # (the anthropic-compat endpoint doesn't expose one). Same API key works.
    echo "" >&2
    echo "Fetching model list from Z.ai..." >&2
    local models_json
    models_json="$(curl -sf --max-time 10 \
      -H "Authorization: Bearer $ZAI_API_KEY" \
      "https://api.z.ai/api/paas/v4/models" 2>/dev/null || echo '')"

    local -a model_ids
    if [[ -n "$models_json" ]] && echo "$models_json" | jq -e '.data' >/dev/null 2>&1; then
      model_ids=( "${(f)$(echo "$models_json" | jq -r '.data[].id' | sort -u)}" )
    else
      echo "  (/models fetch failed — using built-in list)" >&2
      model_ids=( glm-4.5 glm-4.5-air glm-4.6 glm-4.7 )
    fi

    # Heuristic defaults: Opus → glm-4.7 if present, Haiku → a *-air variant if present.
    local opus_default="${model_ids[1]}" haiku_default="${model_ids[${#model_ids[@]}]}"
    local _m
    for _m in "${model_ids[@]}"; do
      [[ "$_m" == "glm-4.7" ]] && opus_default="$_m"
      [[ "$_m" == *air* ]]    && haiku_default="$_m"
    done

    # Render the model list with a (current) marker for the given tier default.
    _zai_print_models() {
      local current="$1" idx=1 m
      for m in "${model_ids[@]}"; do
        if [[ "$m" == "$current" ]]; then
          printf "  %d) %s  (current)\n" "$idx" "$m" >&2
        else
          printf "  %d) %s\n" "$idx" "$m" >&2
        fi
        (( idx++ ))
      done
    }

    # Resolve a user choice ("1", "c", "s", "") to a model ID.
    # Args: choice, default_on_empty, same_as_value ("" if "s" isn't offered).
    _zai_resolve() {
      local choice="$1" default_m="$2" same_as="$3"
      case "$choice" in
        c|C) ask 'Custom model ID' "$default_m" ;;
        s|S)
          if [[ -n "$same_as" ]]; then echo "$same_as"
          else echo "Invalid selection." >&2; return 1; fi
          ;;
        "")  echo "$default_m" ;;
        *)
          if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#model_ids[@]} )); then
            echo "${model_ids[$choice]}"
          else
            echo "Invalid selection." >&2; return 1
          fi
          ;;
      esac
    }

    # --- Tier: Opus ---
    echo "" >&2
    echo "Model for OPUS tier (highest capability — /model opus inside Claude Code):" >&2
    _zai_print_models "$d_opus"
    echo "  c) Custom" >&2
    local _opus_def="${d_opus:-$opus_default}"
    printf "Choice [%s]: " "$_opus_def" >&2
    local opus_choice
    read -r opus_choice
    opus_model="$(_zai_resolve "$opus_choice" "$_opus_def" "")" || exit 1

    # --- Tier: Sonnet ---
    echo "" >&2
    echo "Model for SONNET tier (default conversation):" >&2
    _zai_print_models "$d_sonnet"
    echo "  s) Same as Opus ($opus_model)" >&2
    echo "  c) Custom" >&2
    local _sonnet_def="${d_sonnet:-$opus_model}"
    printf "Choice [%s]: " "$_sonnet_def" >&2
    local sonnet_choice
    read -r sonnet_choice
    sonnet_model="$(_zai_resolve "$sonnet_choice" "$_sonnet_def" "$opus_model")" || exit 1

    # --- Tier: Haiku ---
    echo "" >&2
    echo "Model for HAIKU tier (subagents, background, fast/cheap):" >&2
    _zai_print_models "$d_haiku"
    echo "  s) Same as Sonnet ($sonnet_model)" >&2
    echo "  c) Custom" >&2
    local _haiku_def="${d_haiku:-$haiku_default}"
    printf "Choice [%s]: " "$_haiku_def" >&2
    local haiku_choice
    read -r haiku_choice
    haiku_model="$(_zai_resolve "$haiku_choice" "$_haiku_def" "$sonnet_model")" || exit 1

    # --- 6. Context + timeout ---
    echo "" >&2
    ctx="$(ask 'Context length (tokens)' "$d_ctx")"
    timeout_ms="$(ask 'API_TIMEOUT_MS' "$d_timeout_ms")"

    [[ "$ctx" =~ ^[0-9]+$ ]] || { echo "Context length must be a positive integer (got: $ctx)" >&2; exit 1; }
    [[ "$timeout_ms" =~ ^[0-9]+$ ]] || { echo "API_TIMEOUT_MS must be a positive integer (got: $timeout_ms)" >&2; exit 1; }

    # --- 7. Save profile ---
    jq -n \
      --arg url "$base_url" \
      --arg opus "$opus_model" \
      --arg sonnet "$sonnet_model" \
      --arg haiku "$haiku_model" \
      --argjson c "$ctx" \
      --argjson t "$timeout_ms" \
      '{base_url: $url, opus_model: $opus, sonnet_model: $sonnet, haiku_model: $haiku, context_length: $c, api_timeout_ms: $t}' \
      > "$profile"
    echo "" >&2
    echo "Profile saved." >&2
  fi

  # --- 8. Launch ---
  # Startup tier = Sonnet (Claude Code's default). User can /model opus or /model haiku in-session.
  save_last_session "zai" "$(basename "$profile")" "$base_url" "$sonnet_model"

  export CCLM_AUTH_TOKEN="$ZAI_API_KEY"
  export CCLM_TIER_OPUS="$opus_model"
  export CCLM_TIER_SONNET="$sonnet_model"
  export CCLM_TIER_HAIKU="$haiku_model"
  export CCLM_API_TIMEOUT_MS="$timeout_ms"

  print_tier_routing "$opus_model" "$sonnet_model" "$haiku_model"

  launch_claude exec "$sonnet_model" "$base_url" "" "$ctx" "${passthrough_args[@]}"
}

# ============================================================================
# Remote OpenAI-compatible Backend
# For a server someone else manages (LM Studio / llama.cpp / vLLM / etc.).
# We do NOT load, unload, or probe /health — the user asserts it's already up
# and loaded. Single /v1/models probe is best-effort for the model picker only.
# ============================================================================

run_remote() {
  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    local _pl_host _pl_port _pl_model _pl_ctx
    _pl_host=$(jq -r '.host // ""' "$_PRELOADED_PROFILE")
    _pl_port=$(jq -r '.port // "1234"' "$_PRELOADED_PROFILE")
    _pl_model=$(jq -r '.model // ""' "$_PRELOADED_PROFILE")
    _pl_ctx=$(jq -r '.context_length // "65536"' "$_PRELOADED_PROFILE")

    if [[ "${_PRELOADED_ACTION:-open}" == "open" ]]; then
      echo "" >&2
      echo "  [remote] $_pl_model @ ${_pl_host}:${_pl_port}" >&2
      save_last_session "remote" "$(basename "$_PRELOADED_PROFILE")" "$_pl_host" "$_pl_model"
      launch_claude exec "$_pl_model" "$_pl_host" "$_pl_port" "$_pl_ctx" "${passthrough_args[@]}"
      return
    fi
    # Edit: fall through with defaults pre-filled
  fi

  # --- New session: collect host[:port] ---
  local hp_default="${_pl_host:-}${_pl_port:+:$_pl_port}"
  local hp
  if [[ -n "${remote_host:-}" ]]; then
    hp="${remote_host}:${_pl_port:-1234}"
  else
    hp=$(ask "Remote endpoint (host or host:port, default port 1234)" "$hp_default")
  fi
  if [[ -z "$hp" ]]; then
    echo "Host is required." >&2
    exit 1
  fi

  local r_host r_port
  if [[ "$hp" == *:* ]]; then
    r_host="${hp%:*}"
    r_port="${hp##*:}"
  else
    r_host="$hp"
    r_port="1234"
  fi
  local r_url="http://${r_host}:${r_port}"

  # --- Best-effort model picker via /v1/models (single try, short timeout) ---
  local r_model="${_pl_model:-}"
  local api_models
  api_models=$(curl -sf --max-time 2 "${r_url}/v1/models" 2>/dev/null | jq -r '.data[].id // empty' 2>/dev/null | grep -v 'embedding' || true)

  if [[ -n "$api_models" ]]; then
    echo "" >&2
    echo "Models on ${r_host}:${r_port}:" >&2
    echo "" >&2
    local -a model_list=()
    local count=0 mid
    while IFS= read -r mid; do
      [[ -z "$mid" ]] && continue
      count=$((count + 1))
      model_list+=("$mid")
      printf "  %d) %s\n" "$count" "$mid" >&2
    done <<< "$api_models"
    echo "  m) Enter model id manually" >&2
    echo "" >&2
    printf "Select (1-%d or m): " "$count" >&2
    read -r selection
    if [[ "$selection" == "m" || "$selection" == "M" ]]; then
      r_model=$(ask "Model id" "$r_model")
    elif [[ "$selection" =~ ^[0-9]+$ ]] && (( selection >= 1 && selection <= count )); then
      r_model="${model_list[$selection]}"
    else
      echo "Invalid selection." >&2
      exit 1
    fi
  else
    echo "" >&2
    echo "  (/v1/models unreachable or empty — enter model id manually)" >&2
    r_model=$(ask "Model id" "$r_model")
  fi

  if [[ -z "$r_model" ]]; then
    echo "Model id is required." >&2
    exit 1
  fi

  # --- Context window ---
  local r_ctx
  r_ctx=$(ask "Context window (tokens)" "${_pl_ctx:-65536}")

  # --- Save profile (with validation) ---
  local r_profile="$CONFIG_DIR/remote-$(slug "${r_host}-${r_model}").json"
  if [[ "${DRY_RUN:-false}" != "true" && "${CCLM_SKIP_VALIDATE:-0}" != "1" ]]; then
    if ! _cclm_validate_endpoint "$r_url" "$r_model" "remote"; then
      if ! _cclm_confirm_unreachable_save; then
        echo "Profile not saved. You can re-run cclm to try again." >&2
        return 1
      fi
    fi
  fi
  jq -n \
    --arg host "$r_host" \
    --arg port "$r_port" \
    --arg model "$r_model" \
    --arg ctx "$r_ctx" \
    '{host: $host, port: $port, model: $model, context_length: $ctx}' > "$r_profile"
  echo "" >&2
  echo "Profile saved: $r_profile" >&2

  save_last_session "remote" "$(basename "$r_profile")" "$r_host" "$r_model"
  launch_claude exec "$r_model" "$r_host" "$r_port" "$r_ctx" "${passthrough_args[@]}"
}

# ============================================================================
# Main dispatch — backend is set by profile picker or backend picker above
# ============================================================================

case "$backend" in
  lms)    run_lms ;;
  llama)  run_llama ;;
  zai)    run_zai ;;
  remote) run_remote ;;
  ollama) run_ollama ;;
  vllm)   run_vllm ;;
esac
