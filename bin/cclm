#!/usr/bin/env zsh
# cclm - Claude Code via Local Models
# Supports LM Studio and llama.cpp (llama-server) backends.
# Selects a local model, configures load/server parameters, and launches Claude Code.
# Saves per-model profiles to ~/.config/cclm/ for reuse.

set -euo pipefail

CONFIG_DIR="$HOME/.config/cclm"
MODELS_DIR="${CCLM_MODELS_DIR:-$HOME/.cache/lm-studio/models}"
STATE_FILE="$CONFIG_DIR/.last_session"
mkdir -p "$CONFIG_DIR"

# Portable file size: macOS `stat -f%z`, Linux `stat -c%s`
if [[ "$(uname)" == "Darwin" ]]; then
  _stat_size() { stat -f%z "$1"; }
else
  _stat_size() { stat -c%s "$1"; }
fi

# ============================================================================
# Helpers
# ============================================================================

# Slugify a string into a safe filename
slug() { echo "$1" | tr '/' '_' | tr ' ' '-' | tr -cd 'A-Za-z0-9._-'; }

# Prompt with a default value. Prompt goes to stderr, value to stdout.
ask() {
  local label="$1" default="$2" reply
  if [[ -n "$default" ]]; then
    printf "  %-24s [%s]: " "$label" "$default" >&2
  else
    printf "  %-24s: " "$label" >&2
  fi
  read -r reply
  echo "${reply:-$default}"
}

# Human-readable file size
human_size() {
  local bytes=$1
  if (( bytes >= 1073741824 )); then
    printf "%.1f GB" "$(( bytes / 1073741824.0 ))"
  elif (( bytes >= 1048576 )); then
    printf "%.1f MB" "$(( bytes / 1048576.0 ))"
  else
    printf "%.1f KB" "$(( bytes / 1024.0 ))"
  fi
}

# Last session state (populated by load_last_session)
last_backend="" last_profile="" last_remote="" last_model=""

# Load last session state from STATE_FILE
load_last_session() {
  if [[ -f "$STATE_FILE" ]]; then
    last_backend=$(jq -r '.backend // empty' "$STATE_FILE")
    last_profile=$(jq -r '.profile // empty' "$STATE_FILE")
    last_remote=$(jq -r '.remote_host // empty' "$STATE_FILE")
    last_model=$(jq -r '.model // empty' "$STATE_FILE")
    return 0
  fi
  return 1
}

# Save last session state to STATE_FILE
save_last_session() {
  local backend="$1" profile="$2" remote_host="$3" model="$4"
  jq -n \
    --arg be "$backend" \
    --arg prof "$profile" \
    --arg rh "${remote_host:-}" \
    --arg mod "$model" \
    '{backend: $be, profile: $prof, remote_host: $rh, model: $mod}' > "$STATE_FILE"
}

# Set env vars and launch claude. Args: mode, api_id, host, port, context_length, extra_claude_args...
# mode is "exec" (replaces process) or "fg" (foreground, returns when done)
launch_claude() {
  local mode="$1" api_id="$2" host="$3" port="$4" ctx="$5"
  shift 5

  # Base URL: accept a full http(s):// URL in $host (remote providers like Z.ai),
  # otherwise build http://host:port (local backends).
  if [[ "$host" =~ ^https?:// ]]; then
    export ANTHROPIC_BASE_URL="$host"
  else
    export ANTHROPIC_BASE_URL="http://${host}:${port}"
  fi

  # Auth: real token (remote providers) vs placeholder (local).
  # CCLM_AUTH_TOKEN is set by backends that talk to real cloud endpoints.
  if [[ -n "${CCLM_AUTH_TOKEN:-}" ]]; then
    export ANTHROPIC_AUTH_TOKEN="$CCLM_AUTH_TOKEN"
    unset ANTHROPIC_API_KEY
  else
    export ANTHROPIC_API_KEY="lmstudio"
    unset ANTHROPIC_AUTH_TOKEN
  fi
  # Always clear subscription tokens so they can't leak through.
  unset CLAUDE_CODE_OAUTH_TOKEN
  unset CLAUDE_CODE_OAUTH_REFRESH_TOKEN

  export ANTHROPIC_MODEL="$api_id"
  # Per-tier routing: backends that support distinct models per Claude tier
  # (Z.ai) set CCLM_TIER_OPUS / CCLM_TIER_SONNET / CCLM_TIER_HAIKU. Local backends
  # leave them unset, so all three tiers collapse to $api_id (single loaded model).
  export ANTHROPIC_DEFAULT_OPUS_MODEL="${CCLM_TIER_OPUS:-$api_id}"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="${CCLM_TIER_SONNET:-$api_id}"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="${CCLM_TIER_HAIKU:-$api_id}"
  export CLAUDE_CODE_SUBAGENT_MODEL="${CCLM_TIER_HAIKU:-$api_id}"

  export CLAUDE_CODE_MAX_CONTEXT_TOKENS="$ctx"
  export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$ctx"

  # Remote providers can be slower than Claude on long traces; Z.ai recommends 3000000.
  if [[ -n "${CCLM_API_TIMEOUT_MS:-}" ]]; then
    export API_TIMEOUT_MS="$CCLM_API_TIMEOUT_MS"
  fi

  export CLAUDE_CODE_ATTRIBUTION_HEADER="0"
  export DISABLE_TELEMETRY="1"
  export DISABLE_ERROR_REPORTING="1"
  export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"
  export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING="1"

  echo "" >&2
  echo "Model:   $api_id" >&2
  echo "Backend: $ANTHROPIC_BASE_URL" >&2
  echo "Context: ${ctx} tokens  (CLAUDE_CODE_AUTO_COMPACT_WINDOW=${ctx})" >&2
  echo "" >&2

  if [[ "$mode" == "exec" ]]; then
    exec claude --model "$api_id" "$@"
  else
    claude --model "$api_id" "$@"
  fi
}

# ============================================================================
# Profile Migration
# ============================================================================

for f in "$CONFIG_DIR"/*.json(N); do
  _base="${f:t}"
  if [[ "$_base" != lms-* && "$_base" != llama-* && "$_base" != zai-* ]]; then
    mv "$f" "$CONFIG_DIR/lms-${_base}"
  fi
done

# Add remote_host field to profiles that lack it (backward compat)
for f in "$CONFIG_DIR"/{llama,lms}-*.json(N); do
  jq -e 'has("remote_host")' "$f" >/dev/null 2>&1 && continue
  _tmp=$(mktemp) && jq '. + {remote_host: null}' "$f" > "$_tmp" && mv "$_tmp" "$f"
done

# ============================================================================
# Argument Parsing
# ============================================================================

backend=""
remote_host=""
passthrough_args=()

while (( $# )); do
  case "$1" in
    --lms)   backend="lms" ;;
    --llama) backend="llama" ;;
    --zai)   backend="zai" ;;
    --host)  remote_host="$2"; shift ;;
    --host=*) remote_host="${1#--host=}" ;;
    *)       passthrough_args+=("$1") ;;
  esac
  shift
done

# Try to load last session (return 1 is normal on first run — no state file yet).
load_last_session || true

# ============================================================================
# Profile Picker
# ============================================================================

pick_profile() {
  # Scans all saved profiles and presents a unified picker.
  # Returns 0 with globals set, or 1 to fall through to backend picker.
  # Globals: _PRELOADED_PROFILE, _PRELOADED_ACTION, backend

  local -a profiles
  profiles=( "$CONFIG_DIR"/{llama,lms,zai}-*.json(N) )

  # No saved profiles — skip picker entirely
  (( ${#profiles[@]} == 0 )) && return 1

  while true; do
    echo "" >&2
    echo "Saved profiles:" >&2
    echo "" >&2

    local i=1 be_tag model_name host_info ctx_info
    for f in "${profiles[@]}"; do
      local base="${f:t}"
      case "$base" in
        llama-*) be_tag="llama" ;;
        lms-*)   be_tag="lms" ;;
        zai-*)   be_tag="zai" ;;
      esac

      case "$be_tag" in
        llama)
          model_name=$(jq -r '.model // "${base}"' "$f")
          local rh=$(jq -r '.remote_host // empty' "$f")
          host_info="${rh:+remote:$rh}"
          [[ -z "$host_info" ]] && host_info="local"
          ctx_info=$(jq -r '.ctx_len // "?"' "$f")
          ;;
        lms)
          model_name=$(jq -r '.model // "${base}"' "$f")
          local rh=$(jq -r '.remote_host // empty' "$f")
          host_info="${rh:+remote:$rh}"
          [[ -z "$host_info" ]] && host_info="local"
          ctx_info=$(jq -r '.context_length // "?"' "$f")
          ;;
        zai)
          local pname="${base#zai-}"; pname="${pname%.json}"
          model_name=$(jq -r '.sonnet_model // "?"' "$f")
          host_info=$(jq -r '.base_url // "z.ai"' "$f" | sed 's|https\?://||; s|/.*||')
          ctx_info=$(jq -r '.context_length // "?"' "$f")
          ;;
      esac

      printf "  %2d) [%-5s] %-28s %-21s ctx:%s\n" "$i" "$be_tag" \
        "${model_name:0:28}" "$host_info" "$ctx_info" >&2
      (( i++ ))
    done

    echo "" >&2
    echo "  n) New session (full config)" >&2
    echo "  q) Quit" >&2
    echo "" >&2
    printf "Choice: " >&2
    read -r choice

    [[ "$choice" == "q" ]] && exit 0
    [[ "$choice" == "n" ]] && return 1

    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#profiles[@]} )); then
      echo "Invalid selection." >&2
      continue
    fi

    local picked="${profiles[$choice]}"
    local picked_base="${picked:t}"
    local picked_backend="${picked_base%%-*}"

    # Action sub-menu
    local display_model
    case "$picked_backend" in
      llama) display_model=$(jq -r '.model // "$picked_base"' "$picked") ;;
      lms)   display_model=$(jq -r '.model // "$picked_base"' "$picked") ;;
      zai)   display_model=$(jq -r '.sonnet_model // "$picked_base"' "$picked") ;;
    esac

    echo "" >&2
    echo "  [$picked_backend] $display_model" >&2
    echo "    o) Open/launch" >&2
    echo "    e) Edit parameters" >&2
    echo "    d) Delete" >&2
    echo "    b) Back to list" >&2
    echo "" >&2
    printf "  Action [o]: " >&2
    read -r action
    action="${action:-o}"

    case "$action" in
      o|O)
        _PRELOADED_PROFILE="$picked"
        _PRELOADED_ACTION="open"
        backend="$picked_backend"
        return 0
        ;;
      e|E)
        _PRELOADED_PROFILE="$picked"
        _PRELOADED_ACTION="edit"
        backend="$picked_backend"
        return 0
        ;;
      d|D)
        printf "  Delete %s? (y/N): " "$picked_base" >&2
        read -r del_confirm
        if [[ "$del_confirm" =~ ^[Yy]$ ]]; then
          rm "$picked"
          echo "  Deleted." >&2
          # Refresh list
          profiles=( "$CONFIG_DIR"/{llama,lms,zai}-*.json(N) )
          (( ${#profiles[@]} == 0 )) && return 1
        fi
        # Reset counter and re-display
        i=1
        continue
        ;;
      b|B) i=1; continue ;;
      *) echo "  Invalid action." >&2; i=1; continue ;;
    esac
  done
}

# --- Profile picker (runs first when no backend flag) ---
_PRELOADED_PROFILE="" _PRELOADED_ACTION=""
if [[ -z "$backend" ]] && pick_profile; then
  # backend was set by pick_profile — dispatch directly
  :
elif [[ -n "$_PRELOADED_PROFILE" ]]; then
  # Backend was pre-selected via --lms/--llama/--zai, profile picked
  :
elif [[ -z "$backend" ]]; then
  # No profile picked — show existing backend picker
  echo "" >&2
  echo "Select backend:" >&2

  # Show resume option if available
  if [[ -n "$last_backend" && -n "$last_profile" ]]; then
    echo "  0) Resume last session ($last_backend @ ${last_remote:-local}, $last_model)" >&2
  fi

  echo "  1) LM Studio" >&2
  echo "  2) llama.cpp" >&2
  echo "  3) Z.ai GLM (remote)" >&2
  echo "" >&2

  if [[ -n "$last_backend" ]]; then
    printf "Choice (0-3): " >&2
  else
    printf "Choice (1-3): " >&2
  fi
  read -r bchoice

  case "$bchoice" in
    0)
      backend="$last_backend"
      remote_host="$last_remote"
      ;;
    1) backend="lms" ;;
    2) backend="llama" ;;
    3) backend="zai" ;;
    *) echo "Invalid selection." >&2; exit 1 ;;
  esac
fi

# Remote-host prompt applies to local-backend flows only; Z.ai picks its base URL inside run_zai.
if [[ -z "$remote_host" && "$backend" != "zai" && -z "$_PRELOADED_PROFILE" ]]; then
  printf "  Remote host               [local]: " >&2
  read -r _rhost
  remote_host="${_rhost:-}"
fi

# ============================================================================
# LM Studio Backend
# ============================================================================

run_lms() {
  local LMS_HOST="${remote_host:-localhost}"
  local LMS_PORT=1234
  local LMS_URL="http://${LMS_HOST}:${LMS_PORT}"

  local is_lms_remote=false
  [[ "$LMS_HOST" != "localhost" && "$LMS_HOST" != "127.0.0.1" ]] && is_lms_remote=true

  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    local _pl_model _pl_ctx _pl_gpu _pl_parallel _pl_ttl _pl_id _pl_rh
    _pl_model=$(jq -r '.model' "$_PRELOADED_PROFILE")
    _pl_ctx=$(jq -r '.context_length // "65536"' "$_PRELOADED_PROFILE")
    _pl_gpu=$(jq -r '.gpu // "max"' "$_PRELOADED_PROFILE")
    _pl_parallel=$(jq -r '.parallel // "1"' "$_PRELOADED_PROFILE")
    _pl_ttl=$(jq -r '.ttl // ""' "$_PRELOADED_PROFILE")
    _pl_id=$(jq -r '.identifier // ""' "$_PRELOADED_PROFILE")
    _pl_rh=$(jq -r '.remote_host // ""' "$_PRELOADED_PROFILE")
    LMS_HOST="${_pl_rh:-localhost}"
    [[ "$LMS_HOST" == "null" ]] && LMS_HOST="localhost"
    LMS_URL="http://${LMS_HOST}:${LMS_PORT}"
    [[ "$LMS_HOST" != "localhost" && "$LMS_HOST" != "127.0.0.1" ]] && is_lms_remote=true

    if [[ "${_PRELOADED_ACTION:-open}" == "open" ]]; then
      # Fast launch: skip all model selection, load and connect directly
      echo "" >&2
      echo "  [$LMS_HOST] $_pl_model" >&2
      if $is_lms_remote; then
        # Remote: check server, poll if needed, connect
        local server_up=false
        curl -sf --max-time 3 "${LMS_URL}/v1/models" > /dev/null 2>&1 && server_up=true
        if ! $server_up; then
          echo "" >&2
          echo "  ────────────────────────────────────────────────────────────────" >&2
          echo "  Run this on $LMS_HOST:" >&2
          echo "" >&2
          printf "  lms server start --port %s && \\\\\n" "$LMS_PORT" >&2
          printf "  lms load \"%s\" -c %s --gpu %s --parallel %s -y\n" \
            "$_pl_model" "$_pl_ctx" "$_pl_gpu" "$_pl_parallel" >&2
          echo "" >&2
          echo "  ────────────────────────────────────────────────────────────────" >&2
          echo "" >&2
          printf "  Waiting for %s:%s (Ctrl+C to cancel)..." "$LMS_HOST" "$LMS_PORT" >&2
          local waited=0 timeout=300
          while (( waited < timeout )); do
            if curl -sf --max-time 2 "${LMS_URL}/v1/models" 2>/dev/null | jq -e '.data | length > 0' > /dev/null 2>&1; then
              echo " ready." >&2
              break
            fi
            printf "." >&2
            sleep 5
            waited=$((waited + 5))
          done
          if (( waited >= timeout )); then
            echo "" >&2
            echo "Timed out (${timeout}s)." >&2
            exit 1
          fi
        fi
        save_last_session "lms" "$(basename "$_PRELOADED_PROFILE")" "$LMS_HOST" "$_pl_model"
        launch_claude exec "$_pl_model" "$LMS_HOST" "$LMS_PORT" "$_pl_ctx" "${passthrough_args[@]}"
      else
        # Local: check LMS, load model, launch
        if ! curl -s "${LMS_URL}/v1/models" > /dev/null 2>&1; then
          echo "LM Studio is not reachable at ${LMS_URL}" >&2
          echo "Start it with: lms server start --port ${LMS_PORT}" >&2
          exit 1
        fi
        local loaded_id
        loaded_id=$(lms ps --json 2>/dev/null | jq -r '.[0].modelKey // empty')
        if [[ -n "$loaded_id" && "$loaded_id" != "$_pl_model" ]]; then
          echo "Unloading: $loaded_id" >&2
          lms unload "$loaded_id" 2>/dev/null || true
        fi
        local -a load_args=("-c" "$_pl_ctx" "--gpu" "$_pl_gpu" "--parallel" "$_pl_parallel" "-y")
        [[ -n "$_pl_ttl" ]] && load_args+=("--ttl" "${_pl_ttl}s")
        [[ -n "$_pl_id" ]] && load_args+=("--identifier" "$_pl_id")
        load_args+=("$_pl_model")
        echo "Loading: $_pl_model" >&2
        echo "  ctx:$_pl_ctx  gpu:$_pl_gpu  parallel:$_pl_parallel" >&2
        lms load "${load_args[@]}"
        local api_id
        api_id=$(lms ps --json 2>/dev/null | jq -r '.[0] | if .identifier == null or .identifier == "null" then .modelKey else .identifier end')
        save_last_session "lms" "$(basename "$_PRELOADED_PROFILE")" "$LMS_HOST" "$api_id"
        launch_claude exec "$api_id" "$LMS_HOST" "$LMS_PORT" "$_pl_ctx" "${passthrough_args[@]}"
      fi
      return
    else
      # Edit: fall through to existing flow with profile context
      # Set lms_model_key for remote path or chosen for local path
      # The existing code will show config prompts with current values as defaults
      if $is_lms_remote; then
        # For remote, let the normal flow run — user will re-enter model key
        # but the profile will be there for "Use saved?" prompt
        :
      else
        # For local, pre-set chosen so model listing is skipped
        # (declared below in local flow — will be checked with -z)
        :
      fi
    fi
  fi

  # --- Remote LM Studio ---
  if $is_lms_remote; then
    local server_up=false
    curl -sf --max-time 3 "${LMS_URL}/v1/models" > /dev/null 2>&1 && server_up=true

    if ! $server_up; then
      # Server not running: walk through config, generate one-liner, poll
      echo "" >&2
      echo "LM Studio at ${LMS_URL} is not reachable." >&2
      echo "" >&2

      local lms_model_key lms_ctx lms_gpu lms_parallel lms_profile
      lms_model_key=$(ask "Model key on $LMS_HOST (e.g., qwen/qwen3.5-27b)" "")
      if [[ -z "$lms_model_key" ]]; then
        echo "Model key is required." >&2
        exit 1
      fi
      lms_profile="$CONFIG_DIR/lms-$(slug "$lms_model_key").json"

      local use_lms_saved=false
      if [[ -f "$lms_profile" ]]; then
        echo "" >&2
        echo "Saved profile for $lms_model_key:" >&2
        printf "  %-20s %s\n" "Context length:" "$(jq -r '.context_length' "$lms_profile")" >&2
        printf "  %-20s %s\n" "GPU offload:" "$(jq -r '.gpu' "$lms_profile")" >&2
        printf "  %-20s %s\n" "Parallel:" "$(jq -r '.parallel' "$lms_profile")" >&2
        echo "" >&2
        printf "Use saved profile? (Y/n): " >&2
        read -r use_reply
        [[ -z "$use_reply" || "$use_reply" =~ ^[Yy]$ ]] && use_lms_saved=true
      fi

      local d_lctx="65536" d_lgpu="max" d_lpar="1"
      if [[ -f "$lms_profile" ]]; then
        d_lctx=$(jq -r '.context_length // "65536"' "$lms_profile")
        d_lgpu=$(jq -r '.gpu // "max"' "$lms_profile")
        d_lpar=$(jq -r '.parallel // "1"' "$lms_profile")
      fi

      if $use_lms_saved; then
        lms_ctx="$d_lctx"; lms_gpu="$d_lgpu"; lms_parallel="$d_lpar"
      else
        echo "" >&2
        echo "Configure parameters (press Enter for default):" >&2
        echo "" >&2
        lms_ctx=$(ask "Context length" "$d_lctx")
        lms_gpu=$(ask "GPU offload" "$d_lgpu")
        lms_parallel=$(ask "Parallel requests" "$d_lpar")
        jq -n \
          --arg model "$lms_model_key" \
          --arg ctx "$lms_ctx" \
          --arg gpu "$lms_gpu" \
          --arg par "$lms_parallel" \
          --arg rh "$LMS_HOST" \
          '{model: $model, context_length: $ctx, gpu: $gpu, parallel: $par, remote_host: (if $rh == "" then null else $rh end)}' > "$lms_profile"
        echo "" >&2
        echo "Profile saved." >&2
      fi

      echo "" >&2
      echo "  ────────────────────────────────────────────────────────────────" >&2
      echo "  Run this on $LMS_HOST:" >&2
      echo "" >&2
      printf "  lms server start --port %s && \\\\\n" "$LMS_PORT" >&2
      printf "  lms load \"%s\" -c %s --gpu %s --parallel %s -y\n" \
        "$lms_model_key" "$lms_ctx" "$lms_gpu" "$lms_parallel" >&2
      echo "" >&2
      echo "  ────────────────────────────────────────────────────────────────" >&2
      echo "" >&2

      printf "  Waiting for %s:%s (Ctrl+C to cancel)..." "$LMS_HOST" "$LMS_PORT" >&2
      local waited=0 timeout=300
      while (( waited < timeout )); do
        if curl -sf --max-time 2 "${LMS_URL}/v1/models" 2>/dev/null | jq -e '.data | length > 0' > /dev/null 2>&1; then
          echo " ready." >&2
          break
        fi
        printf "." >&2
        sleep 5
        waited=$((waited + 5))
      done
      if (( waited >= timeout )); then
        echo "" >&2
        echo "Timed out (${timeout}s)." >&2
        exit 1
      fi

      save_last_session "lms" "lms-$(slug "$lms_model_key").json" "$LMS_HOST" "$lms_model_key"
      launch_claude exec "$lms_model_key" "$LMS_HOST" "$LMS_PORT" "$lms_ctx" "${passthrough_args[@]}"
      return
    fi

    # Server IS running: query and select model
    local api_models
    api_models=$(curl -s "${LMS_URL}/v1/models" 2>/dev/null | jq -r '.data[].id' | grep -v 'embedding')

    if [[ -z "$api_models" ]]; then
      echo "No models available on remote LM Studio at ${LMS_URL}" >&2
      exit 1
    fi

    echo "" >&2
    echo "Models on remote LM Studio (${LMS_HOST}):" >&2
    echo "" >&2
    local count=0
    local model_list=()
    while IFS= read -r mid; do
      count=$((count + 1))
      model_list+=("$mid")
      printf "  %d) %s\n" "$count" "$mid" >&2
    done <<< "$api_models"
    echo "" >&2

    printf "Select model (1-%d): " "$count" >&2
    read -r selection

    if ! [[ "$selection" =~ ^[0-9]+$ ]] || (( selection < 1 || selection > count )); then
      echo "Invalid selection." >&2
      exit 1
    fi

    local api_id="${model_list[$selection]}"
    echo "" >&2
    local ctx_size
    ctx_size=$(ask "Context window (tokens)" "65536")

    save_last_session "lms" "lms-$(slug "$api_id").json" "$LMS_HOST" "$api_id"
    launch_claude exec "$api_id" "$LMS_HOST" "$LMS_PORT" "$ctx_size" "${passthrough_args[@]}"
    return
  fi

  # --- Local LM Studio: preflight check ---
  if ! curl -s "${LMS_URL}/v1/models" > /dev/null 2>&1; then
    echo "LM Studio is not reachable at ${LMS_URL}" >&2
    echo "Start it with: lms server start --port ${LMS_PORT}" >&2
    exit 1
  fi

  local models_json
  models_json=$(lms ls --llm --json 2>/dev/null)

  if [[ -z "$models_json" ]] || [[ "$(echo "$models_json" | jq 'length')" -eq 0 ]]; then
    echo "No LLM models found in LM Studio." >&2
    exit 1
  fi

  local loaded_id
  loaded_id=$(lms ps --json 2>/dev/null | jq -r '.[0].modelKey // empty')

  echo "" >&2
  echo "Available LM Studio models:" >&2
  echo "" >&2
  local count
  count=$(echo "$models_json" | jq 'length')
  local key display params max_ctx tool_use loaded_marker tool_tag saved_tag
  for ((i=0; i<count; i++)); do
    loaded_marker="" tool_tag="" saved_tag=""
    key=$(echo "$models_json" | jq -r ".[$i].modelKey")
    display=$(echo "$models_json" | jq -r ".[$i].displayName")
    params=$(echo "$models_json" | jq -r ".[$i].paramsString")
    max_ctx=$(echo "$models_json" | jq -r ".[$i].maxContextLength")
    tool_use=$(echo "$models_json" | jq -r ".[$i].trainedForToolUse")
    [[ "$key" = "$loaded_id" ]] && loaded_marker=" [LOADED]"
    [[ "$tool_use" = "true" ]] && tool_tag=" tools"
    [[ -f "$CONFIG_DIR/lms-$(slug "$key").json" ]] && saved_tag=" *"
    printf "  %d) %-30s %6s  ctx:%dk%s%s%s\n" \
      $((i+1)) "$display" "$params" $((max_ctx/1024)) "$tool_tag" "$loaded_marker" "$saved_tag" >&2
  done
  echo "" >&2
  echo "  (* = saved profile)" >&2
  echo "" >&2

  printf "Select model (1-%d): " "$count" >&2
  read -r selection

  if ! [[ "$selection" =~ ^[0-9]+$ ]] || (( selection < 1 || selection > count )); then
    echo "Invalid selection." >&2
    exit 1
  fi

  local chosen chosen_max_ctx profile
  chosen=$(echo "$models_json" | jq -r ".[$((selection-1))].modelKey")
  chosen_max_ctx=$(echo "$models_json" | jq -r ".[$((selection-1))].maxContextLength")
  profile="$CONFIG_DIR/lms-$(slug "$chosen").json"

  # Load or edit profile
  local use_saved=false
  if [[ -f "$profile" ]]; then
    echo "" >&2
    echo "Saved profile for $chosen:" >&2
    echo "" >&2
    printf "  %-20s %s\n" "Context length:" "$(jq -r '.context_length' "$profile")" >&2
    printf "  %-20s %s\n" "GPU offload:" "$(jq -r '.gpu' "$profile")" >&2
    printf "  %-20s %s\n" "Parallel requests:" "$(jq -r '.parallel' "$profile")" >&2
    printf "  %-20s %s\n" "TTL (seconds):" "$(jq -r '.ttl' "$profile")" >&2
    printf "  %-20s %s\n" "API identifier:" "$(jq -r '.identifier' "$profile")" >&2
    echo "" >&2
    printf "Use saved profile? (Y/n): " >&2
    read -r use_reply
    if [[ -z "$use_reply" || "$use_reply" =~ ^[Yy]$ ]]; then
      use_saved=true
    fi
  fi

  local ctx_size gpu parallel ttl identifier
  if $use_saved; then
    ctx_size=$(jq -r '.context_length' "$profile")
    gpu=$(jq -r '.gpu' "$profile")
    parallel=$(jq -r '.parallel' "$profile")
    ttl=$(jq -r '.ttl // ""' "$profile")
    identifier=$(jq -r '.identifier // ""' "$profile")
  else
    local def_ctx def_gpu="max" def_parallel="1" def_ttl="" def_id=""
    def_ctx=$((chosen_max_ctx < 32768 ? chosen_max_ctx : 32768))

    if [[ -f "$profile" ]]; then
      def_ctx=$(jq -r '.context_length' "$profile")
      def_gpu=$(jq -r '.gpu' "$profile")
      def_parallel=$(jq -r '.parallel' "$profile")
      def_ttl=$(jq -r '.ttl // ""' "$profile")
      def_id=$(jq -r '.identifier // ""' "$profile")
    fi

    echo "" >&2
    echo "Configure load parameters (press Enter for default):" >&2
    echo "" >&2
    ctx_size=$(ask "Context length" "$def_ctx")
    gpu=$(ask "GPU offload" "$def_gpu")
    parallel=$(ask "Parallel requests" "$def_parallel")
    ttl=$(ask "TTL (seconds)" "$def_ttl")
    identifier=$(ask "API identifier" "$def_id")

    jq -n \
      --arg ctx "$ctx_size" \
      --arg gpu "$gpu" \
      --arg par "$parallel" \
      --arg ttl "$ttl" \
      --arg id "$identifier" \
      --arg model "$chosen" \
      '{
        model: $model,
        context_length: $ctx,
        gpu: $gpu,
        parallel: $par,
        ttl: (if $ttl == "" then null else $ttl end),
        identifier: (if $id == "" then null else $id end),
        remote_host: null
      }' > "$profile"

    echo "" >&2
    echo "Profile saved to $profile" >&2
  fi

  # Build lms load command
  local load_args=("$chosen" "-c" "$ctx_size" "--gpu" "$gpu" "--parallel" "$parallel" "-y")
  [[ -n "$ttl" ]] && load_args+=("--ttl" "$ttl")
  [[ -n "$identifier" ]] && load_args+=("--identifier" "$identifier")

  # Load model
  if [[ "$chosen" = "$loaded_id" ]]; then
    echo "" >&2
    echo "Model already loaded: $chosen" >&2
  else
    echo "" >&2
    if [[ -n "$loaded_id" ]]; then
      echo "Unloading: $loaded_id" >&2
      lms unload "$loaded_id" 2>/dev/null || true
    fi
    echo "Loading: $chosen" >&2
    echo "  ctx:$ctx_size  gpu:$gpu  parallel:$parallel${ttl:+  ttl:${ttl}s}${identifier:+  id:$identifier}" >&2
    lms load "${load_args[@]}"
  fi

  # Resolve API identifier
  local api_id
  api_id=$(lms ps --json 2>/dev/null | jq -r '.[0] | if .identifier == null or .identifier == "null" then .modelKey else .identifier end')

  save_last_session "lms" "lms-$(slug "$api_id").json" "$LMS_HOST" "$api_id"
  launch_claude exec "$api_id" "$LMS_HOST" "$LMS_PORT" "$ctx_size" "${passthrough_args[@]}"
}

# ============================================================================
# llama.cpp Backend
# ============================================================================

run_llama() {
  # Determine remote vs local early — governs the entire flow
  local llama_host="${remote_host:-localhost}"
  local is_remote=false
  [[ "$llama_host" != "localhost" && "$llama_host" != "127.0.0.1" ]] && is_remote=true

  # Shared param variables
  local chosen_path="" model_id="" profile="" chosen_fname="" model_dir="" mmproj_path="" mmproj_match=""
  local ctx_len="" gpu_layers="" flash_attn="" cache_type_k="" cache_type_v="" swa_full="" batch_size="" ubatch_size=""
  local temperature="" top_p="" top_k="" min_p="" repeat_penalty=""
  local port="" parallel_slots="" slot_save_path="" cache_ram=""
  local use_saved=false

  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    model_id=$(jq -r '.model' "$_PRELOADED_PROFILE")
    chosen_path=$(jq -r '.model_path' "$_PRELOADED_PROFILE")
    llama_host=$(jq -r '.remote_host // "localhost"' "$_PRELOADED_PROFILE")
    [[ -z "$llama_host" || "$llama_host" == "null" ]] && llama_host="localhost"
    [[ "$llama_host" != "localhost" && "$llama_host" != "127.0.0.1" ]] && is_remote=true
    profile="$_PRELOADED_PROFILE"
    [[ "${_PRELOADED_ACTION:-open}" == "open" ]] && use_saved=true
  fi

  if $is_remote; then
    # ========================================================================
    # Remote: ask model path, configure, generate one-liner, poll, connect
    # ========================================================================

    # Model selection — skip when preloaded from profile picker
    if [[ -z "$model_id" ]]; then
      echo "" >&2
      echo "Remote llama-server target: $llama_host" >&2
      echo "" >&2
      chosen_path=$(ask "Model path on $llama_host" "")
      if [[ -z "$chosen_path" ]]; then
        echo "Model path is required." >&2
        exit 1
      fi
      local _fname="${chosen_path:t}"
      model_id="${_fname%.gguf}"
      profile="$CONFIG_DIR/llama-$(slug "$model_id").json"
    fi

    if [[ -f "$profile" ]] && ! $use_saved; then
      echo "" >&2
      echo "Saved profile for $model_id:" >&2
      echo "" >&2
      echo "  Loading:" >&2
      printf "    %-20s %s\n" "Model path:" "$(jq -r '.model_path' "$profile")" >&2
      printf "    %-20s %s\n" "Context length:" "$(jq -r '.ctx_len' "$profile")" >&2
      printf "    %-20s %s\n" "GPU layers:" "$(jq -r '.gpu_layers' "$profile")" >&2
      printf "    %-20s %s\n" "Flash attention:" "$(jq -r '.flash_attn' "$profile")" >&2
      printf "    %-20s %s\n" "Cache type K:" "$(jq -r '.cache_type_k' "$profile")" >&2
      printf "    %-20s %s\n" "Cache type V:" "$(jq -r '.cache_type_v' "$profile")" >&2
      printf "    %-20s %s\n" "SWA full:" "$(jq -r '.swa_full' "$profile")" >&2
      printf "    %-20s %s\n" "Batch size:" "$(jq -r '.batch_size' "$profile")" >&2
      printf "    %-20s %s\n" "Ubatch size:" "$(jq -r '.ubatch_size' "$profile")" >&2
      echo "  Sampling:" >&2
      printf "    %-20s %s\n" "Temperature:" "$(jq -r '.temperature' "$profile")" >&2
      printf "    %-20s %s\n" "Top-P:" "$(jq -r '.top_p' "$profile")" >&2
      printf "    %-20s %s\n" "Top-K:" "$(jq -r '.top_k' "$profile")" >&2
      printf "    %-20s %s\n" "Min-P:" "$(jq -r '.min_p' "$profile")" >&2
      printf "    %-20s %s\n" "Repeat penalty:" "$(jq -r '.repeat_penalty' "$profile")" >&2
      echo "  Server:" >&2
      printf "    %-20s %s\n" "Port:" "$(jq -r '.port' "$profile")" >&2
      printf "    %-20s %s\n" "Parallel slots:" "$(jq -r '.parallel_slots' "$profile")" >&2
      printf "    %-20s %s\n" "Slot save path:" "$(jq -r '.slot_save_path // ""' "$profile")" >&2
      echo "" >&2
      printf "Use saved profile? (Y/n): " >&2
      read -r use_reply
      [[ -z "$use_reply" || "$use_reply" =~ ^[Yy]$ ]] && use_saved=true
    fi

    if $use_saved; then
      ctx_len=$(jq -r '.ctx_len' "$profile")
      gpu_layers=$(jq -r '.gpu_layers' "$profile")
      flash_attn=$(jq -r '.flash_attn' "$profile")
      cache_type_k=$(jq -r '.cache_type_k' "$profile")
      cache_type_v=$(jq -r '.cache_type_v' "$profile")
      swa_full=$(jq -r '.swa_full' "$profile")
      batch_size=$(jq -r '.batch_size' "$profile")
      ubatch_size=$(jq -r '.ubatch_size' "$profile")
      temperature=$(jq -r '.temperature' "$profile")
      top_p=$(jq -r '.top_p' "$profile")
      top_k=$(jq -r '.top_k' "$profile")
      min_p=$(jq -r '.min_p' "$profile")
      repeat_penalty=$(jq -r '.repeat_penalty' "$profile")
      port=$(jq -r '.port' "$profile")
      parallel_slots=$(jq -r '.parallel_slots' "$profile")
      slot_save_path=$(jq -r '.slot_save_path // ""' "$profile")
      cache_ram=$(jq -r '.cache_ram // ""' "$profile")
    else
      local d_ctx="65536" d_ngl="99" d_fa="on" d_ctk="q8_0" d_ctv="q8_0"
      local d_swa="true" d_bs="4096" d_ubs="1024"
      local d_temp="0.6" d_topp="0.95" d_topk="20" d_minp="0.00" d_rp="1.0"
      local d_port="8081" d_np="1" d_ssp="" d_cram=""

      if [[ -f "$profile" ]]; then
        d_ctx=$(jq -r '.ctx_len' "$profile")
        d_ngl=$(jq -r '.gpu_layers' "$profile")
        d_fa=$(jq -r '.flash_attn' "$profile")
        d_ctk=$(jq -r '.cache_type_k' "$profile")
        d_ctv=$(jq -r '.cache_type_v' "$profile")
        d_swa=$(jq -r '.swa_full' "$profile")
        d_bs=$(jq -r '.batch_size' "$profile")
        d_ubs=$(jq -r '.ubatch_size' "$profile")
        d_temp=$(jq -r '.temperature' "$profile")
        d_topp=$(jq -r '.top_p' "$profile")
        d_topk=$(jq -r '.top_k' "$profile")
        d_minp=$(jq -r '.min_p' "$profile")
        d_rp=$(jq -r '.repeat_penalty' "$profile")
        d_port=$(jq -r '.port' "$profile")
        d_np=$(jq -r '.parallel_slots' "$profile")
        d_ssp=$(jq -r '.slot_save_path // ""' "$profile")
        d_cram=$(jq -r '.cache_ram // ""' "$profile")
      fi

      echo "" >&2
      echo "Configure llama-server parameters (press Enter for default):" >&2
      echo "" >&2
      echo "  Loading:" >&2
      ctx_len=$(ask "Context length" "$d_ctx")
      gpu_layers=$(ask "GPU layers" "$d_ngl")
      flash_attn=$(ask "Flash attention" "$d_fa")
      cache_type_k=$(ask "KV cache type K" "$d_ctk")
      cache_type_v=$(ask "KV cache type V" "$d_ctv")
      swa_full=$(ask "SWA full" "$d_swa")
      batch_size=$(ask "Batch size" "$d_bs")
      ubatch_size=$(ask "Ubatch size" "$d_ubs")
      echo "" >&2
      echo "  Sampling:" >&2
      temperature=$(ask "Temperature" "$d_temp")
      top_p=$(ask "Top-P" "$d_topp")
      top_k=$(ask "Top-K" "$d_topk")
      min_p=$(ask "Min-P" "$d_minp")
      repeat_penalty=$(ask "Repeat penalty" "$d_rp")
      echo "" >&2
      echo "  Server:" >&2
      port=$(ask "Port" "$d_port")
      parallel_slots=$(ask "Parallel slots" "$d_np")
      slot_save_path=$(ask "Slot save path on remote" "$d_ssp")
      cache_ram=$(ask "Cache RAM (MB)" "$d_cram")

      jq -n \
        --arg ctx "$ctx_len" --arg ngl "$gpu_layers" --arg fa "$flash_attn" \
        --arg ctk "$cache_type_k" --arg ctv "$cache_type_v" --arg swa "$swa_full" \
        --arg bs "$batch_size" --arg ubs "$ubatch_size" \
        --arg temp "$temperature" --arg tp "$top_p" --arg tk "$top_k" \
        --arg mp "$min_p" --arg rp "$repeat_penalty" \
        --arg port "$port" --arg np "$parallel_slots" \
        --arg ssp "$slot_save_path" --arg cram "$cache_ram" \
        --arg model "$model_id" --arg path "$chosen_path" \
        --arg rh "$llama_host" \
        '{
          model: $model, model_path: $path,
          ctx_len: $ctx, gpu_layers: $ngl, flash_attn: $fa,
          cache_type_k: $ctk, cache_type_v: $ctv, swa_full: $swa,
          batch_size: $bs, ubatch_size: $ubs,
          temperature: $temp, top_p: $tp, top_k: $tk, min_p: $mp, repeat_penalty: $rp,
          port: $port, parallel_slots: $np,
          slot_save_path: (if $ssp == "" then null else $ssp end),
          cache_ram: (if $cram == "" then null else $cram end),
          remote_host: (if $rh == "localhost" or $rh == "127.0.0.1" or $rh == "" then null else $rh end)
        }' > "$profile"
      echo "" >&2
      echo "Profile saved." >&2
    fi

    # Print one-liner
    echo "" >&2
    echo "  ────────────────────────────────────────────────────────────────" >&2
    echo "  Run this on $llama_host:" >&2
    echo "" >&2
    printf "  llama-server \\\\\n" >&2
    printf "    -m \"%s\" \\\\\n" "$chosen_path" >&2
    printf "    -c %s -ngl %s \\\\\n" "$ctx_len" "$gpu_layers" >&2
    [[ -n "$flash_attn" ]] && printf "    --flash-attn %s \\\\\n" "$flash_attn" >&2
    printf "    --cache-type-k %s --cache-type-v %s \\\\\n" "$cache_type_k" "$cache_type_v" >&2
    [[ "$swa_full" == "true" ]] && printf "    --swa-full \\\\\n" >&2
    printf "    -b %s -ub %s \\\\\n" "$batch_size" "$ubatch_size" >&2
    printf "    --temp %s --top-p %s --top-k %s --min-p %s --repeat-penalty %s \\\\\n" \
      "$temperature" "$top_p" "$top_k" "$min_p" "$repeat_penalty" >&2
    printf "    --port %s -np %s \\\\\n" "$port" "$parallel_slots" >&2
    [[ -n "$slot_save_path" ]] && printf "    --slot-save-path \"%s\" \\\\\n" "$slot_save_path" >&2
    [[ -n "$cache_ram" ]] && printf "    --cache-ram %s \\\\\n" "$cache_ram" >&2
    printf "    --jinja --metrics --host 0.0.0.0\n" >&2
    echo "" >&2
    echo "  ────────────────────────────────────────────────────────────────" >&2

    # Check if already running, or poll until ready
    local remote_health="http://${llama_host}:${port}/health"
    if curl -sf --max-time 3 "$remote_health" 2>/dev/null | jq -e '.status == "ok"' > /dev/null 2>&1; then
      echo "" >&2
      echo "Remote server is already running. Connecting..." >&2
    else
      echo "" >&2
      printf "  Waiting for %s:%s (Ctrl+C to cancel)..." "$llama_host" "$port" >&2
      local waited=0 timeout=300
      while (( waited < timeout )); do
        if curl -sf --max-time 2 "$remote_health" 2>/dev/null | jq -e '.status == "ok"' > /dev/null 2>&1; then
          echo " ready." >&2
          break
        fi
        printf "." >&2
        sleep 5
        waited=$((waited + 5))
      done
      if (( waited >= timeout )); then
        echo "" >&2
        echo "Timed out (${timeout}s)." >&2
        exit 1
      fi
    fi

    # Read actual context window from server (overrides profile — server may have been started with different -c)
    local actual_ctx
    actual_ctx=$(curl -sf --max-time 3 "http://${llama_host}:${port}/slots" 2>/dev/null | jq -r '.[0].n_ctx // empty')
    if [[ -n "$actual_ctx" && "$actual_ctx" != "$ctx_len" ]]; then
      echo "  Context: profile has ${ctx_len}, server reports ${actual_ctx} — using ${actual_ctx}" >&2
      ctx_len="$actual_ctx"
    fi

    save_last_session "llama" "$(basename "$profile")" "$llama_host" "$model_id"
    launch_claude exec "$model_id" "$llama_host" "$port" "$ctx_len" "${passthrough_args[@]}"
    return
  fi

  # ========================================================================
  # Local: scan GGUF files, configure, start llama-server, connect
  # ========================================================================

  # Model selection — skip when preloaded from profile picker
  if [[ -z "$model_id" ]]; then
    if [[ ! -d "$MODELS_DIR" ]]; then
      echo "Models directory not found: $MODELS_DIR" >&2
      exit 1
    fi

    local gguf_files=()
    local gguf_sizes=()
    local gguf_dirs=()

    while IFS= read -r -d '' fpath; do
      gguf_files+=("$fpath")
      gguf_sizes+=("$(_stat_size "$fpath")")
      gguf_dirs+=("$(basename "$(dirname "$(dirname "$fpath")")")")
    done < <(find "$MODELS_DIR" -name "*.gguf" -not -name "mmproj*" -print0 | sort -z)

    local model_count=${#gguf_files[@]}
    if (( model_count == 0 )); then
      echo "No GGUF models found in $MODELS_DIR" >&2
      exit 1
    fi

    echo "" >&2
    echo "Available GGUF models:" >&2
    echo "" >&2
    local fname hsize pdir saved_tag name_no_ext
    for ((i=0; i<model_count; i++)); do
      saved_tag=""
      fname="${gguf_files[$((i+1))]:t}"
      hsize=$(human_size "${gguf_sizes[$((i+1))]}")
      pdir="${gguf_dirs[$((i+1))]}"
      name_no_ext="${fname%.gguf}"
      [[ -f "$CONFIG_DIR/llama-$(slug "$name_no_ext").json" ]] && saved_tag=" *"
      printf "  %2d) %-42s %8s  (%s)%s\n" $((i+1)) "$fname" "$hsize" "$pdir" "$saved_tag" >&2
    done
    echo "" >&2
    echo "  (* = saved profile)" >&2
    echo "" >&2

    printf "Select model (1-%d): " "$model_count" >&2
    read -r selection

    if ! [[ "$selection" =~ ^[0-9]+$ ]] || (( selection < 1 || selection > model_count )); then
      echo "Invalid selection." >&2
      exit 1
    fi

    chosen_path="${gguf_files[$selection]}"
    chosen_fname="${chosen_path:t}"
    model_id="${chosen_fname%.gguf}"
    model_dir="${chosen_path:h}"
    profile="$CONFIG_DIR/llama-$(slug "$model_id").json"

    # --- mmproj detection (optional) ---
    mmproj_match=$(find "$model_dir" -name "mmproj*.gguf" -print -quit 2>/dev/null)
    if [[ -n "$mmproj_match" ]]; then
      echo "" >&2
      echo "Multimodal projector found: ${mmproj_match:t}" >&2
      echo "  Note: enabling mmproj disables slot save/restore (KV cache persistence)." >&2
      printf "  Load mmproj? (y/N): " >&2
      read -r mmproj_reply
      if [[ "$mmproj_reply" =~ ^[Yy]$ ]]; then
        mmproj_path="$mmproj_match"
      fi
    fi
  fi

  # --- Profile load or configure ---
  if [[ -f "$profile" ]] && ! $use_saved; then
    echo "" >&2
    echo "Saved profile for $model_id:" >&2
    echo "" >&2
    echo "  Loading:" >&2
    printf "    %-20s %s\n" "Context length:" "$(jq -r '.ctx_len' "$profile")" >&2
    printf "    %-20s %s\n" "GPU layers:" "$(jq -r '.gpu_layers' "$profile")" >&2
    printf "    %-20s %s\n" "Flash attention:" "$(jq -r '.flash_attn' "$profile")" >&2
    printf "    %-20s %s\n" "Cache type K:" "$(jq -r '.cache_type_k' "$profile")" >&2
    printf "    %-20s %s\n" "Cache type V:" "$(jq -r '.cache_type_v' "$profile")" >&2
    printf "    %-20s %s\n" "SWA full:" "$(jq -r '.swa_full' "$profile")" >&2
    printf "    %-20s %s\n" "Batch size:" "$(jq -r '.batch_size' "$profile")" >&2
    printf "    %-20s %s\n" "Ubatch size:" "$(jq -r '.ubatch_size' "$profile")" >&2
    echo "  Sampling:" >&2
    printf "    %-20s %s\n" "Temperature:" "$(jq -r '.temperature' "$profile")" >&2
    printf "    %-20s %s\n" "Top-P:" "$(jq -r '.top_p' "$profile")" >&2
    printf "    %-20s %s\n" "Top-K:" "$(jq -r '.top_k' "$profile")" >&2
    printf "    %-20s %s\n" "Min-P:" "$(jq -r '.min_p' "$profile")" >&2
    printf "    %-20s %s\n" "Repeat penalty:" "$(jq -r '.repeat_penalty' "$profile")" >&2
    echo "  Server:" >&2
    printf "    %-20s %s\n" "Port:" "$(jq -r '.port' "$profile")" >&2
    printf "    %-20s %s\n" "Parallel slots:" "$(jq -r '.parallel_slots' "$profile")" >&2
    printf "    %-20s %s\n" "Slot save path:" "$(jq -r '.slot_save_path // ""' "$profile")" >&2
    printf "    %-20s %s\n" "Cache RAM (MB):" "$(jq -r '.cache_ram // ""' "$profile")" >&2
    echo "" >&2
    printf "Use saved profile? (Y/n): " >&2
    read -r use_reply
    if [[ -z "$use_reply" || "$use_reply" =~ ^[Yy]$ ]]; then
      use_saved=true
    fi
  fi

  if $use_saved; then
    ctx_len=$(jq -r '.ctx_len' "$profile")
    gpu_layers=$(jq -r '.gpu_layers' "$profile")
    flash_attn=$(jq -r '.flash_attn' "$profile")
    cache_type_k=$(jq -r '.cache_type_k' "$profile")
    cache_type_v=$(jq -r '.cache_type_v' "$profile")
    swa_full=$(jq -r '.swa_full' "$profile")
    batch_size=$(jq -r '.batch_size' "$profile")
    ubatch_size=$(jq -r '.ubatch_size' "$profile")
    temperature=$(jq -r '.temperature' "$profile")
    top_p=$(jq -r '.top_p' "$profile")
    top_k=$(jq -r '.top_k' "$profile")
    min_p=$(jq -r '.min_p' "$profile")
    repeat_penalty=$(jq -r '.repeat_penalty' "$profile")
    port=$(jq -r '.port' "$profile")
    parallel_slots=$(jq -r '.parallel_slots' "$profile")
    slot_save_path=$(jq -r '.slot_save_path // ""' "$profile")
    cache_ram=$(jq -r '.cache_ram // ""' "$profile")
  else
    local d_ctx="65536" d_ngl="99" d_fa="on" d_ctk="q8_0" d_ctv="q8_0"
    local d_swa="true" d_bs="4096" d_ubs="1024"
    local d_temp="0.6" d_topp="0.95" d_topk="20" d_minp="0.00" d_rp="1.0"
    local d_port="8081" d_np="1" d_ssp="$HOME/.cache/cclm/slots" d_cram=""

    if [[ -f "$profile" ]]; then
      d_ctx=$(jq -r '.ctx_len' "$profile")
      d_ngl=$(jq -r '.gpu_layers' "$profile")
      d_fa=$(jq -r '.flash_attn' "$profile")
      d_ctk=$(jq -r '.cache_type_k' "$profile")
      d_ctv=$(jq -r '.cache_type_v' "$profile")
      d_swa=$(jq -r '.swa_full' "$profile")
      d_bs=$(jq -r '.batch_size' "$profile")
      d_ubs=$(jq -r '.ubatch_size' "$profile")
      d_temp=$(jq -r '.temperature' "$profile")
      d_topp=$(jq -r '.top_p' "$profile")
      d_topk=$(jq -r '.top_k' "$profile")
      d_minp=$(jq -r '.min_p' "$profile")
      d_rp=$(jq -r '.repeat_penalty' "$profile")
      d_port=$(jq -r '.port' "$profile")
      d_np=$(jq -r '.parallel_slots' "$profile")
      d_ssp=$(jq -r '.slot_save_path // ""' "$profile")
      d_cram=$(jq -r '.cache_ram // ""' "$profile")
    fi

    echo "" >&2
    echo "Configure llama-server parameters (press Enter for default):" >&2

    echo "" >&2
    echo "  Loading:" >&2
    ctx_len=$(ask "Context length" "$d_ctx")
    gpu_layers=$(ask "GPU layers" "$d_ngl")
    flash_attn=$(ask "Flash attention" "$d_fa")
    cache_type_k=$(ask "KV cache type K" "$d_ctk")
    cache_type_v=$(ask "KV cache type V" "$d_ctv")
    swa_full=$(ask "SWA full" "$d_swa")
    batch_size=$(ask "Batch size" "$d_bs")
    ubatch_size=$(ask "Ubatch size" "$d_ubs")

    echo "" >&2
    echo "  Sampling:" >&2
    temperature=$(ask "Temperature" "$d_temp")
    top_p=$(ask "Top-P" "$d_topp")
    top_k=$(ask "Top-K" "$d_topk")
    min_p=$(ask "Min-P" "$d_minp")
    repeat_penalty=$(ask "Repeat penalty" "$d_rp")

    echo "" >&2
    echo "  Server:" >&2
    port=$(ask "Port" "$d_port")
    parallel_slots=$(ask "Parallel slots" "$d_np")
    slot_save_path=$(ask "Slot save path" "$d_ssp")
    cache_ram=$(ask "Cache RAM (MB)" "$d_cram")

    jq -n \
      --arg ctx "$ctx_len" \
      --arg ngl "$gpu_layers" \
      --arg fa "$flash_attn" \
      --arg ctk "$cache_type_k" \
      --arg ctv "$cache_type_v" \
      --arg swa "$swa_full" \
      --arg bs "$batch_size" \
      --arg ubs "$ubatch_size" \
      --arg temp "$temperature" \
      --arg tp "$top_p" \
      --arg tk "$top_k" \
      --arg mp "$min_p" \
      --arg rp "$repeat_penalty" \
      --arg port "$port" \
      --arg np "$parallel_slots" \
      --arg ssp "$slot_save_path" \
      --arg cram "$cache_ram" \
      --arg model "$model_id" \
      --arg path "$chosen_path" \
      '{
        model: $model,
        model_path: $path,
        ctx_len: $ctx,
        gpu_layers: $ngl,
        flash_attn: $fa,
        cache_type_k: $ctk,
        cache_type_v: $ctv,
        swa_full: $swa,
        batch_size: $bs,
        ubatch_size: $ubs,
        temperature: $temp,
        top_p: $tp,
        top_k: $tk,
        min_p: $mp,
        repeat_penalty: $rp,
        port: $port,
        parallel_slots: $np,
        slot_save_path: (if $ssp == "" then null else $ssp end),
        cache_ram: (if $cram == "" then null else $cram end),
        remote_host: null
      }' > "$profile"

    echo "" >&2
    echo "Profile saved to $profile" >&2
  fi

  # --- Port conflict check ---
  if lsof -i ":${port}" -sTCP:LISTEN > /dev/null 2>&1; then
    echo "" >&2
    echo "Port ${port} is already in use." >&2
    local pid_on_port
    pid_on_port=$(lsof -ti ":${port}" -sTCP:LISTEN 2>/dev/null | head -1)
    printf "Kill process %s and continue? (y/N): " "$pid_on_port" >&2
    read -r kill_reply
    if [[ "$kill_reply" =~ ^[Yy]$ ]]; then
      kill "$pid_on_port" 2>/dev/null || true
      sleep 1
    else
      echo "Aborted." >&2
      exit 1
    fi
  fi

  # Build llama-server command
  local server_args=(
    "-m" "$chosen_path"
    "-c" "$ctx_len"
    "-ngl" "$gpu_layers"
    "--cache-type-k" "$cache_type_k"
    "--cache-type-v" "$cache_type_v"
    "-b" "$batch_size"
    "-ub" "$ubatch_size"
    "--temp" "$temperature"
    "--top-p" "$top_p"
    "--top-k" "$top_k"
    "--min-p" "$min_p"
    "--repeat-penalty" "$repeat_penalty"
    "--port" "$port"
    "-np" "$parallel_slots"
    "--jinja"
    "--metrics"
  )

  [[ -n "$flash_attn" ]] && server_args+=("--flash-attn" "$flash_attn")
  [[ "$swa_full" == "true" ]] && server_args+=("--swa-full")
  if [[ -n "$slot_save_path" ]]; then
    slot_save_path="${slot_save_path/#\~/$HOME}"
    mkdir -p "$slot_save_path"
    server_args+=("--slot-save-path" "$slot_save_path")
  fi
  [[ -n "$cache_ram" ]] && server_args+=("--cache-ram" "$cache_ram")
  [[ -n "$mmproj_path" ]] && server_args+=("--mmproj" "$mmproj_path")

  # Start server
  LLAMA_PID=""
  trap 'if [[ -n "${LLAMA_PID:-}" ]]; then kill "$LLAMA_PID" 2>/dev/null; wait "$LLAMA_PID" 2>/dev/null; fi' EXIT INT TERM

  echo "" >&2
  echo "Starting llama-server..." >&2
  echo "  Model: $model_id" >&2
  echo "  Port:  $port" >&2
  [[ -n "$mmproj_path" ]] && echo "  mmproj: ${mmproj_path:t}" >&2

  local server_log="/tmp/cclm-llama-server.log"
  llama-server "${server_args[@]}" > "$server_log" 2>&1 &
  LLAMA_PID=$!

  # Wait for health
  local health_url="http://localhost:${port}/health"
  local waited=0
  local timeout=120

  printf "Waiting for llama-server to load model..." >&2
  while (( waited < timeout )); do
    if ! kill -0 "$LLAMA_PID" 2>/dev/null; then
      echo "" >&2
      echo "llama-server exited unexpectedly. Check log: $server_log" >&2
      tail -5 "$server_log" >&2
      exit 1
    fi
    if curl -s "$health_url" 2>/dev/null | jq -e '.status == "ok"' > /dev/null 2>&1; then
      echo " ready." >&2
      break
    fi
    printf "." >&2
    sleep 2
    waited=$((waited + 2))
  done

  if (( waited >= timeout )); then
    echo "" >&2
    echo "Timed out waiting for llama-server (${timeout}s). Check log: $server_log" >&2
    tail -10 "$server_log" >&2
    kill "$LLAMA_PID" 2>/dev/null || true
    exit 1
  fi

  save_last_session "llama" "$(basename "$profile")" "$llama_host" "$model_id"
  launch_claude fg "$model_id" "$llama_host" "$port" "$ctx_len" "${passthrough_args[@]}"
}

# ============================================================================
# Z.ai GLM Backend (remote, Anthropic-compatible)
# Docs: https://docs.z.ai/devpack/tool/claude
# ============================================================================

run_zai() {
  # --- 1. API key ---
  # ZAI_API_KEY in env > interactive prompt + persist to ~/.zshenv.
  if [[ -z "${ZAI_API_KEY:-}" ]]; then
    echo "" >&2
    echo "Z.ai API key not found in \$ZAI_API_KEY." >&2
    echo "Get one at: https://z.ai/manage-apikey/apikey-list" >&2
    echo "" >&2
    printf "  Paste API key (input hidden): " >&2
    local _key
    read -rs _key
    echo "" >&2
    if [[ -z "$_key" ]]; then
      echo "No key provided. Aborting." >&2
      exit 1
    fi

    # Persist to ~/.zshenv — loaded by every zsh invocation (login or not),
    # unlike ~/.zshrc which is interactive-only.
    local zshenv="$HOME/.zshenv"
    touch "$zshenv"
    if grep -qE '^[[:space:]]*export[[:space:]]+ZAI_API_KEY=' "$zshenv" 2>/dev/null; then
      local _tmp
      _tmp="$(mktemp)"
      grep -vE '^[[:space:]]*export[[:space:]]+ZAI_API_KEY=' "$zshenv" > "$_tmp" || true
      mv "$_tmp" "$zshenv"
      echo "Replaced existing ZAI_API_KEY in $zshenv" >&2
    else
      echo "Saved ZAI_API_KEY to $zshenv (loaded by all zsh sessions)" >&2
    fi
    printf "export ZAI_API_KEY=%q\n" "$_key" >> "$zshenv"
    chmod 600 "$zshenv"
    export ZAI_API_KEY="$_key"
  fi

  # --- Preload fast-path (from profile picker) ---
  if [[ -n "${_PRELOADED_PROFILE:-}" ]]; then
    local profile="$_PRELOADED_PROFILE"
    if [[ "${_PRELOADED_ACTION:-open}" == "open" ]]; then
      # Fast launch: read profile, set env vars, connect
      local base_url opus_model sonnet_model haiku_model ctx timeout_ms
      base_url=$(jq -r '.base_url // ""' "$profile")
      opus_model=$(jq -r '.opus_model // ""' "$profile")
      sonnet_model=$(jq -r '.sonnet_model // ""' "$profile")
      haiku_model=$(jq -r '.haiku_model // ""' "$profile")
      ctx=$(jq -r '.context_length // 200000' "$profile")
      timeout_ms=$(jq -r '.api_timeout_ms // 3000000' "$profile")

      # Back-compat with old single-model schema
      local _legacy
      _legacy=$(jq -r '.model // ""' "$profile")
      [[ -z "$opus_model"   && -n "$_legacy" ]] && opus_model="$_legacy"
      [[ -z "$sonnet_model" && -n "$_legacy" ]] && sonnet_model="$_legacy"
      [[ -z "$haiku_model"  && -n "$_legacy" ]] && haiku_model="$_legacy"

      echo "" >&2
      echo "  [zai] $sonnet_model @ ${base_url}" >&2

      save_last_session "zai" "$(basename "$profile")" "$base_url" "$sonnet_model"
      export CCLM_AUTH_TOKEN="$ZAI_API_KEY"
      export CCLM_TIER_OPUS="$opus_model"
      export CCLM_TIER_SONNET="$sonnet_model"
      export CCLM_TIER_HAIKU="$haiku_model"
      export CCLM_API_TIMEOUT_MS="$timeout_ms"

      echo "" >&2
      echo "Tier routing:" >&2
      printf "  %-7s → %s\n" "Opus"   "$opus_model"   >&2
      printf "  %-7s → %s  (startup)\n" "Sonnet" "$sonnet_model" >&2
      printf "  %-7s → %s  (subagents)\n" "Haiku" "$haiku_model" >&2

      launch_claude exec "$sonnet_model" "$base_url" "" "$ctx" "${passthrough_args[@]}"
      return
    else
      # Edit: skip profile selection, set profile so existing flow uses it
      # The existing profile loading code will pick it up with use_saved=false
      local prof_name="${profile:t:r}"
      prof_name="${prof_name#zai-}"
      echo "" >&2
      echo "Editing profile: $prof_name" >&2
      # Fall through — the profile selection below will be skipped
    fi
  else
    local profile=""
  fi

  # --- 2. Profile selection ---
  if [[ -z "$profile" ]]; then
    # Profiles key on a user-chosen name so multiple deployments can coexist
    # (e.g., zai-payg, zai-coding-plan, zai-cheap).
    echo "" >&2
    echo "Z.ai profile:" >&2
    local -a zai_profiles
    zai_profiles=( "$CONFIG_DIR"/zai-*.json(N) )

    local i=1
    for f in "${zai_profiles[@]}"; do
      prof_name="${f:t:r}"            # basename, strip .json
      prof_name="${prof_name#zai-}"    # strip zai- prefix
      printf "  %d) %s\n" "$i" "$prof_name" >&2
      (( i++ ))
    done
    echo "  n) New profile" >&2
    printf "Choice: " >&2
    local pchoice
    read -r pchoice

    if [[ -z "$pchoice" || "$pchoice" == [nN] ]]; then
      local new_name
      new_name="$(ask 'Profile name' 'default')"
      profile="$CONFIG_DIR/zai-$(slug "$new_name").json"
    else
      if [[ "$pchoice" =~ ^[0-9]+$ ]] && (( pchoice >= 1 && pchoice <= ${#zai_profiles[@]} )); then
        profile="${zai_profiles[$pchoice]}"
      else
        echo "Invalid selection." >&2; exit 1
      fi
    fi
  fi

  # --- 3. Load saved values ---
  local d_base_url="" d_opus="" d_sonnet="" d_haiku=""
  local d_ctx="200000" d_timeout_ms="3000000"
  if [[ -f "$profile" ]]; then
    d_base_url=$(jq -r '.base_url // ""' "$profile")
    d_opus=$(jq -r '.opus_model // ""' "$profile")
    d_sonnet=$(jq -r '.sonnet_model // ""' "$profile")
    d_haiku=$(jq -r '.haiku_model // ""' "$profile")
    # Back-compat with old single-model profile schema.
    local _d_legacy
    _d_legacy=$(jq -r '.model // ""' "$profile")
    [[ -z "$d_opus"   && -n "$_d_legacy" ]] && d_opus="$_d_legacy"
    [[ -z "$d_sonnet" && -n "$_d_legacy" ]] && d_sonnet="$_d_legacy"
    [[ -z "$d_haiku"  && -n "$_d_legacy" ]] && d_haiku="$_d_legacy"
    d_ctx=$(jq -r '.context_length // 200000' "$profile")
    d_timeout_ms=$(jq -r '.api_timeout_ms // 3000000' "$profile")
  fi

  # --- 3b. Use saved profile as-is? (skip all prompts if yes) ---
  local use_saved=false
  # When preloaded with "edit" action, force use_saved=false to show config prompts
  if [[ "${_PRELOADED_ACTION:-}" == "edit" ]]; then
    use_saved=false
  elif [[ -f "$profile" && -n "$d_base_url" && -n "$d_opus" && -n "$d_sonnet" && -n "$d_haiku" ]]; then
    echo "" >&2
    echo "Saved profile:" >&2
    printf "  %-13s %s\n" "Base URL:" "$d_base_url"     >&2
    printf "  %-13s %s\n" "Opus:"     "$d_opus"         >&2
    printf "  %-13s %s\n" "Sonnet:"   "$d_sonnet"       >&2
    printf "  %-13s %s\n" "Haiku:"    "$d_haiku"        >&2
    printf "  %-13s %s\n" "Context:"  "$d_ctx"          >&2
    printf "  %-13s %s\n" "Timeout:"  "$d_timeout_ms"   >&2
    echo "" >&2
    printf "Use saved profile? (Y/n): " >&2
    local _use_reply
    read -r _use_reply
    [[ -z "$_use_reply" || "$_use_reply" =~ ^[Yy]$ ]] && use_saved=true
  fi

  # Output variables populated by either the saved-profile path or the prompts below.
  local base_url opus_model sonnet_model haiku_model ctx timeout_ms

  if $use_saved; then
    base_url="$d_base_url"
    opus_model="$d_opus"
    sonnet_model="$d_sonnet"
    haiku_model="$d_haiku"
    ctx="$d_ctx"
    timeout_ms="$d_timeout_ms"
  else
    # --- 4. Base URL ---
    echo "" >&2
    echo "Base URL:" >&2
    echo "  1) https://api.z.ai/api/anthropic        (official Claude Code endpoint — recommended)" >&2
    echo "  2) https://api.z.ai/api/coding/paas/v4   (Coding Plan subscription, OpenAI protocol)" >&2
    echo "  3) Custom" >&2
    local url_default_hint="1"
    [[ -n "$d_base_url" ]] && url_default_hint="current: $d_base_url"
    printf "Choice [%s]: " "$url_default_hint" >&2
    local uchoice
    read -r uchoice
    case "${uchoice:-}" in
      1) base_url="https://api.z.ai/api/anthropic" ;;
      2) base_url="https://api.z.ai/api/coding/paas/v4" ;;
      3) base_url="$(ask 'Custom base URL' "${d_base_url:-https://api.z.ai/api/anthropic}")" ;;
      "") base_url="${d_base_url:-https://api.z.ai/api/anthropic}" ;;
      *)  echo "Invalid selection." >&2; exit 1 ;;
    esac

    # --- 5. Per-tier model selection ---
    # Fetch live model list from Z.ai's OpenAI-compat /models endpoint
    # (the anthropic-compat endpoint doesn't expose one). Same API key works.
    echo "" >&2
    echo "Fetching model list from Z.ai..." >&2
    local models_json
    models_json="$(curl -sf --max-time 10 \
      -H "Authorization: Bearer $ZAI_API_KEY" \
      "https://api.z.ai/api/paas/v4/models" 2>/dev/null || echo '')"

    local -a model_ids
    if [[ -n "$models_json" ]] && echo "$models_json" | jq -e '.data' >/dev/null 2>&1; then
      model_ids=( "${(f)$(echo "$models_json" | jq -r '.data[].id' | sort -u)}" )
    else
      echo "  (/models fetch failed — using built-in list)" >&2
      model_ids=( glm-4.5 glm-4.5-air glm-4.6 glm-4.7 )
    fi

    # Heuristic defaults: Opus → glm-4.7 if present, Haiku → a *-air variant if present.
    local opus_default="${model_ids[1]}" haiku_default="${model_ids[${#model_ids[@]}]}"
    local _m
    for _m in "${model_ids[@]}"; do
      [[ "$_m" == "glm-4.7" ]] && opus_default="$_m"
      [[ "$_m" == *air* ]]    && haiku_default="$_m"
    done

    # Render the model list with a (current) marker for the given tier default.
    _zai_print_models() {
      local current="$1" idx=1 m
      for m in "${model_ids[@]}"; do
        if [[ "$m" == "$current" ]]; then
          printf "  %d) %s  (current)\n" "$idx" "$m" >&2
        else
          printf "  %d) %s\n" "$idx" "$m" >&2
        fi
        (( idx++ ))
      done
    }

    # Resolve a user choice ("1", "c", "s", "") to a model ID.
    # Args: choice, default_on_empty, same_as_value ("" if "s" isn't offered).
    _zai_resolve() {
      local choice="$1" default_m="$2" same_as="$3"
      case "$choice" in
        c|C) ask 'Custom model ID' "$default_m" ;;
        s|S)
          if [[ -n "$same_as" ]]; then echo "$same_as"
          else echo "Invalid selection." >&2; return 1; fi
          ;;
        "")  echo "$default_m" ;;
        *)
          if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#model_ids[@]} )); then
            echo "${model_ids[$choice]}"
          else
            echo "Invalid selection." >&2; return 1
          fi
          ;;
      esac
    }

    # --- Tier: Opus ---
    echo "" >&2
    echo "Model for OPUS tier (highest capability — /model opus inside Claude Code):" >&2
    _zai_print_models "$d_opus"
    echo "  c) Custom" >&2
    local _opus_def="${d_opus:-$opus_default}"
    printf "Choice [%s]: " "$_opus_def" >&2
    local opus_choice
    read -r opus_choice
    opus_model="$(_zai_resolve "$opus_choice" "$_opus_def" "")" || exit 1

    # --- Tier: Sonnet ---
    echo "" >&2
    echo "Model for SONNET tier (default conversation):" >&2
    _zai_print_models "$d_sonnet"
    echo "  s) Same as Opus ($opus_model)" >&2
    echo "  c) Custom" >&2
    local _sonnet_def="${d_sonnet:-$opus_model}"
    printf "Choice [%s]: " "$_sonnet_def" >&2
    local sonnet_choice
    read -r sonnet_choice
    sonnet_model="$(_zai_resolve "$sonnet_choice" "$_sonnet_def" "$opus_model")" || exit 1

    # --- Tier: Haiku ---
    echo "" >&2
    echo "Model for HAIKU tier (subagents, background, fast/cheap):" >&2
    _zai_print_models "$d_haiku"
    echo "  s) Same as Sonnet ($sonnet_model)" >&2
    echo "  c) Custom" >&2
    local _haiku_def="${d_haiku:-$haiku_default}"
    printf "Choice [%s]: " "$_haiku_def" >&2
    local haiku_choice
    read -r haiku_choice
    haiku_model="$(_zai_resolve "$haiku_choice" "$_haiku_def" "$sonnet_model")" || exit 1

    # --- 6. Context + timeout ---
    echo "" >&2
    ctx="$(ask 'Context length (tokens)' "$d_ctx")"
    timeout_ms="$(ask 'API_TIMEOUT_MS' "$d_timeout_ms")"

    # --- 7. Save profile ---
    jq -n \
      --arg url "$base_url" \
      --arg opus "$opus_model" \
      --arg sonnet "$sonnet_model" \
      --arg haiku "$haiku_model" \
      --argjson c "$ctx" \
      --argjson t "$timeout_ms" \
      '{base_url: $url, opus_model: $opus, sonnet_model: $sonnet, haiku_model: $haiku, context_length: $c, api_timeout_ms: $t}' \
      > "$profile"
    echo "" >&2
    echo "Profile saved." >&2
  fi

  # --- 8. Launch ---
  # Startup tier = Sonnet (Claude Code's default). User can /model opus or /model haiku in-session.
  save_last_session "zai" "$(basename "$profile")" "$base_url" "$sonnet_model"

  export CCLM_AUTH_TOKEN="$ZAI_API_KEY"
  export CCLM_TIER_OPUS="$opus_model"
  export CCLM_TIER_SONNET="$sonnet_model"
  export CCLM_TIER_HAIKU="$haiku_model"
  export CCLM_API_TIMEOUT_MS="$timeout_ms"

  echo "" >&2
  echo "Tier routing:" >&2
  printf "  %-7s → %s\n" "Opus"   "$opus_model"   >&2
  printf "  %-7s → %s  (startup)\n" "Sonnet" "$sonnet_model" >&2
  printf "  %-7s → %s  (subagents)\n" "Haiku" "$haiku_model" >&2

  launch_claude exec "$sonnet_model" "$base_url" "" "$ctx" "${passthrough_args[@]}"
}

# ============================================================================
# Main dispatch — backend is set by profile picker or backend picker above
# ============================================================================

case "$backend" in
  lms)   run_lms ;;
  llama) run_llama ;;
  zai)   run_zai ;;
esac
