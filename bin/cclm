#!/usr/bin/env zsh
# cclm - Claude Code via Local Models
# Supports LM Studio and llama.cpp (llama-server) backends.
# Selects a local model, configures load/server parameters, and launches Claude Code.
# Saves per-model profiles to ~/.config/cclm/ for reuse.

set -euo pipefail

# Opt-in stricter mode (set CCLM_STRICT=1) — warns on any new global variable
# created inside a function. Helps catch missing `local` declarations.
[[ "${CCLM_STRICT:-0}" == "1" ]] && setopt warn_create_global

CONFIG_DIR="$HOME/.config/cclm"
MODELS_DIR="${CCLM_MODELS_DIR:-$HOME/.cache/lm-studio/models}"
STATE_FILE="$CONFIG_DIR/.last_session"
# Path to Claude Code's global config (where mcpServers lives) and its backup.
# Overridable for tests; real users never need to touch these.
CCLM_CLAUDE_CONFIG="${CCLM_CLAUDE_CONFIG:-$HOME/.claude.json}"
CCLM_CLAUDE_BACKUP="${CCLM_CLAUDE_BACKUP:-$HOME/.claude.json.cclm-backup}"
mkdir -p "$CONFIG_DIR"

# Portable file size: macOS `stat -f%z`, Linux `stat -c%s`
if [[ "$(uname)" == "Darwin" ]]; then
  _stat_size() { stat -f%z "$1"; }
else
  _stat_size() { stat -c%s "$1"; }
fi

# ============================================================================
# Helpers
# ============================================================================

# Slugify a string into a safe filename
slug() { echo "$1" | tr '/' '_' | tr ' ' '-' | tr -cd 'A-Za-z0-9._-'; }

# Prompt with a default value. Prompt goes to stderr, value to stdout.
ask() {
  local label="$1" default="$2" reply
  if [[ -n "$default" ]]; then
    printf "  %-24s [%s]: " "$label" "$default" >&2
  else
    printf "  %-24s: " "$label" >&2
  fi
  read -r reply
  echo "${reply:-$default}"
}

# Display a saved profile and ask if the user wants to reuse it.
# Returns 0 if user accepts, 1 otherwise (missing file, edit mode, or "n").
# Args: profile_path, field_specs... — each spec is "label|jq_filter[|group]"
display_profile_and_ask() {
  local profile="$1"; shift
  [[ -f "$profile" ]] || return 1
  if [[ "${EDIT_MODE:-false}" == "true" || "${_PRELOADED_ACTION:-}" == "edit" ]]; then
    return 1
  fi

  echo "" >&2
  echo "Saved profile:" >&2
  local last_group="" spec label jq_filter group val reply
  for spec in "$@"; do
    IFS='|' read -r label jq_filter group <<< "$spec"
    if [[ "$group" != "$last_group" ]]; then
      [[ -n "$group" ]] && echo "  ${group}:" >&2
      last_group="$group"
    fi
    val=$(jq -r "$jq_filter" "$profile" 2>/dev/null || echo "?")
    [[ -z "$val" || "$val" == "null" ]] && val="-"
    printf "    %-22s %s\n" "$label:" "$val" >&2
  done
  echo "" >&2
  printf "Use saved profile? (Y/n): " >&2
  read -r reply
  [[ -z "$reply" || "$reply" =~ ^[Yy]$ ]]
}

# Poll until URL responds with jq filter returning success.
# Usage: poll_until_ready <url> <jq_filter> <timeout_sec> <sleep_sec> <label>
poll_until_ready() {
  local url="$1" jq_filter="$2" timeout="$3" sleep_interval="$4" label="${5:-server}"
  local waited=0
  printf "  Waiting for %s..." "$label" >&2
  while (( waited < timeout )); do
    if curl -sf --max-time 2 "$url" 2>/dev/null | jq -e "$jq_filter" > /dev/null 2>&1; then
      echo " ready." >&2
      return 0
    fi
    printf "." >&2
    sleep "$sleep_interval"
    waited=$((waited + sleep_interval))
  done
  echo "" >&2
  echo "Timed out waiting for ${label} (${timeout}s)." >&2
  return 1
}

print_tier_routing() {
  echo "" >&2
  echo "Tier routing:" >&2
  printf "  %-7s → %s\n" "Opus"   "$1" >&2
  printf "  %-7s → %s  (startup)\n" "Sonnet" "$2" >&2
  printf "  %-7s → %s  (subagents)\n" "Haiku" "$3" >&2
}

# Validate an endpoint is reachable and (where applicable) confirms the model id.
# Usage: _cclm_validate_endpoint <url> <model> <backend>
# Returns 0 if reachable + model confirmed, 1 otherwise.
# Silent on success. Callers are responsible for honoring DRY_RUN / CCLM_SKIP_VALIDATE.
# Note: curl's --max-time 2 hard-caps every request, so a hanging endpoint
# cannot stall profile creation for more than a couple seconds per probe.
_cclm_validate_endpoint() {
  local url="$1" model="$2" backend="$3"
  case "$backend" in
    llama)
      curl -sf --max-time 2 "${url}/health" 2>/dev/null \
        | jq -e '.status == "ok"' >/dev/null 2>&1
      ;;
    lms|remote|ollama|vllm)
      curl -sf --max-time 2 "${url}/v1/models" 2>/dev/null \
        | jq -e --arg m "$model" '.data[] | select(.id == $m)' >/dev/null 2>&1
      ;;
    zai)
      # Best-effort: count_tokens may 404 on some deployments. Treat non-2xx
      # as WARN (return 0) rather than FAIL so we don't block a known-good key.
      # Requires ANTHROPIC_AUTH_TOKEN (or ZAI_API_KEY) in env for the x-api-key header.
      local _zk="${ANTHROPIC_AUTH_TOKEN:-${ZAI_API_KEY:-}}"
      curl -sf --max-time 2 -H "x-api-key: ${_zk}" "${url}/v1/messages/count_tokens" >/dev/null 2>&1
      # Force success regardless — treat non-2xx as a warning, not a hard fail.
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# Prompt the user to save an unreachable profile. Returns 0 if save should proceed, 1 otherwise.
# Only called from the failure path of _cclm_validate_endpoint.
_cclm_confirm_unreachable_save() {
  local reply
  printf "⚠  Endpoint not reachable or model not found. Save anyway? (y/N): " >&2
  read -r reply
  [[ "$reply" =~ ^[Yy]$ ]]
}

